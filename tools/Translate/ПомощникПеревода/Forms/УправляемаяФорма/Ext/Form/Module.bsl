&НаКлиенте
Процедура ПроверитьСтрокуНаКорректность(Стр)
	Стр = СтрЗаменить(Стр,"% 1","%1");
	Стр = СтрЗаменить(Стр,"% 2","%2");
	Стр = СтрЗаменить(Стр,"% 3","%3");
	Стр = СтрЗаменить(Стр,"% 4","%4");
	Стр = СтрЗаменить(Стр,"% 5","%5");
	Стр = СтрЗаменить(Стр,"% 6","%6");
	Стр = СтрЗаменить(Стр,"% 7","%7");
	
	
	Поз1 = Найти(Стр,"%1");
	Поз2 = Найти(Стр,"%2");
	Поз3 = Найти(Стр,"%3");
	Поз4 = Найти(Стр,"%4");
	Поз5 = Найти(Стр,"%5");
	Поз6 = Найти(Стр,"%6");
	Поз7 = Найти(Стр,"%7");
	
	Если Поз1 > 0 и Поз2 > 0 Тогда
		Если Поз2 < Поз1 Тогда
			Сообщить("Ошибка в строке1: " + ВывестиСтрокуИзXML(Стр));
		КонецЕсли;	 
	КонецЕсли;	 
	
	Если Поз2 > 0 и Поз3 > 0 Тогда
		Если Поз3 < Поз2 Тогда
			Сообщить("Ошибка в строке2: " + ВывестиСтрокуИзXML(Стр));
		КонецЕсли;	 
		
		Если Поз1 = 0 Тогда
			Сообщить("Ошибка в строке2: " + ВывестиСтрокуИзXML(Стр));
		КонецЕсли;	 
	КонецЕсли;	 
	
	Если Поз3 > 0 и Поз4 > 0 Тогда
		Если Поз4 < Поз3 Тогда
			Сообщить("Ошибка в строке3: " + ВывестиСтрокуИзXML(Стр));
		КонецЕсли;	 
		
		Если Поз1 = 0 Тогда
			Сообщить("Ошибка в строке2: " + ВывестиСтрокуИзXML(Стр));
		ИначеЕсли Поз2 = 0 Тогда
			Сообщить("Ошибка в строке2: " + ВывестиСтрокуИзXML(Стр));
		КонецЕсли;	 
	КонецЕсли;	 
	
	Если Поз4 > 0 и Поз5 > 0 Тогда
		Если Поз5 < Поз4 Тогда
			Сообщить("Ошибка в строке4: " + ВывестиСтрокуИзXML(Стр));
		КонецЕсли;	 
		
		Если Поз1 = 0 Тогда
			Сообщить("Ошибка в строке2: " + ВывестиСтрокуИзXML(Стр));
		ИначеЕсли Поз2 = 0 Тогда
			Сообщить("Ошибка в строке2: " + ВывестиСтрокуИзXML(Стр));
		ИначеЕсли Поз3 = 0 Тогда
			Сообщить("Ошибка в строке2: " + ВывестиСтрокуИзXML(Стр));
		КонецЕсли;	 
	КонецЕсли;	 
	
	Если Поз5 > 0 и Поз6 > 0 Тогда
		Если Поз6 < Поз5 Тогда
			Сообщить("Ошибка в строке5: " + ВывестиСтрокуИзXML(Стр));
		КонецЕсли;	 
		
		Если Поз1 = 0 Тогда
			Сообщить("Ошибка в строке2: " + ВывестиСтрокуИзXML(Стр));
		ИначеЕсли Поз2 = 0 Тогда
			Сообщить("Ошибка в строке2: " + ВывестиСтрокуИзXML(Стр));
		ИначеЕсли Поз3 = 0 Тогда
