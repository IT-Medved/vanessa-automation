		Если Не ЭтоМакетПереводаСообщений(Массив) Тогда
			Продолжить;
		КонецЕсли;	 
		
		
		Сообщить(Файл.ПолноеИмя);
		
		КоличествоСтрокМакета = 0;
		ИдСтрокиМассива = -1;
		
		НашлиСтрокуВМакете = Ложь;
		Сч = -1;
		Для Каждого Стр Из Массив Цикл
			КоличествоСтрокМакета = КоличествоСтрокМакета + 1;
			Сч = Сч + 1;
			Если Найти(Стр,"<v8:content>") > 0 Тогда
				Стр = СтрЗаменить(Стр,"<v8:content>","");
				Стр = СтрЗаменить(Стр,"</v8:content>","");
				Стр = СокрЛП(Стр);
				
				//Если Найти(Стр,", а оно должно было быть.") > 0 Тогда
				//	вава = 1;
				//КонецЕсли;	 
				
				Если Стр = СтрокаИсходникМакет Тогда
					НашлиСтрокуВМакете = Истина;
					Массив[Сч] = "							<v8:content>" + СтрокаЗаменыМакет + "</v8:content>";
				КонецЕсли;	 
			КонецЕсли;	 
		КонецЦикла;	
		//Сообщить("КоличествоСтрокМакета="+КоличествоСтрокМакета);
		
		
		Если НЕ НашлиСтрокуВМакете Тогда
			ВызватьИсключение "Не нашли строку <" + СтрокаИсходник + "> в макете <" + Файл.ПолноеИмя + ">";
		КонецЕсли;	 
		
		ВременныйФайл = ПолучитьИмяВременногоФайла("xml");
		ЗТ = Новый ЗаписьТекста(ВременныйФайл,"UTF-8",,Истина); 
		Для Каждого Стр Из Массив Цикл
			ЗТ.ЗаписатьСтроку(Стр); 
		КонецЦикла;	
		ЗТ.Закрыть();
		
		КопироватьФайл(ВременныйФайл,Файл.ПолноеИмя);
	КонецЦикла;	
	
КонецПроцедуры

&НаКлиенте
Функция ПрочитатьОбъектJSON(ДанныеJSON, ПрочитатьВСоответствие = Ложь) Экспорт
	#Если НЕ ВебКлиент Тогда

	ЧтениеJSON = New ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ДанныеJSON);
	Значение = ПрочитатьJSON(ЧтениеJSON, ПрочитатьВСоответствие);
	ЧтениеJSON.Закрыть();
	Возврат Значение;
	
	#КонецЕсли
КонецФункции

&НаКлиенте
Процедура ВставитьВМакетыСтрокиИзМассиваJson(Команда)
	Файл = Новый Файл(ПутьКОбработке);
	
	Файлы = НайтиФайлы(Файл.Путь + "\locales\Messages\Templates","*.xml",Истина);
	Для Каждого Файл Из Файлы Цикл
		Текст = Новый ЧтениеТекста;
		Текст.Открыть(Файл.ПолноеИмя,"UTF-8");
		
		Массив = Новый Массив;
		Пока Истина Цикл
			Стр = Текст.ПрочитатьСтроку();
			Если Стр = Неопределено Тогда
				Прервать;
			КонецЕсли;	 
			
			Массив.Добавить(Стр);
		КонецЦикла;	
		Текст.Закрыть();
		
		Если Не ЭтоМакетПереводаСообщений(Массив) Тогда
			Продолжить;
		КонецЕсли;	 
		
		
		Сообщить(Файл.ПолноеИмя);
		
		КоличествоСтрокМакета = 0;
		ИдСтрокиМассива = -1;
		
		Сч = -1;
		Для Каждого Стр Из Массив Цикл
			Сч = Сч + 1;
			Если Найти(Стр,"</index>") > 0 Тогда
				Стр = СтрЗаменить(Стр,"</index>","");
				Стр = СтрЗаменить(Стр,"<index>","");
				Стр = XMLСтрока(СокрЛП(Стр));
				ПромЧисло = Число(Стр);
				
				Если КоличествоСтрокМакета < ПромЧисло Тогда
					КоличествоСтрокМакета = ПромЧисло;
					ИдСтрокиМассива       = Сч;
				КонецЕсли;	 
			КонецЕсли;	 
		КонецЦикла;	
		Сообщить("КоличествоСтрокМакета="+КоличествоСтрокМакета);
		
		
		РазмерСекции = 27;
		
		ИдСтрокиМассива = ИдСтрокиМассива - 1;
		//это строка "	<rowsItem>"
		
		Секция = Новый Массив;
		Для Ккк = 1 По РазмерСекции Цикл
			ИдСтроки = ИдСтрокиМассива + Ккк  -1;
			Стр      = Массив.Получить(ИдСтроки);
			Секция.Добавить(Стр);
		КонецЦикла;	
		
		Если Найти(Секция[РазмерСекции-1],"</rowsItem>") = 0 Тогда
			//Сообщить(Файл.ПолноеИмя + ", Ошибка при чтении строки макета в исходниках.");
			//Продолжить;
			
			ВызватьИсключение "Ошибка при чтении строки макета в исходниках.";
		КонецЕсли;	 
		
		ИдСтрокиМассива = ИдСтрокиМассива + РазмерСекции;
		
		НовыйМассив = Новый Массив;
		Для Ккк = 0 По ИдСтрокиМассива-1 Цикл
			Стр = Массив.Получить(Ккк);
			НовыйМассив.Добавить(Стр);
		КонецЦикла;	
		
		МассивЗначенийДляВставки = ПрочитатьОбъектJSON(СтрокаДляВставкиВМакет);
		Если СокрЛП(МассивЗначенийДляВставки[МассивЗначенийДляВставки.Количество()-1]) = "" Тогда
			МассивЗначенийДляВставки.Удалить(МассивЗначенийДляВставки.Количество()-1);
		КонецЕсли;	 
		
		Для НомерВставляемойСтроки = 1 По МассивЗначенийДляВставки.Количество() Цикл
			ЗначениеДляВставки = СокрЛП(МассивЗначенийДляВставки[НомерВставляемойСтроки-1]);
			Счетчик_tl = 0;
			Для Каждого Стр Из Секция Цикл
				Если Найти(Стр,"</index>") > 0 Тогда
					Стр = "		<index>" + XMLСтрока(КоличествоСтрокМакета+НомерВставляемойСтроки) + "</index>";
				ИначеЕсли Найти(Стр,"<tl>") > 0 Тогда
					Счетчик_tl = Счетчик_tl + 1;
				ИначеЕсли (Найти(Стр,"<v8:content>") > 0) и (Счетчик_tl = 1) Тогда
					Стр = "							<v8:content>" + ВернутьСтрокуВXML(ЗначениеДляВставки) + "</v8:content>";
					
				ИначеЕсли (Найти(Стр,"<v8:content>") > 0) и (Счетчик_tl = 2) Тогда
					Стр = "							<v8:content>Translation not found</v8:content>";
				КонецЕсли;	 
				
				НовыйМассив.Добавить(Стр);
			КонецЦикла;	
		КонецЦикла;	
		
		КоличествоЗначенийДляВставки = МассивЗначенийДляВставки.Количество();
		
		//подвал
		Для Ккк = ИдСтрокиМассива По Массив.Количество()-1 Цикл
			Стр = Массив.Получить(Ккк);
			Если Найти(Стр,"<height>" + XMLСтрока(КоличествоСтрокМакета+1) + "</height>") > 0 Тогда
				Стр = "	<height>" + XMLСтрока(КоличествоСтрокМакета+КоличествоЗначенийДляВставки+1) + "</height>";
			ИначеЕсли Найти(Стр,"<vgRows>" + XMLСтрока(КоличествоСтрокМакета+1) + "</vgRows>") > 0 Тогда
				Стр = "	<vgRows>" + XMLСтрока(КоличествоСтрокМакета+КоличествоЗначенийДляВставки+1) + "</vgRows>";
			КонецЕсли;	 
			
			НовыйМассив.Добавить(Стр);
		КонецЦикла;	
		
		
		ВременныйФайл = ПолучитьИмяВременногоФайла("xml");
		ЗТ = Новый ЗаписьТекста(ВременныйФайл,"UTF-8",,Истина); 
		Для Каждого Стр Из НовыйМассив Цикл
			ЗТ.ЗаписатьСтроку(Стр); 
		КонецЦикла;	
		ЗТ.Закрыть();
		
		КопироватьФайл(ВременныйФайл,Файл.ПолноеИмя);
	КонецЦикла;
	
КонецПроцедуры

