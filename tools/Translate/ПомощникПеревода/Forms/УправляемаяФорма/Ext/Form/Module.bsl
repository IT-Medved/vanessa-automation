&НаКлиенте
Процедура ЗагрузитьФайлВМассив(Файл,Массив)
	Текст = Новый ЧтениеТекста;
	Текст.Открыть(Файл.ПолноеИмя,"UTF-8");
	
	Пока Истина Цикл
		Стр = Текст.ПрочитатьСтроку();
		Если Стр = Неопределено Тогда
			Прервать;
		КонецЕсли;	 
		
		Массив.Добавить(Стр);
	КонецЦикла;	
	
	Текст.Закрыть();
КонецПроцедуры

&НаКлиенте
Функция ПолучитьТекущееЗначениеСекцииСПереводами(Массив,Знач Ном,НачалоСекции,ОкончаниеСекции)
	НачалоСекции = -1;
	Пока Истина Цикл
		Ном = Ном - 1;
		ТекСтр = Массив[Ном];
		
		Если СокрЛП(ТекСтр) = "<Title>" Тогда
			НачалоСекции = Ном;
			Прервать;
		КонецЕсли;	 
		Если СокрЛП(ТекСтр) = "<Synonym>" Тогда
			НачалоСекции = Ном;
			Прервать;
		КонецЕсли;	 
		Если СокрЛП(ТекСтр) = "<ToolTip>" Тогда
			НачалоСекции = Ном;
			Прервать;
		КонецЕсли;	 
		Если СокрЛП(ТекСтр) = "<Presentation>" Тогда
			НачалоСекции = Ном;
			Прервать;
		КонецЕсли;	 
	КонецЦикла;	
	
	МассивСекции = Новый Массив;
	
	Ном = НачалоСекции-1;
	Пока Истина Цикл
		Ном = Ном + 1;
		
		ТекСтр = Массив[Ном];
		МассивСекции.Добавить(ТекСтр);
		
		ОкончаниеСекции = Ном;
		
		Если СокрЛП(ТекСтр) = "</Title>" Тогда
			Прервать;
		КонецЕсли;	 
		Если СокрЛП(ТекСтр) = "</Synonym>" Тогда
			Прервать;
		КонецЕсли;	 
		Если СокрЛП(ТекСтр) = "</ToolTip>" Тогда
			Прервать;
		КонецЕсли;	 
		Если СокрЛП(ТекСтр) = "</Presentation>" Тогда
			Прервать;
		КонецЕсли;	 
	КонецЦикла;	
	
	Возврат МассивСекции;
КонецФункции	

&НаКлиенте
Функция ЯзыкУжеЕстьВСекции(ТекущееЗначениеСекцииСПереводами,ТекЯзык)
	СтрокаПоиска = "<v8:lang>" + ТекЯзык + "</v8:lang>";
	Для Каждого Стр Из ТекущееЗначениеСекцииСПереводами Цикл
		Если СокрЛП(НРег(Стр)) = СтрокаПоиска Тогда
			Возврат Истина;
		КонецЕсли;	 
	КонецЦикла;	
	
	Возврат Ложь;
КонецФункции	

&НаКлиенте
Функция ЗначениеДляПеревода(ТекущееЗначениеСекцииСПереводами,ЗначениеДляПеревода)
	СтрокаПоиска = "<v8:lang>" + БратьДляПеревода + "</v8:lang>";
	
	Ном = -1;
	Для Каждого Стр Из ТекущееЗначениеСекцииСПереводами Цикл
		Ном = Ном + 1;
		Если СокрЛП(НРег(Стр)) = СтрокаПоиска Тогда
			НужнаяСтрока = ТекущееЗначениеСекцииСПереводами[Ном+1];
			НужнаяСтрока = СтрЗаменить(НужнаяСтрока,"<v8:content>","");
			НужнаяСтрока = СтрЗаменить(НужнаяСтрока,"</v8:content>","");
			Возврат СокрЛП(НужнаяСтрока);
		КонецЕсли;	 
	КонецЦикла;	
	
	ВызватьИсключение "Не нашел строку оригинал для перевода по строке поиска <" + СтрокаПоиска + ">. Значение для перевода <" + ЗначениеДляПеревода + ">";
КонецФункции	

&НаКлиенте
Функция ПеревестиВыражение(Текст,Язык1,Язык2)
	НаправлениеПеревода = Язык1 + "-" + Язык2;
	ТекстПеревод = МойОбъект.Translate(Ключ,  НаправлениеПеревода, Текст);
	
	Возврат ТекстПеревод;
КонецФункции	

&НаКлиенте
Процедура ДобавитьПереводВСекцию(Перевод,ТекЯзык,ТекущееЗначениеСекцииСПереводами)
	КолСтрок = ТекущееЗначениеСекцииСПереводами.Количество();
	ТекущееЗначениеСекцииСПереводами.Вставить(КолСтрок-1,"</v8:item>");
	ТекущееЗначениеСекцииСПереводами.Вставить(КолСтрок-1,"<v8:content>" + Перевод + "</v8:content>");
	ТекущееЗначениеСекцииСПереводами.Вставить(КолСтрок-1,"<v8:lang>" + ТекЯзык + "</v8:lang>");
	ТекущееЗначениеСекцииСПереводами.Вставить(КолСтрок-1,"<v8:item>");
КонецПроцедуры

&НаКлиенте
Процедура ЗаменитьПереводВСекции(Перевод,ТекЯзык,ТекущееЗначениеСекцииСПереводами)
	СтрокаПоиска = "<v8:lang>" + ТекЯзык + "</v8:lang>";
	
	Ном = -1;
	Для Каждого Стр Из ТекущееЗначениеСекцииСПереводами Цикл
		Ном = Ном + 1;
		Если СокрЛП(НРег(Стр)) = СтрокаПоиска Тогда
			ТекущееЗначениеСекцииСПереводами[Ном+1] = "<v8:content>" + Перевод + "</v8:content>";
			Возврат;
		КонецЕсли;	 
	КонецЦикла;	
	
	ВызватьИсключение "Не смог заменить перевод в секции по строк поиска <" + СтрокаПоиска + ">";
КонецПроцедуры

&НаКлиенте
Процедура ЗаменитьСекцию(Массив,НачалоСекции,ТекущееЗначениеСекцииСПереводами)
	//Пока Массив.Количество()-1 >= НачалоСекции Цикл
	//	Массив.Удалить(Массив.Количество()-1);
	//КонецЦикла;	
	
	Ном = Массив.Количество();
	Пока Истина Цикл
		Ном = Ном - 1;
		ТекСтр = СокрЛП(Массив[Ном]);
		
		Массив.Удалить(Ном);
		
		Если ТекСтр = "<Title>" Тогда
			Прервать;
		КонецЕсли;	 
		Если ТекСтр = "<Synonym>" Тогда
			Прервать;
		КонецЕсли;	 
		Если ТекСтр = "<ToolTip>" Тогда
			Прервать;
		КонецЕсли;	 
		Если ТекСтр = "<Presentation>" Тогда
			Прервать;
		КонецЕсли;	 
	КонецЦикла;	
	
	Для Каждого Стр Из ТекущееЗначениеСекцииСПереводами Цикл
		Массив.Добавить(Стр);
	КонецЦикла;	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьФайл(Файл)
	Массив = Новый Массив;
	ЗагрузитьФайлВМассив(Файл,Массив);
	
	НовыйМассив = Новый Массив;
	
	НадоОбновитьФайл = Ложь;
	
	СтрокаПоиска = "<v8:lang>" + ПризнакЧтоНадоПереводить + "</v8:lang>";
	Ном = -1;
	Пока Истина Цикл
		Ном = Ном + 1;
		Если Ном > Массив.Количество()-1 Тогда
			Прервать;
		КонецЕсли;	 
		
		Стр = Массив[Ном];
		
		Если СокрЛП(НРег(Стр)) = СтрокаПоиска Тогда
			НачалоСекции    = -1;
			ОкончаниеСекции = -1;
			ТекущееЗначениеСекцииСПереводами = ПолучитьТекущееЗначениеСекцииСПереводами(Массив,Ном,НачалоСекции,ОкончаниеСекции);
			
			ДобавлялиПеревод = Ложь;
			Для Каждого СтрокаТаблицаЯзыков Из ТаблицаЯзыков Цикл
				ТекЯзык = СтрокаТаблицаЯзыков.Язык;
				
				ЯзыкУжеЕстьВСекции = ЯзыкУжеЕстьВСекции(ТекущееЗначениеСекцииСПереводами,ТекЯзык);
				
				ЗначениеДляПеревода = ЗначениеДляПеревода(ТекущееЗначениеСекцииСПереводами,ЗначениеДляПеревода);
				Перевод             = ПеревестиВыражение(ЗначениеДляПеревода,БратьДляПеревода,ТекЯзык);
				
				Если НЕ ЯзыкУжеЕстьВСекции Тогда
					ДобавитьПереводВСекцию(Перевод,ТекЯзык,ТекущееЗначениеСекцииСПереводами);
					ДобавлялиПеревод = Истина;
				Иначе
					ЗаменитьПереводВСекции(Перевод,ТекЯзык,ТекущееЗначениеСекцииСПереводами);
					ДобавлялиПеревод = Истина;
				КонецЕсли;	 
			КонецЦикла;	
			
			Если ДобавлялиПеревод Тогда
				НадоОбновитьФайл = Истина;
				ЗаменитьСекцию(НовыйМассив,НачалоСекции,ТекущееЗначениеСекцииСПереводами);
				Если ОкончаниеСекции < Ном Тогда
					ВызватьИсключение "Ошибка определения секции. ОкончаниеСекции="+ОкончаниеСекции + ", Ном="+Ном;
				КонецЕсли;	 
				
				Ном = ОкончаниеСекции;
				Продолжить;
			КонецЕсли;	 
		КонецЕсли;	 
		
		НовыйМассив.Добавить(Стр);
	КонецЦикла;	
	
	
	Если НЕ НадоОбновитьФайл Тогда
		Возврат;
	КонецЕсли;	 
	
	ВременныйФайл = ПолучитьИмяВременногоФайла("xml");
	ЗТ = Новый ЗаписьТекста(ВременныйФайл,"UTF-8",,Истина); 
	Для Каждого Стр Из НовыйМассив Цикл
		ЗТ.ЗаписатьСтроку(Стр); 
	КонецЦикла;	
	ЗТ.Закрыть();
	
	
	КопироватьФайл(ВременныйФайл,Файл.ПолноеИмя);
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьПереводПоТаблице(Команда)
	МассивФайлов = НайтиФайлы(КаталогФайлов,"*.xml",Истина);
	
	Для Каждого Файл Из МассивФайлов Цикл
		Сообщить("" + Файл.ПолноеИмя);
		ОбработатьФайл(Файл);
	КонецЦикла;	
КонецПроцедуры

&НаКлиенте
Функция ВыделитьПолезнуюСтроку(Стр)
	Если Прав(Стр,1) = ";" Тогда
		Стр = Лев(Стр,СтрДлина(Стр)-1);
	КонецЕсли;	 
	
	Если Прав(Стр,1) = ")" Тогда
		Стр = Лев(Стр,СтрДлина(Стр)-1);
	КонецЕсли;	 
	
	Если Прав(Стр,1) = """" Тогда
		Стр = Лев(Стр,СтрДлина(Стр)-1);
	КонецЕсли;	 
	
	Если Лев(Стр,1) = """" Тогда
		Стр = Сред(Стр,2);
	КонецЕсли;	 
	
	Возврат Стр;
КонецФункции	 

