	Тзн.Сортировать("Стр");
	
	
	МассивНовый = Новый Массив;
	Для Каждого СтрТзн Из Тзн Цикл
		МассивНовый.Добавить(СтрТзн.Стр);
	КонецЦикла;	
	
	Возврат МассивНовый;
