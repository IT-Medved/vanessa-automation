		КонецЕсли;	 
		
		
		Стр = СтрЗаменить(Стр,"Сообщить(","");
		Если Прав(Стр,1) = ";" Тогда
			Стр = Лев(Стр,СтрДлина(Стр)-1);
		КонецЕсли;	 
		Если Прав(Стр,1) = ")" Тогда
			Стр = Лев(Стр,СтрДлина(Стр)-1);
		КонецЕсли;	 
		
		Стр = ВыделитьПолезнуюСтроку(Стр);
		
		Возврат Стр;
	ИначеЕсли Лев(НРег(Стр),18) = НРег("ВызватьИсключение ") Тогда
		
		
		Если Найти(НРег(Стр),НРег("""")) = 0 Тогда
			Возврат Неопределено;
		КонецЕсли;	 
		
		ПромСтр = СокрЛП(Сред(Стр,18));
		Если Лев(ПромСтр,1) <> """" Тогда
			Возврат Неопределено;
		КонецЕсли;	 
		
		
		Стр = СтрЗаменить(Стр,"ВызватьИсключение","");
		Стр = СокрЛП(Стр);
		
		Если Прав(Стр,1) = ";" Тогда
			Стр = Лев(Стр,СтрДлина(Стр)-1);
		КонецЕсли;	 
		Если Прав(Стр,1) = ")" Тогда
			Стр = Лев(Стр,СтрДлина(Стр)-1);
		КонецЕсли;	 
		
		Стр = ВыделитьПолезнуюСтроку(Стр);
		Возврат Стр;
	КонецЕсли;	 
	
	Возврат Неопределено;
КонецФункции	 

&НаКлиенте
Функция ПроверитьСтрокуНаПравильность(Стр)
	Если Стр = "%1 %2" Тогда
		Возврат Неопределено;
	ИначеЕсли Стр = "%1. %2" Тогда
		Возврат Неопределено;
	ИначеЕсли Стр = "Failed: %1" Тогда
		Возврат Неопределено;
	ИначеЕсли Стр = "Pending: %1" Тогда
		Возврат Неопределено;
	ИначеЕсли Стр = "Sleep:%1" Тогда
		Возврат Неопределено;
	ИначеЕсли Стр = "%1 = %2" Тогда
		Возврат Неопределено;
	ИначеЕсли Стр = "%1.%2" Тогда
		Возврат Неопределено;
	ИначеЕсли Стр = "" Тогда
		Возврат Неопределено;
	ИначеЕсли Стр = " " Тогда
		Возврат Неопределено;
	ИначеЕсли Стр = "ffmpeg - OK" Тогда
		Возврат Неопределено;
	ИначеЕсли Стр = "ImageMagic - OK" Тогда
		Возврат Неопределено;
	ИначеЕсли Стр = "oscript - OK" Тогда
		Возврат Неопределено;
	ИначеЕсли Стр = "VLC 2.1.5 - OK" Тогда
		Возврат Неопределено;
	КонецЕсли;	 
	
	Возврат Стр;
КонецФункции	  

