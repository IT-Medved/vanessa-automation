&НаКлиенте
Процедура СортировкаМакетаСообщенийПоАлфавиту(Команда)
	Файл = Новый Файл(ПутьКОбработке);
	Файлы = НайтиФайлы(Файл.Путь + "\locales\Messages\Templates","*.xml",Истина);
	Для Каждого Файл Из Файлы Цикл
		Текст = Новый ЧтениеТекста;
		Текст.Открыть(Файл.ПолноеИмя,"UTF-8");
		
		МассивСтрокМакета = Новый Массив;
		Пока Истина Цикл
			Стр = Текст.ПрочитатьСтроку();
			Если Стр = Неопределено Тогда
				Прервать;
			КонецЕсли;	 
			
			МассивСтрокМакета.Добавить(Стр);
		КонецЦикла;	
		Текст.Закрыть();
		
		Если Не ЭтоМакетПереводаСообщений(МассивСтрокМакета) Тогда
			Продолжить;
		КонецЕсли;	 
		
		
		НовыйМассив = Новый Массив;
		
		Сч = -1;
		Для Каждого Стр Из МассивСтрокМакета Цикл
			Сч = Сч + 1;
			
			НовыйМассив.Добавить(Стр);
			//добавили шапку и первую строку макета
			
			Если СокрЛП(Стр) = "</rowsItem>" Тогда
				Прервать;
			КонецЕсли;	
		КонецЦикла;	
		
		НомерСтрокиМакета = Сч;
		Счетчик_tl = 0;
		
		Секция = Неопределено;
		МассивСекций = Новый Массив;
		Для Ккк = (НомерСтрокиМакета + 1) По МассивСтрокМакета.Количество()-1 Цикл
			Стр = МассивСтрокМакета.Получить(Ккк);
			Сч  = Ккк;
			
			Если Найти(Стр,"<tl>") > 0 Тогда
				Счетчик_tl = Счетчик_tl + 1;
			КонецЕсли;	 
			
			Если Секция = Неопределено Тогда
				Секция = Новый Структура;
				Секция.Вставить("МассивСтрок",Новый Массив);
				Секция.Вставить("СтрокаRU","");
				Секция.Вставить("СтрокаEN","");
			КонецЕсли;	 
			
			Секция.МассивСтрок.Добавить(Стр);
			
			Если (Найти(Стр,"<v8:lang>") > 0) и (Счетчик_tl = 1) Тогда
				СледующаяСтрока = МассивСтрокМакета.Получить(Ккк+1);
				СледующаяСтрока = СтрЗаменить(СледующаяСтрока,"<v8:content>","");
				СледующаяСтрока = СтрЗаменить(СледующаяСтрока,"</v8:content>","");
				ПроверитьСтрокуНаКорректность(СледующаяСтрока);
				Секция.СтрокаRU = СокрЛП(СледующаяСтрока);
			ИначеЕсли (Найти(Стр,"<v8:lang>") > 0) и (Счетчик_tl = 2) Тогда
				СледующаяСтрока = МассивСтрокМакета.Получить(Ккк+1);
				СледующаяСтрока = СтрЗаменить(СледующаяСтрока,"<v8:content>","");
				СледующаяСтрока = СтрЗаменить(СледующаяСтрока,"</v8:content>","");
				ПроверитьСтрокуНаКорректность(СледующаяСтрока);
				Секция.СтрокаEN = СокрЛП(СледующаяСтрока);
			КонецЕсли;	 
			
			Если СокрЛП(Стр) = "</rowsItem>" Тогда
				МассивСекций.Добавить(Секция);
				Секция = Неопределено;
				Счетчик_tl = 0;
			КонецЕсли;	 
			
			Если СокрЛП(Стр) = "<templateMode>true</templateMode>" Тогда
				Прервать;
			КонецЕсли;	 
		КонецЦикла;	
		
		НомерСтрокиМакета = Сч-1;
		//вычтем 1, чтобы попала строка "<templateMode>true</templateMode>"
		
		
		СортироватьМассивСекцийСервер(МассивСекций);
		
		СчетчикСтрок = 0;
		Для Каждого Элем Из МассивСекций Цикл
			СчетчикСтрок = СчетчикСтрок + 1;
			Для Каждого Стр Из Элем.МассивСтрок Цикл
				Если (Найти(Стр,"<index>") > 0) и (Найти(Стр,"</index>") > 0) Тогда
					Поз = Найти(Стр,"<index>");
					Стр = Лев(Стр,Поз + 7 - 1);
					Стр = Стр + XMLСтрока(СчетчикСтрок) + "</index>";
				КонецЕсли;	 
				НовыйМассив.Добавить(Стр);
			КонецЦикла;	
		КонецЦикла;	
		
		
		//добавим подвал
		Для Ккк = (НомерСтрокиМакета + 1) По МассивСтрокМакета.Количество()-1 Цикл
			Стр = МассивСтрокМакета.Получить(Ккк);
			НовыйМассив.Добавить(Стр);
		КонецЦикла;		
		
		
		ИмяВременногоXML = ПолучитьИмяВременногоФайла("xml");
		
		ЗТ = Новый ЗаписьТекста(ИмяВременногоXML,"UTF-8",,Истина); 
		
		Для Каждого Стр Из НовыйМассив Цикл
			ЗТ.ЗаписатьСтроку(Стр); 
		КонецЦикла;	
		
		ЗТ.Закрыть();
		
		КопироватьФайл(ИмяВременногоXML,Файл.ПолноеИмя);
		
	КонецЦикла;	
	
	
	
КонецПроцедуры


&НаКлиенте
Процедура ПеревестиМакетыСообщений(Команда)
	Файл = Новый Файл(ПутьКОбработке);
	МассивФайлов = НайтиФайлы(Файл.Путь + "\locales\Messages\Templates","*.xml",Ложь);
	
	
	Для Каждого Файл Из МассивФайлов Цикл
		ЯзыкДляПеревода = Файл.ИмяБезРасширения;
		
		Текст = Новый ЧтениеТекста;
		НовыйПуть = Файл.Путь + "\" + Файл.ИмяБезРасширения + "\Ext\Template.xml";
		
		Текст.Открыть(НовыйПуть,"UTF-8");
		
		
		Массив      = Новый Массив;
		НовыйМассив = Новый Массив;
		Пока Истина Цикл
			Стр = Текст.ПрочитатьСтроку();
			Если Стр = Неопределено Тогда
				Прервать;
			КонецЕсли;	 
			
			Массив.Добавить(Стр);
		КонецЦикла;	
		Текст.Закрыть();
		
		
		НашлиСекцию1 = Ложь;
		НомСтр = -1;
		Для Ккк = 0 По Массив.Количество()-1 Цикл
			НомСтр = НомСтр + 1;
			
			Стр = Массив.Получить(Ккк);
			НовыйМассив.Добавить(Стр);
			
			Если Найти(Стр,"</columns>") > 0 Тогда
				НашлиСекцию1 = Истина;
			ИначеЕсли НашлиСекцию1 и Найти(Стр,"<index>1</index>") > 0 Тогда
				Прервать;
			КонецЕсли;	 
		КонецЦикла;	
		
		
		
		
		
		ЗначениеДляПеревода = "";
		СчетчикЗначений     = 0;
		Для Ккк = НомСтр+1 По Массив.Количество()-1 Цикл
			Стр = Массив.Получить(Ккк);
			
			Если СокрЛП(Стр) = "<row>" Тогда
				ЗначениеДляПеревода = "";
				СчетчикЗначений     = 0;
			ИначеЕсли СокрЛП(Стр) = "<tl>" Тогда
				СчетчикЗначений = СчетчикЗначений + 1;
			ИначеЕсли Найти(Стр,"<v8:content>") > 0 Тогда
				Если СчетчикЗначений = 1 Тогда
					ЗначениеДляПеревода = СтрЗаменить(Стр,"<v8:content>","");
					ЗначениеДляПеревода = СтрЗаменить(ЗначениеДляПеревода,"</v8:content>","");
					ЗначениеДляПеревода = СокрЛП(ЗначениеДляПеревода);
					ЗначениеДляПеревода = ВывестиСтрокуИзXML(ЗначениеДляПеревода);
				ИначеЕсли СчетчикЗначений = 2 Тогда
					ПромСтр = СтрЗаменить(Стр,"<v8:content>","");
					ПромСтр = СтрЗаменить(ПромСтр,"</v8:content>","");
					ПромСтр = СокрЛП(ПромСтр);
					Если ПромСтр = "111" Тогда
						//значит надо перевести
						Перевод = ПеревестиВыражение(ЗначениеДляПеревода,"ru",ЯзыкДляПеревода);
						Перевод = СокрЛП(Перевод);
						Сообщить("ЗначениеДляПеревода="+ЗначениеДляПеревода + ", Перевод="+Перевод);
						Перевод = ВернутьСтрокуВXML(Перевод);
						
						Стр = "							<v8:content>" + Перевод + "</v8:content>";
					КонецЕсли;	 
				КонецЕсли;	 
			КонецЕсли;	
			
			НовыйМассив.Добавить(Стр);
		КонецЦикла;	
		
		
		ВременныйФайл = ПолучитьИмяВременногоФайла("xml");
		
		
		ЗТ = Новый ЗаписьТекста(ВременныйФайл,"UTF-8",,Истина); 
		Для Каждого Стр Из НовыйМассив Цикл
			ЗТ.ЗаписатьСтроку(Стр); 
		КонецЦикла;	
		ЗТ.Закрыть();
		
		КопироватьФайл(ВременныйФайл,НовыйПуть);
	КонецЦикла;	
	
КонецПроцедуры

Функция ЭтоМакетПереводаСообщений(Массив)
	НашлиСтроку = Ложь;
	Для Каждого Стр Из Массив Цикл
		Если Найти(Стр,"<rowsItem>") > 0 Тогда
			НашлиСтроку = Истина;
			Прервать;
		КонецЕсли;	 
	КонецЦикла;	
	
	Возврат НашлиСтроку; 
КонецФункции	 

&НаКлиенте
Процедура ВставитьВМакетыПереводовСообщенийСтроку(Команда)
	Файл = Новый Файл(ПутьКОбработке);
	
	Файлы = НайтиФайлы(Файл.Путь + "\locales\Messages\Templates","*.xml",Истина);
	Для Каждого Файл Из Файлы Цикл
		Текст = Новый ЧтениеТекста;
		Текст.Открыть(Файл.ПолноеИмя,"UTF-8");
		
		Массив = Новый Массив;
		Пока Истина Цикл
			Стр = Текст.ПрочитатьСтроку();
			Если Стр = Неопределено Тогда
				Прервать;
			КонецЕсли;	 
			
			Массив.Добавить(Стр);
		КонецЦикла;	
		Текст.Закрыть();
		
		Если Не ЭтоМакетПереводаСообщений(Массив) Тогда
			Продолжить;
		КонецЕсли;	 
		
		
		Сообщить(Файл.ПолноеИмя);
		
		КоличествоСтрокМакета = 0;
		ИдСтрокиМассива = -1;
		
		Сч = -1;
		Для Каждого Стр Из Массив Цикл
			Сч = Сч + 1;
			Если Найти(Стр,"</index>") > 0 Тогда
				Стр = СтрЗаменить(Стр,"</index>","");
				Стр = СтрЗаменить(Стр,"<index>","");
				Стр = XMLСтрока(СокрЛП(Стр));
				ПромЧисло = Число(Стр);
				
				Если КоличествоСтрокМакета < ПромЧисло Тогда
					КоличествоСтрокМакета = ПромЧисло;
					ИдСтрокиМассива       = Сч;
				КонецЕсли;	 
			КонецЕсли;	 
		КонецЦикла;	
		Сообщить("КоличествоСтрокМакета="+КоличествоСтрокМакета);
		
		
		РазмерСекции = 27;
		
		ИдСтрокиМассива = ИдСтрокиМассива - 1;
		//это строка "	<rowsItem>"
		
		Секция = Новый Массив;
		Для Ккк = 1 По РазмерСекции Цикл
			ИдСтроки = ИдСтрокиМассива + Ккк  -1;
			Стр      = Массив.Получить(ИдСтроки);
			Секция.Добавить(Стр);
		КонецЦикла;	
		
		Если Найти(Секция[РазмерСекции-1],"</rowsItem>") = 0 Тогда
			//Сообщить(Файл.ПолноеИмя + ", Ошибка при чтении строки макета в исходниках.");
			//Продолжить;
			
			ВызватьИсключение "Ошибка при чтении строки макета в исходниках.";
		КонецЕсли;	 
		
		ИдСтрокиМассива = ИдСтрокиМассива + РазмерСекции;
		
		НовыйМассив = Новый Массив;
		Для Ккк = 0 По ИдСтрокиМассива-1 Цикл
			Стр = Массив.Получить(Ккк);
			НовыйМассив.Добавить(Стр);
		КонецЦикла;	
		
		
		МассивЗначенийДляВставки = СтрРазделить(СтрокаДляВставкиВМакет,Символы.ПС);
		Если СокрЛП(МассивЗначенийДляВставки[МассивЗначенийДляВставки.Количество()-1]) = "" Тогда
			МассивЗначенийДляВставки.Удалить(МассивЗначенийДляВставки.Количество()-1);
		КонецЕсли;	 
		
		Для НомерВставляемойСтроки = 1 По МассивЗначенийДляВставки.Количество() Цикл
			ЗначениеДляВставки = СокрЛП(МассивЗначенийДляВставки[НомерВставляемойСтроки-1]);
			Счетчик_tl = 0;
			Для Каждого Стр Из Секция Цикл
				Если Найти(Стр,"</index>") > 0 Тогда
					Стр = "		<index>" + XMLСтрока(КоличествоСтрокМакета+НомерВставляемойСтроки) + "</index>";
				ИначеЕсли Найти(Стр,"<tl>") > 0 Тогда
					Счетчик_tl = Счетчик_tl + 1;
				ИначеЕсли (Найти(Стр,"<v8:content>") > 0) и (Счетчик_tl = 1) Тогда
					Стр = "							<v8:content>" + ВернутьСтрокуВXML(ЗначениеДляВставки) + "</v8:content>";
					
				ИначеЕсли (Найти(Стр,"<v8:content>") > 0) и (Счетчик_tl = 2) Тогда
					Стр = "							<v8:content>Translation not found</v8:content>";
				КонецЕсли;	 
				
				НовыйМассив.Добавить(Стр);
			КонецЦикла;	
		КонецЦикла;	
		
		КоличествоЗначенийДляВставки = МассивЗначенийДляВставки.Количество();
		
		//подвал
		Для Ккк = ИдСтрокиМассива По Массив.Количество()-1 Цикл
			Стр = Массив.Получить(Ккк);
			Если Найти(Стр,"<height>" + XMLСтрока(КоличествоСтрокМакета+1) + "</height>") > 0 Тогда
				Стр = "	<height>" + XMLСтрока(КоличествоСтрокМакета+КоличествоЗначенийДляВставки+1) + "</height>";
			ИначеЕсли Найти(Стр,"<vgRows>" + XMLСтрока(КоличествоСтрокМакета+1) + "</vgRows>") > 0 Тогда
				Стр = "	<vgRows>" + XMLСтрока(КоличествоСтрокМакета+КоличествоЗначенийДляВставки+1) + "</vgRows>";
			КонецЕсли;	 
			
			НовыйМассив.Добавить(Стр);
		КонецЦикла;	
		
		
		ВременныйФайл = ПолучитьИмяВременногоФайла("xml");
		ЗТ = Новый ЗаписьТекста(ВременныйФайл,"UTF-8",,Истина); 
		Для Каждого Стр Из НовыйМассив Цикл
			ЗТ.ЗаписатьСтроку(Стр); 
		КонецЦикла;	
		ЗТ.Закрыть();
		
		КопироватьФайл(ВременныйФайл,Файл.ПолноеИмя);
	КонецЦикла;	
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаменитьСтрокуВМакетахИВКоде(Команда)
