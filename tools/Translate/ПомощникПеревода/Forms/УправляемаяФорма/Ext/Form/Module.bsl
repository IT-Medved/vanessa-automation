&НаКлиенте
Процедура НайтиНовыеСообщения(МакетСообщений,Каталог,МассивРезультат)
	МассивУжеЕсть = Новый Массив;
	Для Ккк = 1 По МакетСообщений.ВысотаТаблицы Цикл
		МассивУжеЕсть.Добавить(СокрЛП(НРег(МакетСообщений.Область(Ккк,1,Ккк,1).Текст)));
	КонецЦикла;	
	
	
	МассивФайлов = МассивФайловДляОбработки(Каталог);
	
	Для Каждого Файл Из МассивФайлов Цикл
		Текст = Новый ЧтениеТекста;
		Текст.Открыть(Файл.ПолноеИмя,"UTF-8");
		
		Пока Истина Цикл
			Стр = Текст.ПрочитатьСтроку();
			Если Стр = Неопределено Тогда
				Прервать;
			КонецЕсли;	 
			ИсходнаяСтрока = Стр;
			
			Если Найти(Стр,"Не указано имя файла лога в параметре") > 0 Тогда
				ввап = 1;
			КонецЕсли;	 
			
			Если Найти(Стр,"$") > 0 Тогда
				Продолжить;
			КонецЕсли;	 
			
			
			
			Стр = СокрЛП(Стр);
			
			
			Если Найти(Стр,"Запускаю генерацию epf.") > 0 Тогда
				вава = 1;
			КонецЕсли;	 
			
			СообщениеВСтроке = ПолучитьСообщениеИзСтроки(Стр);
			
			
			СообщениеВСтроке = ПроверитьСтрокуНаПравильность(СообщениеВСтроке);
		
			Если СообщениеВСтроке = Неопределено Тогда
				Продолжить;
			КонецЕсли;	 
			
			Если МассивУжеЕсть.Найти(НРег(СообщениеВСтроке)) = Неопределено Тогда
				//Сообщить("СообщениеВСтроке="+СообщениеВСтроке);
				МассивУжеЕсть.Добавить(НРег(СообщениеВСтроке));
				МассивРезультат.Добавить(СообщениеВСтроке);
			КонецЕсли;	 
			
		КонецЦикла;	
		
		Текст.Закрыть();
		
	КонецЦикла;	
	
КонецПроцедуры 

&НаСервере
Функция ОтсортироватьМассивСервер(Массив)
	Тзн = Новый ТаблицаЗначений;
