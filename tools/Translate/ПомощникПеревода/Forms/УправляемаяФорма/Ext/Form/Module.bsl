&НаКлиенте
Процедура ДополнитьМакетСообщений(Команда)
	ПереводСообщений = Неопределено;
	ИмяОбработки = ПодключитьВнешнююОбработкуКлиент(ПутьКОбработке,ПереводСообщений);
	Сообщить("ИмяОбработки="+ИмяОбработки);
	Сообщить("ПереводСообщений="+ПереводСообщений);
	
	
	МассивРезультат = Новый Массив;
	
	
	Файл = Новый Файл(ПутьКОбработке);
	НайтиНовыеСообщения(ПереводСообщений,Файл.Путь,МассивРезультат);
	
	МассивРезультат = ОтсортироватьМассивСервер(МассивРезультат);
	
	ТабДок = Новый ТабличныйДокумент;
	Сч = 0;
	Для Каждого Элем Из МассивРезультат Цикл
		Сч = Сч + 1;
		ТабДок.Область(Сч,1,Сч,1).Текст = Элем;
	КонецЦикла;	
	
	ТабДок.Показать();
	
КонецПроцедуры

