&НаКлиенте
Функция ДанныеИзБазыЗнанийКлиент(ФорматОтвета, НомерВопроса, СтрокаПоиска)
	
	Если ФорматОтвета = "all" Тогда
		Возврат глКешБазыЗнаний;
	ИначеЕсли ФорматОтвета = "short_info" Тогда
		Возврат КороткаяИнформацияОБазеЗнаний();
	ИначеЕсли ФорматОтвета = "questions_only" Тогда
		Возврат ТолькоВопросыИзБазыЗнанийСНомерами();
	ИначеЕсли ФорматОтвета = "one_question" Тогда
		Возврат ПолучитьОтветНаОдинВопрос(НомерВопроса);
	ИначеЕсли ФорматОтвета = "question_search" Тогда
		Возврат ПоискПоВопросам(СтрокаПоиска);
	ИначеЕсли ФорматОтвета = "answers_search" Тогда
		Возврат ПоискПоОтветам(СтрокаПоиска);
	КонецЕсли;	
	
КонецФункции

&НаКлиенте
Функция КороткаяИнформацияОБазеЗнаний()
	
	Вопросы = ПолучитьМассивВопросов();
	КолВопросов = Вопросы.Количество();
	
	КоличествоСимволов = СтрДлина(глКешБазыЗнаний);
	
	Возврат Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("## Количество вопросов: %1, размер базы знаний в символах: %2"), XMLСтрока(КолВопросов), XMLСтрока(КоличествоСимволов));
	
КонецФункции

&НаКлиенте
Функция ТолькоВопросыИзБазыЗнанийСНомерами()
	
	Вопросы = ПолучитьМассивВопросов();
	КолВопросов = Вопросы.Количество();
	
	КоличествоСимволов = СтрДлина(глКешБазыЗнаний);

	Результат = Новый Массив;
	Результат.Добавить(Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("## Количество вопросов: %1, размер базы знаний в символах: %2"), XMLСтрока(КолВопросов), XMLСтрока(КоличествоСимволов)));
	Результат.Добавить("");
	Для Каждого ТекВопрос Из Вопросы Цикл
		Результат.Добавить("Вопрос №" + xmlСтрока(ТекВопрос.Номер));
		Результат.Добавить(ТекВопрос.Текст);
		Результат.Добавить("");
	КонецЦикла;	
	
	Возврат Ванесса._СтрСоединить(Результат);
	
КонецФункции

&НаКлиенте
Функция ПолучитьОтветНаОдинВопрос(НомерВопроса)
	
	Если НомерВопроса = Неопределено ИЛИ НомерВопроса <= 0 Тогда
		ТекстСообщения = Ванесса.Локализовать("Некорректно указан параметр 'question_number'");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	Вопросы = ПолучитьМассивВопросов();
	Если НомерВопроса > Вопросы.Количество() Тогда
		ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Не корректно указан параметр 'question_number'. Всего вопросов %1, а передано значение %2"), XMLСтрока(Вопросы.Количество()), XMLСтрока(НомерВопроса));
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	ТекВопрос = Вопросы[НомерВопроса - 1];
	Результат = Новый Массив;
	Результат.Добавить(ТекВопрос.ТекстВопросаБезОбработки);
	Для Каждого Стр Из ТекВопрос.Ответ Цикл
		Результат.Добавить(Стр);
	КонецЦикла;	
	Возврат Ванесса._СтрСоединить(Результат);

КонецФункции

&НаКлиенте
Функция ПолучитьМассивВопросов()
	
	Если глКешВопросов <> Неопределено Тогда
		Возврат глКешВопросов;
	КонецЕсли;	
	
	Вопросы = Новый Массив;
	
	СтрокаПоиска = ПолучитьСтрокуПоискаВопрос();
	КолВопросов = 0;
	МассивСтрок = Ванесса._СтрРазделить(глКешБазыЗнаний, Символы.ПС);
	Для Сч = 0 По МассивСтрок.Количество()-1 Цикл
		Стр_нрег = НРег(МассивСтрок[Сч]);
		
		Поз = Найти(Стр_нрег, СтрокаПоиска);
		Если Поз = 1 Тогда
			ТекстВопроса = СокрЛП(Сред(МассивСтрок[Сч], СтрДлина(СтрокаПоиска) + 1));
			КолВопросов = КолВопросов + 1;
			ДанныеВопроса = Новый Структура;
			ДанныеВопроса.Вставить("Номер", КолВопросов);
			ДанныеВопроса.Вставить("Текст", ТекстВопроса);
			ДанныеВопроса.Вставить("ТекстВопросаБезОбработки", МассивСтрок[Сч]);
			ДанныеВопроса.Вставить("НомерСтроки", Сч + 1); //Номер строки с которой начинается ответ
			ДанныеВопроса.Вставить("Ответ", Новый Массив);
			Вопросы.Добавить(ДанныеВопроса);
		КонецЕсли;	
	КонецЦикла;
	
	ДлинныйРазделитель = ДлинныйРазделитель();
	
	Для Каждого ТекВопрос Из Вопросы Цикл
		НомерСтроки = ТекВопрос.НомерСтроки - 1;
		Пока Истина Цикл
			НомерСтроки = НомерСтроки + 1;
			Если НомерСтроки > МассивСтрок.Количество() - 1 Тогда
				// Значит кончился файл
				Прервать;
			КонецЕсли;	
			Стр = МассивСтрок[НомерСтроки];
			
			Если Лев(НРег(СокрЛ(Стр)), СтрДлина(СтрокаПоиска)) = СтрокаПоиска Тогда
				// Значит найден следующий вопрос
				Прервать;
			ИначеЕсли Найти(НРег(Стр), ДлинныйРазделитель) > 0 Тогда
				// Значит найден разделитель
				Прервать;
			КонецЕсли;
			
			ТекВопрос.Ответ.Добавить(Стр);
		КонецЦикла;
	КонецЦикла;
	
	глКешВопросов = Вопросы;
	
	Возврат Вопросы;
	
КонецФункции

