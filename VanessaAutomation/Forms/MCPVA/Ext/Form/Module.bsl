КонецФункции

// Возвращает строку json с шагами, которые были найдены по строке поиска
// Пример строки поиска: кнопка|кнопки|кнопку
&НаКлиенте
Функция ПоискШаговПоСтроке(Запрос, ДополнительныеПараметры) Экспорт
	search_name = Строка(ЗначениеПараметраИзЗапроса(Запрос, "search_name"));
	exclude_name = Строка(ЗначениеПараметраИзЗапроса(Запрос, "exclude_name"));
	search_description = Строка(ЗначениеПараметраИзЗапроса(Запрос, "search_description"));
	exclude_description = Строка(ЗначениеПараметраИзЗапроса(Запрос, "exclude_description"));
	search_type = Строка(ЗначениеПараметраИзЗапроса(Запрос, "search_type"));
	exclude_type = Строка(ЗначениеПараметраИзЗапроса(Запрос, "exclude_type"));
	Попытка
		limit = Число(ЗначениеПараметраИзЗапроса(Запрос, "limit"));
	Исключение
		limit = 0;
	КонецПопытки;
	
	ТолькоЦиклы = ЗначениеПараметраИзЗапроса(Запрос, "loops_only");
	Если ТолькоЦиклы = Неопределено Тогда
		ТолькоЦиклы = Ложь;
	Иначе
		Попытка
			ТолькоЦиклы = Булево(ТолькоЦиклы);
		Исключение
			ТекстСообщения = Ванесса.Локализовать("Параметр loops_only передан некорректно") + Символы.ПС + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
		КонецПопытки;
	КонецЕсли;
	
	ТолькоУсловия = ЗначениеПараметраИзЗапроса(Запрос, "conditions_only");
	Если ТолькоУсловия = Неопределено Тогда
		ТолькоУсловия = Ложь;
	Иначе
		Попытка
			ТолькоУсловия = Булево(ТолькоУсловия);
		Исключение
			ТекстСообщения = Ванесса.Локализовать("Параметр conditions_only передан некорректно") + Символы.ПС + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
		КонецПопытки;
	КонецЕсли;	
	
    Возврат ПоискШаговПоСтрокеMCP(search_name, exclude_name, search_description, exclude_description, search_type, exclude_type, limit, ТолькоЦиклы, ТолькоУсловия);
	
КонецФункции

// Возвращает строку json с шагами, которые были найдены по строке поиска
// Пример строки поиска: кнопка|кнопки|кнопку
&НаКлиенте
Функция ПолучитьИмяЗаголовокАктивногоОкнаИФормы(Запрос, ДополнительныеПараметры) Экспорт
	type = Строка(ЗначениеПараметраИзЗапроса(Запрос, "type"));
	Если type = "window_caption" ИЛИ type = "navigation_link" ИЛИ type = "form_name" ИЛИ type = "form_caption" Тогда
		
	Иначе
		ТекстСообщения = Ванесса.Локализовать("Передано неправильное значение параметра type. Допустимые варианты: window_caption, navigation_link, form_name, form_caption");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	Попытка
		АктивноеОкно = Ванесса.ПолучитьАктивноеОкноИзТестовоеПриложение();
	Исключение
		ТекстОшибки = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	       
	Если type = "window_caption" Тогда
		Возврат АктивноеОкно.Заголовок;
	ИначеЕсли type = "navigation_link" Тогда
		Попытка
			НавСсылка = АктивноеОкно.НавигационнаяСсылка;
		Исключение
			ТекстСообщения = Ванесса.Локализовать("У активного окна <%1> нет навигационной ссылки.");
			ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(ТекстСообщения, АктивноеОкно.Заголовок);
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстСообщения);
		КонецПопытки;
		
		Если НЕ ЗначениеЗаполнено(НавСсылка) Тогда
			ТекстСообщения = Ванесса.Локализовать("У активного окна <%1> нет навигационной ссылки.");
			ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(ТекстСообщения, АктивноеОкно.Заголовок);
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстСообщения);
		КонецЕсли;	
		
		Возврат НавСсылка;
	ИначеЕсли type = "form_name" Тогда
		Попытка
			ТестируемаяФорма = АктивноеОкно.НайтиОбъект(Тип("ТестируемаяФорма"));
			Возврат ТестируемаяФорма.ИмяФормы;
		Исключение
			ТекстОшибки = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
		КонецПопытки;
	ИначеЕсли type = "form_caption" Тогда
		Попытка
			ТестируемаяФорма = АктивноеОкно.НайтиОбъект(Тип("ТестируемаяФорма"));
			Возврат ТестируемаяФорма.ТекстЗаголовка;
		Исключение
			ТекстОшибки = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
		КонецПопытки;
	Иначе
		ТекстСообщения = Ванесса.Локализовать("Передано неправильное значение параметра type. Допустимые варианты: window_caption, navigation_link, form_name, form_caption");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
КонецФункции

// Возвращает информацию об элементах текущей формы
&НаКлиенте
Функция ПолучитьИнформациюОТекущейФорме(Запрос, ДополнительныеПараметры) Экспорт
	
	ФорматВывода = Строка(ЗначениеПараметраИзЗапроса(Запрос, "format"));
	Если НЕ ЗначениеЗаполнено(ФорматВывода) Тогда
		ФорматВывода = "full";
	КонецЕсли;
	
	Если ФорматВывода <> "full" И ФорматВывода <> "gherkin" И ФорматВывода <> "elements" И ФорматВывода <> "messages" И ФорматВывода <> "buttons" Тогда
		ТекстСообщения = Ванесса.Локализовать("Параметр format должен быть 'full', 'gherkin' или 'elements' или 'buttons' или 'messages'.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	Попытка
		АктивноеОкно = Ванесса.ПолучитьАктивноеОкноИзТестовоеПриложение();
	Исключение
		ТекстОшибки = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	
	Если ФорматВывода = "messages" Тогда
		CообщенияПользователю = ПолучитьСообщенияПользователюИзОкна(АктивноеОкно);
		Если CообщенияПользователю = Неопределено Тогда
			Возврат Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("В окне <%1> нет сообщений пользователю."), АктивноеОкно.Заголовок);
		Иначе	
			ТекстСообщения = Ванесса.Локализовать("Обнаружены сообщения пользователю:") + Символы.ПС + Ванесса._СтрСоединить(CообщенияПользователю);
			Возврат ТекстСообщения;
		КонецЕсли;	
	КонецЕсли;	
	
	Идентификатор = Запрос.Идентификатор;
	Если ФорматВывода = "elements" Или ФорматВывода = "buttons" Или ФорматВывода = "full" Тогда
		MCPОткрытьИсследовательФормыДляАнализа(Идентификатор, ФорматВывода);
		Возврат Неопределено;
	КонецЕсли;
	
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Анализ текущей формы"));
	Строки.Добавить("");
	
	// Получаем Gherkin-состояние формы
	Если ФорматВывода = "gherkin" Тогда
		Попытка
			Ванесса.ПолучитьИзмененияФормыGherkin();
			Gherkin = Ванесса.Объект.СгенерированныйСценарий;
			Если ЗначениеЗаполнено(Gherkin) Тогда
				Строки.Добавить(Ванесса.Локализовать("## Gherkin-состояние формы"));
				Строки.Добавить("```gherkin");
				Строки.Добавить(Gherkin);
				Строки.Добавить("```");
				Строки.Добавить("");
			Иначе
				Строки.Добавить(Ванесса.Локализовать("## Gherkin-состояние формы"));
				Строки.Добавить(Ванесса.Локализовать("Нет данных."));
				Строки.Добавить("");
				Строки.Добавить(Ванесса.Локализовать("## Следующие шаги"));
				Строки.Добавить(Ванесса.Локализовать("- Подключите клиента тестирования: `connect_test_client`"));
				Строки.Добавить(Ванесса.Локализовать("- Затем повторите: `get_form_analysis`"));
				Строки.Добавить("");
			КонецЕсли;
		Исключение
			Строки.Добавить(Ванесса.Локализовать("## Gherkin-состояние формы"));
			Строки.Добавить(Ванесса.Локализовать("ошибка:") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки()));
			Строки.Добавить("");
		КонецПопытки;
	КонецЕсли;
	
	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Выполняет один шаг произвольным текстом
&НаКлиенте
Функция ВыполнитьОдинШагТекстом(Запрос, ДополнительныеПараметры) Экспорт
	
	ТекстШага = Строка(ЗначениеПараметраИзЗапроса(Запрос, "stepText"));
	Если ЗначениеЗаполнено(ТекстШага) Тогда
		ТекстШага = СокрЛП(Строка(ТекстШага));
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ТекстШага) Тогда
		ТекстСообщения = Ванесса.Локализовать("Параметр stepText обязателен и не может быть пустым.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	Если Ванесса.Объект.ИдетВыполнениеСценариев Тогда
		ТекстСообщения = Ванесса.Локализовать("Сценарии уже выполняются. Дождитесь завершения или вызовите stopExecution.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстСообщения);
	КонецЕсли;
	
	Идентификатор = Запрос.Идентификатор;
	Ванесса.УстановитьИдентификаторЗадачиMCP(Идентификатор);
	
	Попытка
		Ванесса.Шаг(ТекстШага);
	Исключение
		ТекстСообщения = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

// Подключает клиент тестирования
&НаКлиенте
Функция ПодключитьКлиентТестирования(Запрос, ДополнительныеПараметры) Экспорт
	
	ИмяПрофиля = Строка(ЗначениеПараметраИзЗапроса(Запрос, "profileName"));
	Если Не ЗначениеЗаполнено(ИмяПрофиля) Тогда
		ТекстСообщения = Ванесса.Локализовать("Параметр profileName обязателен.") + Символы.ПС + Символы.ПС + MCPСписокДоступныхПрофилей();
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	Попытка
		Идентификатор = Запрос.Идентификатор;
		Ванесса.УстановитьИдентификаторЗадачиMCP(Идентификатор);
		Результат = Ванесса.ПодключитьПрофильTestClientПоИмени(ИмяПрофиля);
		
		Если Результат Тогда
			ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
				"# Подключение клиента тестирования
				|
				|- Статус: подключен
				|- Профиль: %1
				|
				|## Следующие шаги
				|- Получите состояние формы: `get_form_analysis`
				|- Выполните шаг: `execute_feature_step`"),
				ИмяПрофиля);
		Иначе
			ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
				"# Подключение клиента тестирования
				|
				|- Статус: не удалось подключить
				|- Профиль: %1"),
				ИмяПрофиля)
				+ Символы.ПС + Символы.ПС
				+ MCPСписокДоступныхПрофилей()
				+ Символы.ПС + Символы.ПС
				+ Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
					"## Возможные причины
					|- Профиль с именем '%1' не найден в настройках
					|- Тестовое приложение не запущено
					|- Настройки подключения некорректны"),
					ИмяПрофиля);
		КонецЕсли;
		
		//MCPОтправитьРезультатИнструмента(ИдентификаторЗапроса, ТекстОтвета);
		МодульМсп_Сервер().ЗавершитьВызовИнструментаУспешно(Ванесса.ПолучитьИдентификаторЗадачиMCP(), ТекстОтвета);
		Ванесса.УстановитьИдентификаторЗадачиMCP(Неопределено);
		Возврат Неопределено;
	Исключение
		ТекстСообщения = Ванесса.Локализовать("Ошибка подключения клиента тестирования:") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки()) + Символы.ПС + Символы.ПС + MCPСписокДоступныхПрофилей();
		МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

// Выполняет один шаг из фича файла
&НаКлиенте
Функция ВыполнитьОдинШагВФичаФайле(Запрос, ДополнительныеПараметры) Экспорт
	
	ПутьКФайлу = Строка(ЗначениеПараметраИзЗапроса(Запрос, "filePath"));
	НомерСтроки = Число(ЗначениеПараметраИзЗапроса(Запрос, "lineNumber"));
	Если НЕ ЗначениеЗаполнено(ПутьКФайлу) Тогда
		ПутьКФайлу = Ванесса.Объект.КаталогФич;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(НомерСтроки) ИЛИ НомерСтроки < 1 Тогда
		ТекстСообщения = Ванесса.Локализовать("Параметр lineNumber обязателен и должен быть >= 1.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	ПутьКФайлу = MCPНормализоватьПутьКФичаФайлу(ПутьКФайлу);
	Идентификатор = Запрос.Идентификатор;
	Ванесса.УстановитьИдентификаторЗадачиMCP(Идентификатор);
	
	// Открыть/активировать вкладку файла в редакторе
	ДопПараметрыВызоваMCP = Новый Структура;
	ДопПараметрыВызоваMCP.Вставить("ПутьКФайлу", ПутьКФайлу);
	ДопПараметрыВызоваMCP.Вставить("НомерСтроки", НомерСтроки);
	ДопПараметрыВызоваMCP.Вставить("Тип", "ВыполнитьОдинШагВФичаФайле");
	MCPOpenFeatureFileВРедакторе(ПутьКФайлу, "ВыполнитьОдинШагВФичаФайле", ДопПараметрыВызоваMCP);
	
КонецФункции

// Получает список окон клиента тестирования для снятия скриншотов
&НаКлиенте
Функция ПолучитьСписокОконКлиентаТестированияДляСнятияСкриншотов(Запрос, ДополнительныеПараметры) Экспорт
	
	// Реальная проверка подключения клиента тестирования
	Попытка
		АктивноеОкно = Ванесса.ПолучитьАктивноеОкноИзТестовоеПриложение();
	Исключение
		ТекстОшибки = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	
	ProcessId = Ванесса.PIDТекущегоКлиентаТестирования();
	Если НЕ ЗначениеЗаполнено(ProcessId) Тогда
		ТекстОшибки = Ванесса.Локализовать("Не вышло получить PID процесса клиента тестирования.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецЕсли;	
	
	Идентификатор = Запрос.Идентификатор;
	Ванесса.УстановитьИдентификаторЗадачиMCP(Идентификатор);
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("ProcessId", ProcessId);
	ОписаниеОповещения = Новый ОписаниеОповещения("ПолученПолучитьСписокОконКлиентаТестированияДляВозвратаИхЗаголовков", ЭтаФорма, ДопПараметры);
	Ванесса.ВнешняяКомпонентаДляСкриншотов.НачатьВызовПолучитьСписокОкон(ОписаниеОповещения, ProcessId);
	
КонецФункции

// Получает скриншот окна клиента тестирования
&НаКлиенте
Функция ПолучитьСкриншотОкнаКлиентаТестирования(Запрос, ДополнительныеПараметры) Экспорт
	
	ЗаголовокОкна = Строка(ЗначениеПараметраИзЗапроса(Запрос, "window_title"));
	ИмяФайла = Строка(ЗначениеПараметраИзЗапроса(Запрос, "file_name"));
	Если НЕ ЗначениеЗаполнено(ЗаголовокОкна) Тогда
		ТекстОшибки = Ванесса.Локализовать("Не указан обязательный параметр window_title");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстОшибки);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИмяФайла) Тогда
		Файл = Новый Файл(ИмяФайла);
		КаталогФайла = Файл.Путь;
		Если НЕ Ванесса.ФайлСуществуетКомандаСистемы(КаталогФайла) Тогда
			ТекстОшибки = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Некорректное значение параметра file_name. Не найден каталог файла '%1'"), КаталогФайла);
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстОшибки);
		КонецЕсли;	
	КонецЕсли;	
	
	// Получаем параметр color_mode (по умолчанию 'grayscale')
	ЦветовойРежим = Строка(ЗначениеПараметраИзЗапроса(Запрос, "color_mode"));
	Если НЕ ЗначениеЗаполнено(ЦветовойРежим) Тогда
		ЦветовойРежим = "grayscale";
	Иначе
		ЦветовойРежим = НРег(СокрЛП(ЦветовойРежим));
		Если ЦветовойРежим <> "color" И ЦветовойРежим <> "grayscale" Тогда
			ТекстОшибки = Ванесса.Локализовать("Некорректное значение параметра color_mode. Допустимые значения: 'grayscale' (черно-белый) или 'color' (цветной).");
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстОшибки);
		КонецЕсли;
	КонецЕсли;
	
	// Реальная проверка подключения клиента тестирования
	Попытка
		АктивноеОкно = Ванесса.ПолучитьАктивноеОкноИзТестовоеПриложение();
	Исключение
		ТекстОшибки = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	
	ProcessId = Ванесса.PIDТекущегоКлиентаТестирования();
	Если НЕ ЗначениеЗаполнено(ProcessId) Тогда
		ТекстОшибки = Ванесса.Локализовать("Не вышло получить PID процесса клиента тестирования.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецЕсли;	
	
	Идентификатор = Запрос.Идентификатор;
	Ванесса.УстановитьИдентификаторЗадачиMCP(Идентификатор);
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("ProcessId", ProcessId);
	ДопПараметры.Вставить("ЗаголовокОкна", ЗаголовокОкна);
	ДопПараметры.Вставить("ИмяФайла", ИмяФайла);
	ДопПараметры.Вставить("ЦветовойРежим", ЦветовойРежим);
	ОписаниеОповещения = Новый ОписаниеОповещения("ПолученПолучитьСписокОконКлиентаТестированияДляСнятияСкриншотов", ЭтаФорма, ДопПараметры);
	Ванесса.ВнешняяКомпонентаДляСкриншотов.НачатьВызовПолучитьСписокОкон(ОписаниеОповещения, ProcessId);
	
КонецФункции

&НаКлиенте
Процедура ПолученПолучитьСписокОконКлиентаТестированияДляСнятияСкриншотов(РезультатВызова, ПараметрыВызова, ДопПараметры) Экспорт
	
	ОкнаДляСкриншотов = ПолучитьОкнаДляСкриншотов(РезультатВызова);
	
	Если ОкнаДляСкриншотов.Количество() = 0 Тогда
		ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("У процесса с ID=%1 не найдено окон для снятия скриншотов."), XMLСтрока(ДопПараметры.ProcessId));
		МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	НужноеОкно = Неопределено;
	Для Каждого ТекОкно Из ОкнаДляСкриншотов Цикл
		Если НРег(ТекОкно.Заголовок) = НРег(ДопПараметры.ЗаголовокОкна) Тогда
			НужноеОкно = ТекОкно;
			Прервать;
		КонецЕсли;	
	КонецЦикла;
	
	Если НужноеОкно = Неопределено Тогда
		ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("У процесса с ID=%1 не найдено окно с заголовком <%2>."), XMLСтрока(ДопПараметры.ProcessId), ДопПараметры.ЗаголовокОкна);
		МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
		Возврат;
	КонецЕсли;	
	
	ДопПараметры.Вставить("НужноеОкно", НужноеОкно);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПолученСнимокОкнаДляВозвратаСкриншота", ЭтаФорма, ДопПараметры);
	Ванесса.ВнешняяКомпонентаДляСкриншотов.НачатьВызовПолучитьСнимокОкна(ОписаниеОповещения,
		НужноеОкно.ПолныеДанныеОкна.window);
		
КонецПроцедуры 

&НаКлиенте
Процедура ПолученСнимокОкнаДляВозвратаСкриншота(ДвоичныеДанные, ПараметрыВызова, ДополнительныеПараметры) Экспорт
	
	Если ДвоичныеДанные = Неопределено Тогда
		
		ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
				"Не удалось получить снимок экрана.
				|Проверьте настройки компоненты VanessaExt в разделе «Скриншоты».
				|Если используется клиент тестирования, попробуйте сначала активировать его окно."));
		МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
		Возврат;
	КонецЕсли;

	ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
		"# Скриншот клиента тестирования
		|
		|Скриншот клиента тестирования сделан успешно."));

	MCPОтправитьРезультатИнструментаСИзображением(ТекстОтвета, ДвоичныеДанные, ДополнительныеПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ПолученПолучитьСписокОконКлиентаТестированияДляВозвратаИхЗаголовков(РезультатВызова, ПараметрыВызова, ДопПараметры) Экспорт
	
	ОкнаДляСкриншотов = ПолучитьОкнаДляСкриншотов(РезультатВызова);
	
	Если ОкнаДляСкриншотов.Количество() = 0 Тогда
		ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("У процесса с ID=%1 не найдено окон для снятия скриншотов."), XMLСтрока(ДопПараметры.ProcessId));
		МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	Результат = Новый Массив;
	Результат.Добавить(Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Для снятия скриншотов найдено %1 окон:"), ОкнаДляСкриншотов.Количество()));
	Для Каждого ТекОкно Из ОкнаДляСкриншотов Цикл
		Результат.Добавить("  -" + ТекОкно.Заголовок);
	КонецЦикла;	
	
	ТекстСообщения = Ванесса._СтрСоединить(Результат);
	МодульМсп_Сервер().ЗавершитьВызовИнструментаУспешно(Ванесса.ПолучитьИдентификаторЗадачиMCP(), ТекстСообщения);
	Ванесса.УстановитьИдентификаторЗадачиMCP(Неопределено);
	
КонецПроцедуры 

// Возвращает список окон клиента тестирования
&НаКлиенте
Функция ПолучитьСписокВнутреннихОконКлиентаТестирования(Запрос, ДополнительныеПараметры) Экспорт
	
	// Реальная проверка подключения клиента тестирования
	Попытка
		АктивноеОкно = Ванесса.ПолучитьАктивноеОкноИзТестовоеПриложение();
	Исключение
		ТекстОшибки = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	
	Попытка
		ТестовоеПриложение = Ванесса.ПолучитьТестовоеПриложение();
	Исключение
		ТекстОшибки = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	
	МассивОкон = ТестовоеПриложение.НайтиОбъекты(Тип("ТестируемоеОкноКлиентскогоПриложения"));
	
	Результат = Новый Массив;
	Результат.Добавить(Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("В клиенте тестирования найдено %1 окон:"), МассивОкон.Количество()));
	
	Для Каждого ТекОкно Из МассивОкон Цикл
		Результат.Добавить("   -" + ТекОкно.Заголовок);
	КонецЦикла;
	
	Возврат Ванесса._СтрСоединить(Результат);
	
КонецФункции

// Активизирует окно клиента тестирования по заголовку
&НаКлиенте
Функция АктивизироватьОкноКлиентаТестирования(Запрос, ДополнительныеПараметры) Экспорт
	
	// Реальная проверка подключения клиента тестирования
	Попытка
		АктивноеОкно = Ванесса.ПолучитьАктивноеОкноИзТестовоеПриложение();
	Исключение
		ТекстОшибки = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	
	Попытка
		ТестовоеПриложение = Ванесса.ПолучитьТестовоеПриложение();
	Исключение
		ТекстОшибки = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	
	ЗаголовокОкна = Строка(ЗначениеПараметраИзЗапроса(Запрос, "window_title"));
	Если НЕ ЗначениеЗаполнено(ЗаголовокОкна) Тогда
		ТекстОшибки = Ванесса.Локализовать("Не указан обязательный параметр window_title");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстОшибки);
	КонецЕсли;	
	
	НужноеОкно = ТестовоеПриложение.НайтиОбъект(Тип("ТестируемоеОкноКлиентскогоПриложения"), ЗаголовокОкна);
	
	Если НужноеОкно = Неопределено Тогда
		ТекстОшибки = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Окно с заголовоком <%1> не найдено."), ЗаголовокОкна);
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецЕсли;	
	
	Попытка
		НужноеОкно.Активизировать();
	Исключение
		ТекстОшибки = Ванесса.Локализовать("Не получилось активизировать указанное окно. Возмжоно оно заблокировано модальным окном или другим окном.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	
	Возврат Ванесса.Локализовать("Окно было успешно активизировано.");
	
КонецФункции

// Добавляет, читает и удаляет переменные контекста и глобального контекста
&НаКлиенте
Функция УправлениеПеременными(Запрос, ДополнительныеПараметры) Экспорт
	
	Действие = Строка(ЗначениеПараметраИзЗапроса(Запрос, "action"));
	Если НЕ ЗначениеЗаполнено(Действие) Тогда
		Действие = "get";
	КонецЕсли;
	
	ИмяПеременной = Строка(ЗначениеПараметраИзЗапроса(Запрос, "name"));
	ЗначениеПеременнойПараметр = Строка(ЗначениеПараметраИзЗапроса(Запрос, "value"));
	ПеременнаяГлобальная = Строка(ЗначениеПараметраИзЗапроса(Запрос, "is_global"));
	Если ЗначениеЗаполнено(ПеременнаяГлобальная) Тогда
		ПеременнаяГлобальная = Булево(ПеременнаяГлобальная);
	Иначе
		ПеременнаяГлобальная = Ложь;
	КонецЕсли;	
	
	ОбъектКонтекст = Ванесса.ОбъектКонтекст;
	ОбъектКонтекстСохраняемый = Ванесса.ОбъектКонтекстСохраняемый;
	
	Если Действие = "get" Тогда
		// Если имя указано — одна переменная, иначе — все
		Если ЗначениеЗаполнено(ИмяПеременной) Тогда
			Значение = Ванесса.ЗначениеПеременной(ИмяПеременной);
			
			Если ПеременнаяГлобальная Тогда
				Значение = ЗначениеИзСтруктуры(ОбъектКонтекстСохраняемый, ИмяПеременной);
			Иначе	
				Значение = ЗначениеИзСтруктуры(ОбъектКонтекст, ИмяПеременной);
			КонецЕсли;	
			
			ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
				"# Переменная: %1
				|
				|- Значение: %2"),
				ИмяПеременной,
				MCPПредставлениеЗначенияДляMarkdown(Значение));
			Возврат ТекстОтвета;
		Иначе
			// Все переменные — формируем Markdown
			Строки = Новый Массив;
			Строки.Добавить("# Переменные контекста");
			Строки.Добавить("");
			
			КоличествоПеременных = 0;
			
			Если ОбъектКонтекст <> Неопределено И ТипЗнч(ОбъектКонтекст) = Тип("Структура") Тогда
				Строки.Добавить("## Контекст ($var$)");
				Для Каждого КлючЗначение Из ОбъектКонтекст Цикл
					Если Ванесса.ЭтоСлужебнаяПеременаяКонтекста(КлючЗначение.Ключ) Тогда
						Продолжить;
					КонецЕсли;
					Строки.Добавить("- `" + КлючЗначение.Ключ + "` = " + MCPПредставлениеЗначенияДляMarkdown(КлючЗначение.Значение));
					КоличествоПеременных = КоличествоПеременных + 1;
				КонецЦикла;
			КонецЕсли;
			
			Если ОбъектКонтекстСохраняемый <> Неопределено И ТипЗнч(ОбъектКонтекстСохраняемый) = Тип("Структура") Тогда
				Строки.Добавить("");
				Строки.Добавить("## Сохраняемый контекст ($$var$$)");
				Для Каждого КлючЗначение Из ОбъектКонтекстСохраняемый Цикл
					Если Ванесса.ЭтоСлужебнаяПеременаяКонтекста(КлючЗначение.Ключ) Тогда
						Продолжить;
					КонецЕсли;
					Строки.Добавить("- `" + КлючЗначение.Ключ + "` = " + MCPПредставлениеЗначенияДляMarkdown(КлючЗначение.Значение));
					КоличествоПеременных = КоличествоПеременных + 1;
				КонецЦикла;
			КонецЕсли;
			
			Если КоличествоПеременных = 0 Тогда
				Строки.Добавить(Ванесса.Локализовать("Переменных нет."));
			КонецЕсли;
			
			Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
		КонецЕсли;
		
	ИначеЕсли Действие = "set" Тогда
		Если Не ЗначениеЗаполнено(ИмяПеременной) Тогда
			ТекстОшибки = Ванесса.Локализовать("Параметр name обязателен для action=set.");
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстОшибки);
		КонецЕсли;
		
		Попытка
			Если ПеременнаяГлобальная Тогда
				ОбъектКонтекстСохраняемый.Вставить(ИмяПеременной, ЗначениеПеременнойПараметр);
			Иначе
				ОбъектКонтекст.Вставить(ИмяПеременной, ЗначениеПеременнойПараметр);
			КонецЕсли;	
			ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
				"# Переменная установлена
				|
				|- Имя: %1
				|- Значение: %2"),
				ИмяПеременной,
				MCPПредставлениеЗначенияДляMarkdown(ЗначениеПеременнойПараметр));
			Возврат ТекстОтвета;
		Исключение
			ТекстОшибки = Ванесса.Локализовать("Ошибка установки переменной:") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
		КонецПопытки;
		
	ИначеЕсли Действие = "delete" Тогда
		Если Не ЗначениеЗаполнено(ИмяПеременной) Тогда
			ТекстОшибки = Ванесса.Локализовать("Параметр name обязателен для action=delete.");
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстОшибки);
		КонецЕсли;
		
		Попытка
			// Удаляем из обоих контекстов
			Если ОбъектКонтекст <> Неопределено И ТипЗнч(ОбъектКонтекст) = Тип("Структура") Тогда
				Попытка
					ОбъектКонтекст.Удалить(ИмяПеременной);
				Исключение
				КонецПопытки;
			КонецЕсли;
			
			ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
				"# Переменная удалена
				|
				|- Имя: %1"),
				ИмяПеременной);
			Возврат ТекстОтвета;
		Исключение
			ТекстОшибки = Ванесса.Локализовать("Ошибка удаления:")+ " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
		КонецПопытки;
		
	Иначе
		ТекстОшибки = Ванесса.Локализовать("Неизвестное действие:") + " " + Действие + Ванесса.Локализовать(". Допустимые: get, set, delete.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстОшибки);
	КонецЕсли;
	
	
	Возврат Ванесса.Локализовать("Окно было успешно активизировано.");
	
КонецФункции

// Получает информацию из базы знаний
&НаКлиенте
Функция ПолучитьДанныеИзБазыЗнаний(Запрос, ДополнительныеПараметры) Экспорт
	
	ФорматОтвета = ЗначениеПараметраИзЗапроса(Запрос, "format");
	СтрокаПоиска = СокрЛП(ЗначениеПараметраИзЗапроса(Запрос, "search_string"));
	Попытка
		НомерВопроса = Число(ЗначениеПараметраИзЗапроса(Запрос, "question_number"));	
	Исключение
		НомерВопроса = Неопределено;
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ФорматОтвета) Тогда
		ТекстСообщения = Ванесса.Локализовать("Не указан обязательный параметр 'format'");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	Если ФорматОтвета <> "short_info"
		И ФорматОтвета <> "questions_only"
		И ФорматОтвета <> "one_question"
		И ФорматОтвета <> "question_search"
		И ФорматОтвета <> "answers_search"
		И ФорматОтвета <> "all"
		Тогда
		ТекстСообщения = Ванесса.Локализовать("Передано недопустимое значение параметра 'format'");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	Если глКешБазыЗнаний = Неопределено Тогда
		глКешБазыЗнаний = ПолныйТекстБазыЗнанийСервер();
	КонецЕсли;
	
	Возврат ДанныеИзБазыЗнанийКлиент(ФорматОтвета, НомерВопроса, СтрокаПоиска);
	
КонецФункции

// Получает информацию о статистике использования шагов
&НаКлиенте
Функция ПолучитьДанныеОЧастоИспользуемыхШагах(Запрос, ДополнительныеПараметры) Экспорт
	
	Количество = ЗначениеПараметраИзЗапроса(Запрос, "limit");
	Если НЕ ЗначениеЗаполнено(Количество) Тогда
		Количество = 100;
	КонецЕсли;	
	
	Если глЧастоИспользуемыеШаги = Неопределено Тогда
		глЧастоИспользуемыеШаги = ПолучитьДанныеМакетаЧастоИспользуемыеШаги();
	КонецЕсли;
	
	Возврат ДанныеОЧастоИспользуемыхШагах(Количество);
	
КонецФункции

// Получает список расширений, установленных в базе
&НаКлиенте
Функция ПолучитьСписокРасширений(Запрос, ДополнительныеПараметры) Экспорт
	
	Попытка
		АктивноеОкно = Ванесса.ПолучитьАктивноеОкноИзТестовоеПриложение();
	Исключение
		ТекстОшибки = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	
	Попытка
		// Получаем данные расширений с сервера
		ТекстОшибки = Неопределено;
		МассивДанныхРасширений = ПолучитьДанныеРасширенийКлиент(ТекстОшибки);
		Если ЗначениеЗаполнено(ТекстОшибки) Тогда
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
		КонецЕсли;
		
		// Формируем массив строк на клиенте
		Строки = СформироватьМассивСтрокРасширений(МассивДанныхРасширений);
		
		Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
		
	Исключение
		ТекстОшибки = Ванесса.Локализовать("Ошибка получения списка расширений:") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	
КонецФункции

// Универсальный инструмент для работы с таблицей профилей клиентов тестирования
&НаКлиенте
Функция УправлениеПрофилямиКлиентовТестирования(Запрос, ДополнительныеПараметры) Экспорт
	
	Действие = Строка(ЗначениеПараметраИзЗапроса(Запрос, "action"));
	Если НЕ ЗначениеЗаполнено(Действие) Тогда
		ТекстСообщения = Ванесса.Локализовать("Параметр action обязателен. Допустимые значения: 'get_list', 'add', 'edit'.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	Если Действие = "get_list" Тогда
		Возврат ПолучитьСписокПрофилейКлиентовТестирования();
	ИначеЕсли Действие = "add" Тогда
		Возврат ДобавитьПрофильКлиентаТестирования(Запрос);
	ИначеЕсли Действие = "edit" Тогда
		Возврат РедактироватьПрофильКлиентаТестирования(Запрос);
	Иначе
		ТекстСообщения = Ванесса.Локализовать("Неизвестное действие:") + " " + Действие + ". " + Ванесса.Локализовать("Допустимые: 'get_list', 'add', 'edit'.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
КонецФункции

// Получает список профилей клиентов тестирования
&НаКлиенте
Функция ПолучитьСписокПрофилейКлиентовТестирования()
	
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Список профилей клиентов тестирования"));
	Строки.Добавить("");
	
	Если Ванесса.ДанныеКлиентовТестирования.Количество() = 0 Тогда
		Строки.Добавить(Ванесса.Локализовать("Профили не настроены. Добавьте профиль на вкладке 'Клиенты тестирования' в настройках VA."));
	Иначе
		Строки.Добавить(Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Найдено профилей: %1"), Ванесса.ДанныеКлиентовТестирования.Количество()));
		Строки.Добавить("");
		Для Каждого СтрокаПрофиля Из Ванесса.ДанныеКлиентовТестирования Цикл
			Строки.Добавить(Ванесса.Локализовать("## Профиль: ") + СтрокаПрофиля.Имя);
			Строки.Добавить("");
			Строки.Добавить(Ванесса.Локализовать("| Свойство | Значение |"));
			Строки.Добавить(Ванесса.Локализовать("|----------|----------|"));
			Строки.Добавить(Ванесса.Локализовать("| Имя |") + " " + СтрокаПрофиля.Имя + " |");
			Строки.Добавить(Ванесса.Локализовать("| Синоним |") + " " + СтрокаПрофиля.Синоним + " |");
			Строки.Добавить(Ванесса.Локализовать("| Строка подключения |") + " " + СтрокаПрофиля.ПутьКИнфобазе + " |");
			Строки.Добавить(Ванесса.Локализовать("| Дополнительные параметры |") + " " + СтрокаПрофиля.ДопПараметры + " |");
			Строки.Добавить(Ванесса.Локализовать("| Тип клиента |") + " " + СтрокаПрофиля.ТипКлиента + " |");
			Строки.Добавить(Ванесса.Локализовать("| Имя компьютера |") + " " + СтрокаПрофиля.ИмяКомпьютера + " |");
			Строки.Добавить(Ванесса.Локализовать("| Дескриптор окна |") + " " + СтрокаПрофиля.ДескрипторОкна + " |");
			Строки.Добавить(Ванесса.Локализовать("| PID |") + " " + СтрокаПрофиля.PIDКлиентаТестирования + " |");
			СтатусПодключения = ?(СтрокаПрофиля.Подключен,Ванесса.Локализовать("✅ подключен"),Ванесса.Локализовать("❌ не подключен"));
			Строки.Добавить(Ванесса.Локализовать("| Статус |") + " " + СтатусПодключения + " |");
			Строки.Добавить("");
		КонецЦикла;
	КонецЕсли;
	
	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Добавляет профиль клиента тестирования
&НаКлиенте
Функция ДобавитьПрофильКлиентаТестирования(Запрос)
	
	ИмяПрофиля = Строка(ЗначениеПараметраИзЗапроса(Запрос, "name"));
	Если НЕ ЗначениеЗаполнено(ИмяПрофиля) Тогда
		ТекстСообщения = Ванесса.Локализовать("Параметр name обязателен для добавления профиля.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	// Проверяем, нет ли уже профиля с таким именем
	Для Каждого СтрокаПрофиля Из Ванесса.ДанныеКлиентовТестирования Цикл
		Если НРег(СтрокаПрофиля.Имя) = НРег(ИмяПрофиля) ИЛИ НРег(СтрокаПрофиля.Синоним) = НРег(ИмяПрофиля) Тогда
			ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Профиль с именем '%1' уже существует."), ИмяПрофиля);
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстСообщения);
		КонецЕсли;
	КонецЦикла;
	
	Попытка
		// Создаем новую строку в таблице профилей
		НоваяСтрока = Ванесса.ДанныеКлиентовТестирования.Добавить();
		НоваяСтрока.Имя = ИмяПрофиля;
		НоваяСтрока.Синоним = Строка(ЗначениеПараметраИзЗапроса(Запрос, "synonym"));
		НоваяСтрока.ПутьКИнфобазе = Строка(ЗначениеПараметраИзЗапроса(Запрос, "infobase_path"));
		НоваяСтрока.ДопПараметры = Строка(ЗначениеПараметраИзЗапроса(Запрос, "additional_parameters"));
		НоваяСтрока.ТипКлиента = Строка(ЗначениеПараметраИзЗапроса(Запрос, "client_type"));
		Если НЕ ЗначениеЗаполнено(НоваяСтрока.ТипКлиента) Тогда
			НоваяСтрока.ТипКлиента = "Тонкий";
		КонецЕсли;	
		НоваяСтрока.ИмяКомпьютера = Строка(ЗначениеПараметраИзЗапроса(Запрос, "computer_name"));
		НоваяСтрока.Подключен = Ложь;
		
		ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
			"# Профиль добавлен
			|
			|- Имя: %1
			|- Синоним: %2
			|
			|## Следующие шаги
			|- Используйте `connect_test_client` для подключения профиля"),
			ИмяПрофиля,
			НоваяСтрока.Синоним);
		Возврат ТекстОтвета;
	Исключение
		ТекстОшибки = Ванесса.Локализовать("Ошибка добавления профиля:") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	
КонецФункции

// Редактирует профиль клиента тестирования
&НаКлиенте
Функция РедактироватьПрофильКлиентаТестирования(Запрос)
	
	ИмяПрофиля = Строка(ЗначениеПараметраИзЗапроса(Запрос, "name"));
	Если НЕ ЗначениеЗаполнено(ИмяПрофиля) Тогда
		ТекстСообщения = Ванесса.Локализовать("Параметр name обязателен для редактирования профиля.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	// Ищем профиль с таким именем
	НайденныйПрофиль = Неопределено;
	Для Каждого СтрокаПрофиля Из Ванесса.ДанныеКлиентовТестирования Цикл
		Если НРег(СтрокаПрофиля.Имя) = НРег(ИмяПрофиля) ИЛИ НРег(СтрокаПрофиля.Синоним) = НРег(ИмяПрофиля)  Тогда
			НайденныйПрофиль = СтрокаПрофиля;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если НайденныйПрофиль = Неопределено Тогда
		ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Профиль с именем '%1' не найден."), ИмяПрофиля);
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстСообщения);
	КонецЕсли;
	
	Попытка
		// Обновляем поля профиля
		ЗначениеСиноним = ЗначениеПараметраИзЗапроса(Запрос, "synonym");
		Если ЗначениеЗаполнено(ЗначениеСиноним) Тогда
			НайденныйПрофиль.Синоним = ЗначениеСиноним;
		КонецЕсли;
		
		ЗначениеПуть = ЗначениеПараметраИзЗапроса(Запрос, "infobase_path");
		Если ЗначениеЗаполнено(ЗначениеПуть) Тогда
			НайденныйПрофиль.ПутьКИнфобазе = ЗначениеПуть;
		КонецЕсли;
		
		ЗначениеДопПараметры = ЗначениеПараметраИзЗапроса(Запрос, "additional_parameters");
		Если ЗначениеЗаполнено(ЗначениеДопПараметры) Тогда
			НайденныйПрофиль.ДопПараметры = ЗначениеДопПараметры;
		КонецЕсли;
		
		ЗначениеТипКлиента = ЗначениеПараметраИзЗапроса(Запрос, "client_type");
		Если ЗначениеЗаполнено(ЗначениеТипКлиента) Тогда
			НайденныйПрофиль.ТипКлиента = ЗначениеТипКлиента;
		КонецЕсли;
		
		ЗначениеИмяКомпьютера = ЗначениеПараметраИзЗапроса(Запрос, "computer_name");
		Если ЗначениеЗаполнено(ЗначениеИмяКомпьютера) Тогда
			НайденныйПрофиль.ИмяКомпьютера = ЗначениеИмяКомпьютера;
		КонецЕсли;
		
		ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
			"# Профиль отредактирован
			|
			|- Имя: %1
			|- Синоним: %2
			|
			|## Следующие шаги
			|- Используйте `connect_test_client` для подключения профиля"),
			НайденныйПрофиль.Имя,
			НайденныйПрофиль.Синоним);
		Возврат ТекстОтвета;
	Исключение
		ТекстОшибки = Ванесса.Локализовать("Ошибка редактирования профиля:") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	
КонецФункции

&НаКлиенте
Функция ПолучитьДанныеРасширенийКлиент(ТекстОшибки)
	// Нельзя получать данные по расширениям напрямую из базы менеджера тестирования, т.к. он мог долго не перезапускаться и данные (возможно) могут отличаться от данных клиента тестирования.
	Возврат ПолучитьДанныеРасширенийСПомощьюРасшренияVAExtension(ТекстОшибки);
КонецФункции

&НаКлиенте
Функция ПолучитьДанныеРасширенийСПомощьюРасшренияVAExtension(ТекстОшибки)
	
	Текст = "
	|Результат = Новый Массив;
	|
	|Данные = РасширенияКонфигурации.Получить();
	|Для Каждого ТекРасширение Из Данные Цикл
	|	ДанныеРасширения = Новый Структура;
	|	ДанныеРасширения.Вставить(""Имя"", ТекРасширение.Имя);
	|	ДанныеРасширения.Вставить(""Версия"", ТекРасширение.Версия);
	|	ДанныеРасширения.Вставить(""Назначение"", Строка(ТекРасширение.Назначение));
	|	ДанныеРасширения.Вставить(""ОбластьДействия"", Строка(ТекРасширение.ОбластьДействия));
	|	ДанныеРасширения.Вставить(""Активно"", ТекРасширение.Активно);
	|	ДанныеРасширения.Вставить(""БезопасныйРежим"", Строка(ТекРасширение.БезопасныйРежим));
	|	ДанныеРасширения.Вставить(""ЗащитаОтОпасныхДействий"", Строка(ТекРасширение.ЗащитаОтОпасныхДействий));
	|	
	|	Результат.Добавить(ДанныеРасширения);
	|	
	|	ЗаписьJSON = Новый ЗаписьJSON;
	|	ЗаписьJSON.УстановитьСтроку();
	|	ЗаписатьJSON(ЗаписьJSON, Результат);
	|	ЗначениеДляВозврата = ЗаписьJSON.Закрыть();
	|	
	|КонецЦикла;
	|";
	
	Ванесса.ОткрытьНавигационнуюСсылку("e1cib/app/Обработка.VAExtension_ВыполнитьПроизвольныйКод");
	ТестовоеПриложение = Ванесса.ПолучитьТестовоеПриложение();
	НужнаяФорма = ТестовоеПриложение.НайтиОбъект(Тип("ТестируемаяФорма"),, "*.VAExtension_ВыполнитьПроизвольныйКод.*",5);
	Если НужнаяФорма = Неопределено Тогда
		ТекстОшибки = Ванесса.Локализовать("Клиент тестирования подключен, но не найдена форма 'VAExtension_ВыполнитьПроизвольныйКод' из служебного расширения.");
		Возврат Неопределено
	КонецЕсли;	
	
	РеквизитВыражениеВычислено = Ванесса.НайтиРеквизитОткрытойФормыПоЗаголовку("ВыражениеВычислено", Истина);
	РеквизитКодДляВыполнения = Ванесса.НайтиРеквизитОткрытойФормыПоЗаголовку("КодДляВыполнения", Истина);
	РеквизитКодДляВыполнения.ВвестиТекст(Текст);
	
	АктивноеОкно = Ванесса.ПолучитьАктивноеОкноИзТестовоеПриложение();
	
	КнопкаВыполнитьКод = АктивноеОкно.НайтиОбъект(Тип("ТестируемаяКнопкаФормы"),,"ФормаВыполнитьКодСервер");
	
	КнопкаЗакрытьФорму = АктивноеОкно.НайтиОбъект(Тип("ТестируемаяКнопкаФормы"),,"ЗакрытьФорму");
	
	КнопкаВыполнитьКод.Нажать();
	
	БылаОшибка = Истина;
	Ванесса.ОжиданиеОкончанияОбработки(БылаОшибка, РеквизитВыражениеВычислено);
	
	Если БылаОшибка Тогда
		ТекстОшибки = Ванесса.Локализовать("Не получилось выполнить код для получения списка расширений на стороне клиента тестирования.");
		Возврат Неопределено
	КонецЕсли;
	
	РеквизитЗначениеДляВозврата = Ванесса.НайтиРеквизитОткрытойФормыПоЗаголовку("ЗначениеДляВозврата", Истина);
	ПредставлениеРезультата = Ванесса.ПолучитьПредставлениеДанныхЭлементаФормы(РеквизитЗначениеДляВозврата);
	
	Данные = Ванесса.ПрочитатьОбъектJSON(ПредставлениеРезультата);
	
	Попытка
		КнопкаЗакрытьФорму.Нажать();
	Исключение
		Ванесса.ЗаписатьЛогВЖРИнформация("ПолучениеДанныхРасширений", ОписаниеОшибки());
	КонецПопытки;
	
	Возврат Данные;
	
КонецФункции

// Формирует массив строк для вывода информации о расширениях
&НаКлиенте
Функция СформироватьМассивСтрокРасширений(МассивДанныхРасширений)
	
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Список расширений, установленных в базе"));
	Строки.Добавить("");
	
	КоличествоРасширений = 0;
	Для Каждого ДанныеРасширения Из МассивДанныхРасширений Цикл
		КоличествоРасширений = КоличествоРасширений + 1;
		Строки.Добавить(Ванесса.Локализовать("## ") + КоличествоРасширений + ". " + ДанныеРасширения.Имя);
		Строки.Добавить("");
		Строки.Добавить(Ванесса.Локализовать("| Свойство | Значение |"));
		Строки.Добавить(Ванесса.Локализовать("|----------|----------|"));
		Строки.Добавить(Ванесса.Локализовать("| Имя |") + " " + ДанныеРасширения.Имя + " |");
		Строки.Добавить(Ванесса.Локализовать("| Версия |") + " " + ДанныеРасширения.Версия + " |");
		Строки.Добавить(Ванесса.Локализовать("| Назначение |") + " " + ДанныеРасширения.Назначение + " |");
		Строки.Добавить(Ванесса.Локализовать("| Активно |") + " " + MCPПредставлениеЗначенияДляMarkdown(ДанныеРасширения.Активно) + " |");
		Строки.Добавить(Ванесса.Локализовать("| Безопасный режим |") + " " + MCPПредставлениеЗначенияДляMarkdown(ДанныеРасширения.БезопасныйРежим) + " |");
		//Строки.Добавить(Ванесса.Локализовать("| Область действия |") + " " + ДанныеРасширения.ОбластьДействия + " |");
		Строки.Добавить("");
	КонецЦикла;
	
	Если КоличествоРасширений = 0 Тогда
		Строки.Добавить(Ванесса.Локализовать("Расширения не найдены."));
		Строки.Добавить("");
	Иначе
		Строки.Добавить(Ванесса.Локализовать("## Итого:") + " " + КоличествоРасширений + " " + Ванесса.Локализовать("расширений"));
		Строки.Добавить("");
	КонецЕсли;
	
	Возврат Строки;
	
КонецФункции

// Универсальный инструмент для управления командным интерфейсом
&НаКлиенте
Функция УправлениеКоманднымИнтерфейсом(Запрос, ДополнительныеПараметры) Экспорт
	
	Действие = Строка(ЗначениеПараметраИзЗапроса(Запрос, "action"));
	Если НЕ ЗначениеЗаполнено(Действие) Тогда
		ТекстСообщения = Ванесса.Локализовать("Параметр action обязателен. Допустимые значения: 'get_section_panel', 'get_function_panel', 'click_section_panel', 'click_function_panel'.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	// Проверка подключения клиента тестирования
	Попытка
		АктивноеОкно = Ванесса.ПолучитьАктивноеОкноИзТестовоеПриложение();
	Исключение
		ТекстОшибки = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.Локализовать("Клиент тестирования не подключен. Сначала вызовите connect_test_client.") + " " + ТекстОшибки);
	КонецПопытки;
	
	Если Действие = "get_section_panel" Тогда
		Возврат ПолучитьПанельРазделов(Запрос);
	ИначеЕсли Действие = "get_function_panel" Тогда
		Возврат ПолучитьПанельФункций(Запрос);
	ИначеЕсли Действие = "click_section_panel" Тогда
		Возврат НажатьКнопкуПанелиРазделов(Запрос);
	ИначеЕсли Действие = "click_function_panel" Тогда
		Возврат НажатьКнопкуПанелиФункций(Запрос);
	Иначе
		ТекстСообщения = Ванесса.Локализовать("Неизвестное действие:") + " " + Действие + ". " + Ванесса.Локализовать("Допустимые: 'get_section_panel', 'get_function_panel', 'click_section_panel', 'click_function_panel'.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
КонецФункции

// Получает панель разделов (внутренняя реализация)
&НаКлиенте
Функция ПолучитьПанельРазделов(Запрос)
	
	ПанельРазделов = Ванесса.ПанельРазделов();
	Если ПанельРазделов = Неопределено Тогда
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.Локализовать("Панель разделов пуста или недоступна."));
	КонецЕсли;
	СписокКоманд = ПанельРазделов.НайтиОбъекты();
	
	// Markdown формат
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Панель разделов"));
	Строки.Добавить("");
	
	Если СписокКоманд.Количество() = 0 Тогда
		Строки.Добавить(Ванесса.Локализовать("Панель разделов пуста."));
	Иначе
		Для Каждого Команда Из СписокКоманд Цикл
			Строки.Добавить(Ванесса.Локализовать("- Команда:") + " " + Команда.ТекстЗаголовка);
			//Если ЗначениеЗаполнено(Команда.НавигационнаяСсылка) Тогда
			//	Строки.Добавить("  " + "- НавигационнаяСсылка:" + " " + Команда.НавигационнаяСсылка);
			//КонецЕсли;
			// Навигационные ссылки не добавляются для панели разделов, т.к. для них не работает переход по навигационной ссылке
			Строки.Добавить("");
		КонецЦикла;
	КонецЕсли;
	
	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Получает панель функций (внутренняя реализация)
&НаКлиенте
Функция ПолучитьПанельФункций(Запрос)
	
	ПанельФункций = Ванесса.ПанельФункций();
	
	Если ПанельФункций = Неопределено Тогда
		Возврат Ванесса.Локализовать("Панель функций пуста или недоступна. Возможно, не выбран раздел в панели разделов. Либо повторное нажатие на одну и туже команду панели разделов скрыло панель функций.");
	КонецЕсли;
	
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Панель функций"));
	Строки.Добавить("");
	
	ТекстОшибки = Неопределено;
	ДобавитьВМассивСтрокДанныеПанелиФункций(Строки, ТекстОшибки);
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецЕсли;	
	
	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Нажимает кнопку панели разделов (внутренняя реализация)
&НаКлиенте
Функция НажатьКнопкуПанелиРазделов(Запрос)
	
	Команда = Строка(ЗначениеПараметраИзЗапроса(Запрос, "command"));
	Если НЕ ЗначениеЗаполнено(Команда) Тогда
		ТекстСообщения = Ванесса.Локализовать("Параметр command обязателен для действия click_section_panel.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	ВозвратФункции = ЗначениеПараметраИзЗапроса(Запрос, "returnFunctionPanel");
	Если НЕ ЗначениеЗаполнено(ВозвратФункции) Тогда
		ВозвратФункции = Ложь;
	Иначе
		Попытка
			ВозвратФункции = Булево(ВозвратФункции);
		Исключение
			ВозвратФункции = Ложь;
		КонецПопытки;
	КонецЕсли;
	
	// Получаем панель разделов
	ПанельРазделов = Ванесса.ПанельРазделов();
	
	Если ПанельРазделов = Неопределено Тогда
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.Локализовать("Панель разделов пуста или недоступна."));
	КонецЕсли;
	
	// Ищем и нажимаем кнопку
	Попытка
		ДопПараметры = Новый Структура;
		ДопПараметры.Вставить("КоличествоПопыток", 1);
		Ванесса.ВПанелиРазделовЯВыбираю(Команда, ДопПараметры);
	Исключение
		ТекстОшибки = Ванесса.Локализовать("Не удалось нажать на команду панели разделов.") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	
	// Формируем ответ
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("# Команда панели разделов нажата: %1"), Команда));
	Строки.Добавить("");
	
	Если ВозвратФункции Тогда
		ТекстОшибки = Неопределено;
		ДобавитьВМассивСтрокДанныеПанелиФункций(Строки, ТекстОшибки);
		Если ЗначениеЗаполнено(ТекстОшибки) Тогда
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
		КонецЕсли;	
	КонецЕсли;
	
	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

&НаКлиенте
Процедура ДобавитьВМассивСтрокДанныеПанелиФункций(Строки, ТекстОшибки)
	Строки.Добавить(Ванесса.Локализовать("## Панель функций"));
	Строки.Добавить("");
	БылиЭлементы = Ложь;
	// Получаем панель функций после нажатия
	Попытка
		ПанельФункций = Ванесса.ПанельФункций();
		Если ПанельФункций <> Неопределено Тогда
			
			ДанныеПанелиФункций = ДанныеПанелиФункций(ПанельФункций);
			ЭлементыБезГруппы = ДанныеПанелиФункций.ЭлементыБезГруппы;
			КешГрупп = ДанныеПанелиФункций.КешГрупп;
			
			Если ЭлементыБезГруппы.Количество() > 0 Тогда
				Для Каждого Элем Из ЭлементыБезГруппы Цикл
					Строки.Добавить("- `" + Элем.ТекстЗаголовка + "`");
					БылиЭлементы = Истина;
				КонецЦикла;
				Строки.Добавить("");
			КонецЕсли;
			
			Для Каждого КлючЗначение Из КешГрупп Цикл
				Строки.Добавить(Ванесса.Локализовать("# Группа `") + КлючЗначение.Ключ + "`");
				ДанныеГруппы = КлючЗначение.Значение;
				Для Каждого Элем Из ДанныеГруппы Цикл
					Строки.Добавить("* `" + Элем.ТекстЗаголовка + "`");
					Строки.Добавить("  " + "- Навигацонная ссылка:" + " " + Элем.НавигационнаяСсылка);
					Строки.Добавить("");
					БылиЭлементы = Истина;
				КонецЦикла;	
			КонецЦикла;	
			
		КонецЕсли;
		
		Если НЕ БылиЭлементы Тогда
			Строки.Добавить(Ванесса.Локализовать("Панель функций пуста."));
		КонецЕсли;	
		
	Исключение
		ТекстОшибки = Ванесса.Локализовать("Не удалось нажать на команду панели функций.") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
	КонецПопытки;
КонецПроцедуры

&НаКлиенте
Функция ДанныеПанелиФункций(ПанельФункций)
	
	ЭлементыБезГруппы = Новый Массив;
	КешГрупп = Новый Соответствие;

	Результат = Новый Структура;
	Результат.Вставить("ЭлементыБезГруппы", ЭлементыБезГруппы);
	Результат.Вставить("КешГрупп", КешГрупп);
	
	СписокКомандФункций = ПанельФункций.НайтиОбъекты();
	Если СписокКомандФункций.Количество() = 0 Тогда
	Иначе
		КешНавигационныхССылок = Новый Соответствие;
		
		Для Каждого КомандаФункции Из СписокКомандФункций Цикл
			Если ТипЗнч(КомандаФункции) = Тип("ТестируемаяГруппаКомандногоИнтерфейса") Тогда
				Если КешГрупп[КомандаФункции.ТекстЗаголовка] = Неопределено Тогда
					ДанныеГруппы = Новый Массив;
					КешГрупп.Вставить(КомандаФункции.ТекстЗаголовка, ДанныеГруппы);
				КонецЕсли;
				
				ДанныеГруппы = КешГрупп[КомандаФункции.ТекстЗаголовка];
				
				ЭлементыГруппы = КомандаФункции.НайтиОбъекты();
				Для Каждого Элем Из ЭлементыГруппы Цикл
					Если ЗначениеЗаполнено(Элем.НавигационнаяСсылка) Тогда
						Если КешНавигационныхССылок[Элем.НавигационнаяСсылка] <> Неопределено Тогда
							Продолжить;
						КонецЕсли;
						КешНавигационныхССылок.Вставить(Элем.НавигационнаяСсылка, Элем);
					КонецЕсли;	
					ДанныеГруппы.Добавить(Элем);
				КонецЦикла;	
			КонецЕсли;
		КонецЦикла;
		
		// собираем элемены без группы
		Для Каждого КомандаФункции Из СписокКомандФункций Цикл
			Если ТипЗнч(КомандаФункции) = Тип("ТестируемаяГруппаКомандногоИнтерфейса") Тогда
				Продолжить;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(КомандаФункции.НавигационнаяСсылка) Тогда
				Если КешНавигационныхССылок[КомандаФункции.НавигационнаяСсылка] <> Неопределено Тогда
					Продолжить;
				КонецЕсли;
			КонецЕсли;	
			
			ЭлементыБезГруппы.Добавить(КомандаФункции);
			
		КонецЦикла;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции	

// Нажимает кнопку панели функций (внутренняя реализация)
&НаКлиенте
Функция НажатьКнопкуПанелиФункций(Запрос)
	
	Команда = Строка(ЗначениеПараметраИзЗапроса(Запрос, "command"));
	Если НЕ ЗначениеЗаполнено(Команда) Тогда
		ТекстСообщения = Ванесса.Локализовать("Параметр command обязателен для действия click_function_panel.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	Группа = Строка(ЗначениеПараметраИзЗапроса(Запрос, "group"));
	
	// Получаем панель функций
	ПанельФункций = Неопределено;
	Попытка
		ПанельФункций = Ванесса.ПанельФункций();
	Исключение
		ТекстОшибки = Ванесса.Локализовать("Не удалось получить панель функций.") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	
	Если ПанельФункций = Неопределено Тогда
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.Локализовать("Панель функций пуста или недоступна. Возможно, не выбран раздел в панели разделов."));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Группа) Тогда
		//Ищем группу
		
		ЭлементыГруппа = ПанельФункций.НайтиОбъекты(Тип("ТестируемаяГруппаКомандногоИнтерфейса"),Группа);
		Если ЭлементыГруппа.Количество() = 0 Тогда
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("В панели функций не найдена группа '%1'"), Группа));
		КонецЕсли;
		
		Если ЭлементыГруппа.Количество() > 1 Тогда
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("В панели функций найдено %1 групп с заголовоком '%2'"), XMLСтрока(ЭлементыГруппа.Количество()), Группа));
		КонецЕсли;
		
		ЭлементФункция = ЭлементыГруппа[0].НайтиОбъект(,Команда);
		Если ЭлементФункция = Неопределено Тогда
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("В панели функций в группе '%1' не найдена команда '%2'"), Группа, Команда));
		КонецЕсли;
		
		Попытка
			ЭлементФункция.Нажать();
		Исключение
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("В панели функций не получлось нажать на команду '%1'"), Команда)) + Символы.ПС + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		КонецПопытки;
	Иначе	
		ЭлементФункция = ПанельФункций.НайтиОбъект(,Команда);
		Если ЭлементФункция = Неопределено Тогда
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("В панели функций не найдена команда '%1'"), Команда));
		КонецЕсли;
		
		Попытка
			ЭлементФункция.Нажать();
		Исключение
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("В панели функций не получлось нажать на команду '%1'"), Команда)) + Символы.ПС + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		КонецПопытки;
	КонецЕсли;	
	
	Возврат Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("# Команда панели функций нажата: %1"), Команда);
	
КонецФункции

// Получает информацию о строке сценария. Если в строке находится шаг - то возвращает подробную информацию о шаге.
&НаКлиенте
Функция ПолучитьПодробнуюИнформациюОШагеВСтрокеСценария(Запрос, ДополнительныеПараметры) Экспорт
	
	НомерСтроки = Число(ЗначениеПараметраИзЗапроса(Запрос, "lineNumber"));	
	Если НЕ ЗначениеЗаполнено(НомерСтроки) Тогда
		ТекстСообщения = Ванесса.Локализовать("Не указан обязательный параметр 'lineNumber'");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	СтрокаДерева = Ванесса.СтрокаДереваПоНомеруСтрокиФичи(НомерСтроки);
	
	ЭкземплярVanessaEditor = Ванесса.ПолучитьVanessaEditor();
	Если СтрокаДерева = Неопределено Тогда
		Попытка
			ТекстСтроки = ЭкземплярVanessaEditor.getLineContent(НомерСтроки);
			ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("В строке %1 не найден шаг.
			|Текст в строке: %2"), XMLСтрока(НомерСтроки), ТекстСтроки);
			Возврат ТекстСообщения;
		Исключение
			ТекстОшибки = Ванесса.Локализовать("Ошибка:") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
		КонецПопытки;
	КонецЕсли;
	
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("### Данные строки"));
	Строки.Добавить("");
	ТекстСтроки = СокрЛ(ЭкземплярVanessaEditor.getLineContent(НомерСтроки));
	Строки.Добавить(Ванесса.Локализовать("Текст в строке:") + " " + ТекстСтроки);
	Строки.Добавить(Ванесса.Локализовать("Шаг в строке:") + " " + СтрокаДерева.Имя);
	Строки.Добавить(Ванесса.Локализовать("Снипет:") + " " + СтрокаДерева.Снипет);
	Строки.Добавить(Ванесса.Локализовать("Тип данных в строке:") + " " + СтрокаДерева.Тип);
	Если ЗначениеЗаполнено(СтрокаДерева.ДопТип) Тогда
		Строки.Добавить(Ванесса.Локализовать("Уточнение типа:") + " " + СтрокаДерева.ДопТип);
	КонецЕсли;	
	
	Если СтрокаДерева.Тип = "Шаг" Тогда
		СтрокаДляПоиска = ПолучитьСтрокуДляПоискаШагаПоСнипету(СтрокаДерева.Снипет);
		Отбор = Новый Структура();
		Отбор.Вставить("СтрокаДляПоиска", СтрокаДляПоиска);
		СтрокиТаблицы = Ванесса.ТаблицаИзвестныхStepDefinition.НайтиСтроки(Отбор);
		СтрокаТаблицаИзвестныхStepDefinition = Неопределено;
		Если СтрокиТаблицы.Количество() > 0 Тогда
			СтрокаТаблицаИзвестныхStepDefinition = СтрокиТаблицы[0];
		КонецЕсли;	
		Если СтрокаТаблицаИзвестныхStepDefinition = Неопределено Тогда
			Строки.Добавить(Ванесса.Локализовать("В таблице известных шагов не найден шаг:") + " " + СтрокаДерева.Имя);
		Иначе	
			Строки.Добавить(Ванесса.Локализовать("## Данные шага:"));
			Строки.Добавить(Ванесса.Локализовать("  " + "- Тип шага:") + " " + СтрокаТаблицаИзвестныхStepDefinition.ТипШага);
			ИмяФайла = СтрокаТаблицаИзвестныхStepDefinition.ИмяФайла;
			Если НЕ Ванесса.ЭтоLinuxКлиент() Тогда
				ИмяФайла = СтрЗаменить(ИмяФайла, "/", "\");
			КонецЕсли;	
			Строки.Добавить(Ванесса.Локализовать("  " + "- Имя файла где находится реализация шага:") + " " + ИмяФайла);
			Строки.Добавить(Ванесса.Локализовать("# Описание шага:"));
			Строки.Добавить(СтрокаТаблицаИзвестныхStepDefinition.ОписаниеШага);
		КонецЕсли;	
	КонецЕсли;	
	
	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Добавляет, читает и удаляет точки останова
&НаКлиенте
Функция УправлениеТочкамиОстанова(Запрос, ДополнительныеПараметры) Экспорт
	
	Если НЕ Ванесса.Объект.ИспользоватьРедакторVanessaEditor Тогда
		ТекстОшибки = Ванесса.Локализовать("Работать с точками останова можно только когда используется основной редактор Vanessa Automation, а сейчас он выключен.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецЕсли;	
	
	Действие = Строка(ЗначениеПараметраИзЗапроса(Запрос, "action"));
	Если НЕ ЗначениеЗаполнено(Действие) Тогда
		Действие = "toggle";
	КонецЕсли;
	
	Если Действие = "list" Тогда
		Попытка
			МассивБрейкпоинтов = Ванесса.БрейкпоинтыVanessaEditor();
			Строки = Новый Массив;
			Строки.Добавить(Ванесса.Локализовать("# Точки останова"));
			Строки.Добавить("");
			Если МассивБрейкпоинтов <> Неопределено И ТипЗнч(МассивБрейкпоинтов) = Тип("Массив") И МассивБрейкпоинтов.Количество() > 0 Тогда
				Строки.Добавить(Ванесса.Локализовать("Количество:") + " " + Формат(МассивБрейкпоинтов.Количество(), "ЧГ=0; ЧН=0"));
				Для Каждого ДанныеТочкиОстнова Из МассивБрейкпоинтов Цикл
					Строки.Добавить("- " + ДанныеТочкиОстнова.НомерСтроки);
				КонецЦикла;
			Иначе
				Строки.Добавить(Ванесса.Локализовать("Точек останова нет."));
				Строки.Добавить("");
				// Контекст: показать открытые файлы
				Если Не Ванесса.ОтсутствуетVanessaEditor() Тогда
					Попытка
						Редактор = Ванесса.ПолучитьVanessaEditor();
						СписокВкладок = Редактор.tabsGetAll();
						Если ТипЗнч(СписокВкладок) = Тип("Массив") И СписокВкладок.Количество() > 0 Тогда
							Строки.Добавить("## Открытые файлы");
							Для Каждого Вкладка Из СписокВкладок Цикл
								Строки.Добавить("- " + Строка(Вкладка));
							КонецЦикла;
						Иначе
							Строки.Добавить(Ванесса.Локализовать("Файлы не открыты. Загрузите фичи (`load_features`) и откройте сценарий."));
						КонецЕсли;
					Исключение
						Строки.Добавить(Ванесса.Локализовать("Загрузите фичи (`load_features`) и откройте сценарий для работы с точками останова."));
					КонецПопытки;
				Иначе
					Строки.Добавить(Ванесса.Локализовать("Редактор не доступен. Загрузите фичи (`load_features`) для инициализации."));
				КонецЕсли;
				Строки.Добавить("");
				Строки.Добавить(Ванесса.Локализовать("## Как добавить"));
				Строки.Добавить(Ванесса.Локализовать("- Используйте `manage_breakpoints(action='toggle', line=N)` для переключения точки останова на строке N."));
			КонецЕсли;
			
			Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
		Исключение
			ТекстОшибки = Ванесса.Локализовать("Ошибка:") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
		КонецПопытки;
		
	ИначеЕсли Действие = "remove_all" Тогда
		Попытка
			МассивБрейкпоинтов = Ванесса.Брейкпоинты();
			Количество = 0;
			Если МассивБрейкпоинтов <> Неопределено И ТипЗнч(МассивБрейкпоинтов) = Тип("Массив") Тогда
				Количество = МассивБрейкпоинтов.Количество();
			КонецЕсли;
			
			// Удаляем все точки останова через API редактора
			Если НЕ Ванесса.ОтсутствуетVanessaEditor() Тогда
				Ванесса.УдалитьВсеТочкиОстановаРедактора();
			КонецЕсли;
			
			ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
				"# Точки останова удалены
				|
				|- Удалено: %1"),
				Формат(Количество, "ЧГ=0; ЧН=0"));
			Возврат ТекстОтвета;
		Исключение
			ТекстОшибки = Ванесса.Локализовать("Ошибка:") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
		КонецПопытки;
		
	ИначеЕсли Действие = "toggle" Тогда
		Попытка
			
			Если НЕ Ванесса.ЭтоВкладкаEdit(Ванесса.VanessaTabs.current) Тогда
				ТекстОшибки = Ванесса.Локализовать("В редакторе не открыт фича файл.");
				Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
			КонецЕсли;	
			
			НомерСтроки = Число(ЗначениеПараметраИзЗапроса(Запрос, "line"));
			РедакторДоступен = НЕ Ванесса.ОтсутствуетVanessaEditor();
			
			Если НомерСтроки <> Неопределено И РедакторДоступен Тогда
				Редактор = Ванесса.ПолучитьVanessaEditor();
				Редактор.toggleBreakpoint(НомерСтроки);
			ИначеЕсли НомерСтроки <> Неопределено И Не РедакторДоступен Тогда
				ТекстОшибки = Ванесса.Локализовать("Редактор Monaco недоступен. Загрузите фичи (`load_features`) для инициализации редактора.");
				Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
			Иначе
				Ванесса.ОбработатьУстановкуСнятиеБрейкпоинта();
			КонецЕсли;
			
			Если НомерСтроки <> Неопределено Тогда
				ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
					"# Брейкпоинт переключён
					|
					|- Строка: %1"),
					Формат(НомерСтроки, "ЧГ=0; ЧН=0"));
			Иначе
				ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
					"# Брейкпоинт переключён
					|
					|- Строка: текущая"));
			КонецЕсли;
			Возврат ТекстОтвета;
		Исключение
			ТекстОшибки = Ванесса.Локализовать("Ошибка:") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
		КонецПопытки;
		
	Иначе
		ТекстОшибки = Ванесса.Локализовать("Неизвестное действие:") + " " + Действие + ". " + Ванесса.Локализовать("Допустимые: toggle, remove_all, list.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецЕсли;
	
КонецФункции

// Выполняет сценарий или все сценарии
&НаКлиенте
Функция ВыполнитьСценарий(Запрос, ДополнительныеПараметры) Экспорт
	
	Если Ванесса.Объект.ИдетВыполнениеСценариев Тогда
		ТекстСообщения = Ванесса.Локализовать("Сценарии уже выполняются. Дождитесь завершения или вызовите stopExecution.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстСообщения);
	КонецЕсли;
	
	Режим = "all";
	Значение = Строка(ЗначениеПараметраИзЗапроса(Запрос, "mode"));
	Если ЗначениеЗаполнено(Значение) Тогда
		Режим = Значение;
	КонецЕсли;	
	
	// Параметр filePath: загрузить фичу и открыть в редакторе перед запуском
	ПутьКФайлу = Строка(ЗначениеПараметраИзЗапроса(Запрос, "filePath"));
	Попытка
		НомерСтроки = Число(ЗначениеПараметраИзЗапроса(Запрос, "linenumber"));
	Исключение
		НомерСтроки = Неопределено;
	КонецПопытки;

	Идентификатор = Запрос.Идентификатор;
	Ванесса.УстановитьИдентификаторЗадачиMCP(Идентификатор);
	
	ДопПараметрыВызоваMCP = Новый Структура;
	ДопПараметрыВызоваMCP.Вставить("Тип", "ВыполнитьСценарий");
	ДопПараметрыВызоваMCP.Вставить("ПутьКФайлу", ПутьКФайлу);
	ДопПараметрыВызоваMCP.Вставить("Режим", Режим);
	ДопПараметрыВызоваMCP.Вставить("Идентификатор", Идентификатор);
	ДопПараметрыВызоваMCP.Вставить("НомерСтроки", НомерСтроки);
	
	ПродолжитьВыполнитьСценарий1(ПутьКФайлу, ДопПараметрыВызоваMCP);
	
КонецФункции

// Останавливает выполнение сценариев
&НаКлиенте
Функция ОстановитьВыполнениеСценариев(Запрос, ДополнительныеПараметры) Экспорт
	
	БылоВыполнение = Ванесса.Объект.ИдетВыполнениеСценариев;
	
	Попытка
		Ванесса.КомандаОстановитьСценарии();
	Исключение
	КонецПопытки;
	
	Если Не БылоВыполнение Тогда
		ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
			"# Остановка выполнения
			|
			|- Остановлено: да
			|- Было активное выполнение: %1
			|
			|Сценарии не выполнялись. Используйте `run_scenario` для запуска."),
			MCPПредставлениеЗначенияДляMarkdown(БылоВыполнение));
	Иначе
		ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
			"# Остановка выполнения
			|
			|- Остановлено: да
			|- Было активное выполнение: %1
			|
			|## Следующие шаги
			|- Получите результаты: `get_test_results`"),
			MCPПредставлениеЗначенияДляMarkdown(БылоВыполнение));
	КонецЕсли;
	
	Возврат ТекстОтвета;
	
КонецФункции

// Получает результат выполнения тестов
&НаКлиенте
Функция ПолучитьРезультатВыполненияТестов(Запрос, ДополнительныеПараметры) Экспорт
	
	Результат = Неопределено;
	ИдСценария = Строка(ЗначениеПараметраИзЗапроса(Запрос, "scenarioId"));

	Если ЗначениеЗаполнено(ИдСценария) Тогда
		Попытка
			Результат = Ванесса.ПолучитьРезультатПрохожденияТестовСценария(ИдСценария);
		Исключение
			ТекстОшибки = Ванесса.Локализовать("Ошибка получения результата:") + " " + ОписаниеОшибки();
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
		КонецПопытки;
	Иначе
		// Последний результат
		
		МассивРезультатПрохожденияТестовСценария = Ванесса.ПолучитьМассивРезультатПрохожденияТестовСценария();	
		
		Попытка
			Если МассивРезультатПрохожденияТестовСценария <> Неопределено 
				И МассивРезультатПрохожденияТестовСценария.Количество() > 0 Тогда
				Результат = МассивРезультатПрохожденияТестовСценария[МассивРезультатПрохожденияТестовСценария.Количество() - 1];
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Если Результат = Неопределено Тогда
		
		ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
				"# Результаты тестов
				|
				|Нет результатов выполнения.
				|
				|## Следующие шаги
				|- Загрузите фичи: `load_features`
				|- Запустите сценарий: `run_scenario`
				|- Затем повторите: `get_test_results`"));
		
		Возврат ТекстСообщения;
	КонецЕсли;
	
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
		"# Результаты тестов
		|
		|- Статус: %1"),
		MCPПредставлениеЗначенияДляMarkdown(MCPБезопасноеСвойство(Результат, "Статус"))));
	
	ВремяНач = MCPБезопасноеСвойство(Результат, "ВремяНачала");
	ВремяКон = MCPБезопасноеСвойство(Результат, "ВремяОкончания");
	Если ВремяНач <> Неопределено И ВремяКон <> Неопределено Тогда
		Строки.Добавить(Ванесса.Локализовать("- Длительность:") + " " + Формат(ВремяКон - ВремяНач, "ЧГ=0; ЧН=0") + Ванесса.Локализовать(" мс"));
	КонецЕсли;
	
	ОписаниеОшибкиРез = MCPБезопасноеСвойство(Результат, "ОписаниеОшибки");
	Если ЗначениеЗаполнено(ОписаниеОшибкиРез) Тогда
		Строки.Добавить(Ванесса.Локализовать("- Ошибка:") + " " + ОписаниеОшибкиРез);
	КонецЕсли;
	Строки.Добавить("");
	
	ШагиРезультаты = MCPБезопасноеСвойство(Результат, "РезультатПрохожденияТестовШагов");
	Если ШагиРезультаты <> Неопределено И ТипЗнч(ШагиРезультаты) = Тип("Массив") Тогда
		Строки.Добавить(Ванесса.Локализовать("## Шаги (") + Формат(ШагиРезультаты.Количество(), "ЧГ=0; ЧН=0") + ")");
		Номер = 0;
		Для Каждого ШагРез Из ШагиРезультаты Цикл
			Номер = Номер + 1;
			ИмяШага = MCPПредставлениеЗначенияДляMarkdown(MCPБезопасноеСвойство(ШагРез, "Имя"));
			СтатусШага = MCPПредставлениеЗначенияДляMarkdown(MCPБезопасноеСвойство(ШагРез, "Статус"));
			
			ВремяНачШ = MCPБезопасноеСвойство(ШагРез, "ВремяНачала");
			ВремяКонШ = MCPБезопасноеСвойство(ШагРез, "ВремяОкончания");
			ВремяШага = "";
			Если ВремяНачШ <> Неопределено И ВремяКонШ <> Неопределено Тогда
				ВремяШага = " (" + Формат(ВремяКонШ - ВремяНачШ, "ЧГ=0; ЧН=0") + " " + Ванесса.Локализовать("мс)");
			КонецЕсли;
			
			ОшибкаШага = ТекстОшибкиИзОписанияОшибки(MCPБезопасноеСвойство(ШагРез, "ОписаниеОшибки"));
			
			Строки.Добавить(Формат(Номер, "ЧГ=0; ЧН=0") + ". " + ИмяШага + " → **" + СтатусШага + "**" + ВремяШага);
			Если ЗначениеЗаполнено(ОшибкаШага) Тогда
				Строки.Добавить(Ванесса.Локализовать("   " + "- Ошибка:") + " " + ОшибкаШага);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);

КонецФункции

