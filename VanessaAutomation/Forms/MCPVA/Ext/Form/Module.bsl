Функция ПолучитьОкнаДляСкриншотов(РезультатВызова)
	
	ДанныеОкон = Ванесса.ПрочитатьСтрокуJSON(РезультатВызова);
	ОкнаДляСкриншотов = Новый Массив;
	Если ТипЗнч(ДанныеОкон) = Тип("Массив") Тогда
		Для каждого ДанныеОкна из ДанныеОкон Цикл
			Если Ванесса.ЭтоОкноНеДляСнятияСкриншотов(ДанныеОкна) Тогда
				Ванесса.ЗаписатьЛогВЖРИнформация("СнятиеСкриншота.ОкноПропущено.Class", Ванесса.ЗаписатьОбъектJSON(ДанныеОкна));
				Продолжить;
			КонецЕсли;
			
			Если ДанныеОкна.Свойство("Types") И Ванесса.ОкноДанногоТипаНеДляСнятияСкриншотов(ДанныеОкна.Types) Тогда
				Ванесса.ЗаписатьЛогВЖРИнформация("СнятиеСкриншота.ОкноПропущено.Types", Ванесса.ЗаписатьОбъектJSON(ДанныеОкна));
				Продолжить;
			КонецЕсли;	
			
			ДанныеОкнаОтвет = Новый Структура;
			ДанныеОкнаОтвет.Вставить("Заголовок", ДанныеОкна.Title);
			ДанныеОкнаОтвет.Вставить("ПолныеДанныеОкна", ДанныеОкна);
			ОкнаДляСкриншотов.Добавить(ДанныеОкнаОтвет);
		КонецЦикла;
	КонецЕсли;
	
	Возврат ОкнаДляСкриншотов;
	
КонецФункции

