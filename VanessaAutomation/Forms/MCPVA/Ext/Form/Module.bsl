	Описание_Формат = Ванесса.Локализовать("Формат файла: 'mxl' (MXL, по умолчанию), 'xlsx' (Excel), 'pdf' (PDF).");
    Свойства.Вставить("format", ПараметрыСозданияMCP.МодульМсп_СхемаПараметров.НовыйСвойствоСхемы("string", Описание_Формат));
	
	Описание_ИмяЭлементаФормы = Ванесса.Локализовать("Имя элемента формы (табличного документа) для сохранения. Обязательный параметр.");
    Свойства.Вставить("form_element_name", ПараметрыСозданияMCP.МодульМсп_СхемаПараметров.НовыйСвойствоСхемы("string", Описание_ИмяЭлементаФормы));
	
    ТребуемыеПоля = Новый Массив;
	ТребуемыеПоля.Добавить("file_name");
	ТребуемыеПоля.Добавить("form_element_name");
    Схема = ПараметрыСозданияMCP.МодульМсп_СхемаПараметров.НовыйСхемаОбъекта(Свойства, ТребуемыеПоля);
	ПараметрыСозданияMCP.МодульМсп_Сервер.ЗарегистрироватьИнструмент(ПараметрыСозданияMCP.МодульМсп_Сервер.НовыйИнструмент(
        "save_table_document_to_file",
        Ванесса.Локализовать("Сохраняет содержимое табличного документа в файл на диске.
		|Поддерживаемые форматы: 'mxl' (MXL), 'xlsx' (Excel), 'pdf' (PDF).
		|Параметр file_name обязателен и должен содержать полный путь к файлу.
		|Параметр format необязательный, по умолчанию 'mxl'.
		|Параметр form_element_name обязателен и должен содержать имя элемента формы (табличного документа) для сохранения."),
        Схема,
        Новый ОписаниеОповещения("СохранитьТабличныйДокументВФайл", Вычислить("ЭтотОбъект")),
		Ложь),
	    ИмяПровайдера());
		
КонецПроцедуры

// Возвращает значения реквизитов объекта связанного с формой
&НаКлиенте
Функция ПолучитьРеквизитыОбъекта(Запрос, ДополнительныеПараметры) Экспорт
	
	// Получаем параметр data_mode (по умолчанию 'all')
	РежимДанных = Строка(ЗначениеПараметраИзЗапроса(Запрос, "data_mode"));
	Если НЕ ЗначениеЗаполнено(РежимДанных) Тогда
		РежимДанных = "all";
	Иначе
		РежимДанных = НРег(СокрЛП(РежимДанных));
	КонецЕсли;
	
	// Проверка допустимого значения
	ДопустимыеРежимы = Новый Массив;
	ДопустимыеРежимы.Добавить("all");
	ДопустимыеРежимы.Добавить("attributes_only");
	ДопустимыеРежимы.Добавить("single_attribute");
	ДопустимыеРежимы.Добавить("tabular_sections_only");
	ДопустимыеРежимы.Добавить("single_tabular_section");
	
	Если ДопустимыеРежимы.Найти(РежимДанных) = Неопределено Тогда
		ТекстСообщения = Ванесса.Локализовать("Недопустимое значение data_mode. Допустимые значения: 'all', 'attributes_only', 'single_attribute', 'tabular_sections_only', 'single_tabular_section'.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	// Получаем параметр attribute_name для режима single_attribute
	ИмяРеквизита = Строка(ЗначениеПараметраИзЗапроса(Запрос, "attribute_name"));
	Если РежимДанных = "single_attribute" И НЕ ЗначениеЗаполнено(ИмяРеквизита) Тогда
		ТекстСообщения = Ванесса.Локализовать("Для режима data_mode='single_attribute' необходимо указать параметр attribute_name.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	// Получаем параметр tabular_section_name для режима single_tabular_section
	ИмяТабличнойЧасти = Строка(ЗначениеПараметраИзЗапроса(Запрос, "tabular_section_name"));
	Если РежимДанных = "single_tabular_section" И НЕ ЗначениеЗаполнено(ИмяТабличнойЧасти) Тогда
		ТекстСообщения = Ванесса.Локализовать("Для режима data_mode='single_tabular_section' необходимо указать параметр tabular_section_name.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	// Получаем параметр only_filled (по умолчанию false - возвращать все реквизиты)
	ТолькоЗаполненные = ЗначениеПараметраИзЗапроса(Запрос, "only_filled");
	Если ТолькоЗаполненные = Неопределено Тогда
		ТолькоЗаполненные = Ложь;
	Иначе
		Попытка
			ТолькоЗаполненные = Булево(ТолькоЗаполненные);
		Исключение
			ТолькоЗаполненные = Ложь;
		КонецПопытки;
	КонецЕсли;
	
	// Проверяем подключение клиента тестирования
	Попытка
		АктивноеОкно = Ванесса.ПолучитьАктивноеОкноИзТестовоеПриложение();
	Исключение
		ТекстОшибки = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.Локализовать("Клиент тестирования не подключен. Сначала вызовите connect_test_client.") + " " + ТекстОшибки);
	КонецПопытки;
	
	ТекстОшибки = Неопределено;
	ДанныеОбъекта = ДанныеОбъектаИзУказанногоОкна(АктивноеОкно.Заголовок, ТекстОшибки);
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецЕсли;
	
	// Формируем результат
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Реквизиты объекта"));
	Строки.Добавить("");
	
	// Получаем реквизиты шапки
	Если РежимДанных = "all" ИЛИ РежимДанных = "attributes_only" ИЛИ РежимДанных = "single_attribute" Тогда
		Если РежимДанных = "single_attribute" Тогда
			//Получаем только указанный реквизит
			Нашли = Ложь;
			Попытка
				Для Каждого ТекРеквизит Из ДанныеОбъекта.СтандартныеРеквизиты Цикл
					Если НРег(ТекРеквизит.Имя) = НРег(ИмяРеквизита) Тогда
						ДобавитьРеквизитКВыводуВMarkdown(Строки, ТекРеквизит);
						Нашли = Истина;
						Прервать;
					КонецЕсли;	
				КонецЦикла;
				
				Если НЕ Нашли Тогда
					Для Каждого ТекРеквизит Из ДанныеОбъекта.РеквизитыШапки Цикл
						Если НРег(ТекРеквизит.Имя) = НРег(ИмяРеквизита) Тогда
							ДобавитьРеквизитКВыводуВMarkdown(Строки, ТекРеквизит);
							Нашли = Истина;
							Прервать;
						КонецЕсли;	
					КонецЦикла;
				КонецЕсли;	
				
			Исключение
				ТекстОшибки = Ванесса.Локализовать("Реквизит '%1' не найден в объекте.") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
				ТекстОшибки = Ванесса.ПодставитьПараметрыВСтроку(ТекстОшибки, ИмяРеквизита);
				Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
			КонецПопытки;
			
			Если НЕ Нашли Тогда
				ТекстОшибки = Ванесса.Локализовать("Реквизит '%1' не найден в объекте.");
				ТекстОшибки = Ванесса.ПодставитьПараметрыВСтроку(ТекстОшибки, ИмяРеквизита);
				Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
			КонецЕсли;	
			
		Иначе
			// Получаем все реквизиты шапки или все данные
			Строки.Добавить(Ванесса.Локализовать("## Реквизиты шапки"));
			Строки.Добавить("");
			
			Для Каждого ТекРеквизит Из ДанныеОбъекта.СтандартныеРеквизиты Цикл
				ДобавитьРеквизитКВыводуВMarkdown(Строки, ТекРеквизит, ТолькоЗаполненные);
			КонецЦикла;
			
			Для Каждого ТекРеквизит Из ДанныеОбъекта.РеквизитыШапки Цикл
				ДобавитьРеквизитКВыводуВMarkdown(Строки, ТекРеквизит, ТолькоЗаполненные);
			КонецЦикла;
			
		КонецЕсли;
	КонецЕсли;
	
	// Получаем табличные части
	Если РежимДанных = "all" ИЛИ РежимДанных = "tabular_sections_only" ИЛИ РежимДанных = "single_tabular_section" Тогда
		Если РежимДанных = "single_tabular_section" Тогда
			// Получаем только указанную табличную часть
			Попытка
				
				Нашли = Ложь;
				Для Каждого ТекТабличнаяЧасть Из ДанныеОбъекта.ТабличныеЧасти Цикл
					Если НРег(ТекТабличнаяЧасть.Имя) = НРег(ИмяТабличнойЧасти) Тогда
						ВывестиРеквизитыТабличнойЧастиВMarkdown(Строки, ТекТабличнаяЧасть);
						Нашли = Истина;
						Прервать;
					КонецЕсли;	
				КонецЦикла;
				
			Исключение
				ТекстОшибки = Ванесса.Локализовать("Табличная часть '%1' не найдена в объекте.") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
				ТекстОшибки = Ванесса.ПодставитьПараметрыВСтроку(ТекстОшибки, ИмяТабличнойЧасти);
				Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
			КонецПопытки;
			
			Если НЕ Нашли Тогда
				ТекстОшибки = Ванесса.Локализовать("Табличная часть '%1' не найдена в объекте.");
				ТекстОшибки = Ванесса.ПодставитьПараметрыВСтроку(ТекстОшибки, ИмяТабличнойЧасти);
				Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
			КонецЕсли;	
			
		Иначе
			// Получаем все табличные части или все данные
			Строки.Добавить(Ванесса.Локализовать("## Табличные части"));
			Строки.Добавить("");
			
			Для Каждого ТекТабличнаяЧасть Из ДанныеОбъекта.ТабличныеЧасти Цикл
				ВывестиРеквизитыТабличнойЧастиВMarkdown(Строки, ТекТабличнаяЧасть, ТолькоЗаполненные);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

&НаКлиенте
Функция ДанныеОбъектаИзУказанногоОкна(ЗаголовокОкна, ТекстОшибки)
	Ванесса.ОткрытьНавигационнуюСсылку("e1cib/app/Обработка.VAExtension_ДанныеРеквизитовОбъекта");
	ТестовоеПриложение = Ванесса.ПолучитьТестовоеПриложение();
	НужнаяФорма = ТестовоеПриложение.НайтиОбъект(Тип("ТестируемаяФорма"),, "*.VAExtension_ДанныеРеквизитовОбъекта.*",5);
	Если НужнаяФорма = Неопределено Тогда
		ТекстОшибки = Ванесса.Локализовать("Клиент тестирования подключен, но не найдена форма 'VAExtension_ДанныеРеквизитовОбъекта' из служебного расширения.");
		Возврат Неопределено
	КонецЕсли;	
	
	РеквизитВыражениеВычислено = Ванесса.НайтиРеквизитОткрытойФормыПоЗаголовку("ОбработкаВыполнена", Истина);
	РеквизитЗаголовокОкна = Ванесса.НайтиРеквизитОткрытойФормыПоЗаголовку("ЗаголовокОкна", Истина);
	РеквизитЗаголовокОкна.ВвестиТекст(ЗаголовокОкна);
	
	АктивноеОкно = Ванесса.ПолучитьАктивноеОкноИзТестовоеПриложение();
	
	КнопкаВыполнитьОбработку = АктивноеОкно.НайтиОбъект(Тип("ТестируемаяКнопкаФормы"),,"ФормаВыполнитьОбработку");
	
	КнопкаЗакрытьФорму = АктивноеОкно.НайтиОбъект(Тип("ТестируемаяКнопкаФормы"),,"ЗакрытьФорму");
	
	КнопкаВыполнитьОбработку.Нажать();
	
	БылаОшибка = Истина;
	Ванесса.ОжиданиеОкончанияОбработки(БылаОшибка, РеквизитВыражениеВычислено);
	
	Если БылаОшибка Тогда
		ТекстОшибки = Ванесса.Локализовать("Не вышло получить данные объекта из текущего окна.");
		Возврат Неопределено
	КонецЕсли;
	
	РеквизитЗначениеДляВозврата = Ванесса.НайтиРеквизитОткрытойФормыПоЗаголовку("ЗначениеРезультат", Истина);
	ПредставлениеРезультата = Ванесса.ПолучитьПредставлениеДанныхЭлементаФормы(РеквизитЗначениеДляВозврата);
	
	Данные = Ванесса.ПрочитатьОбъектJSON(ПредставлениеРезультата);
	
	Попытка
		КнопкаЗакрытьФорму.Нажать();
	Исключение
		Ванесса.ЗаписатьЛогВЖРИнформация("ДанныеОбъектаИзУказанногоОкна", ОписаниеОшибки());
	КонецПопытки;
	
	Возврат Данные;
КонецФункции	

&НаКлиенте
Процедура ДобавитьРеквизитКВыводуВMarkdown(Строки, ТекРеквизит, ТолькоЗаполненные = Ложь)
	ЗначениеРеквизита = ТекРеквизит.Значение;
	ТипРеквизита = ТекРеквизит.Тип;
	
	// Если установлен флаг ТолькоЗаполненные и значение пустое - пропускаем реквизит
	Если ТолькоЗаполненные И НЕ ЗначениеЗаполнено(ЗначениеРеквизита) Тогда
		Возврат;
	КонецЕсли;
	
	Строки.Добавить(Ванесса.Локализовать("## Реквизит:") + " " + ТекРеквизит.Имя);
	Строки.Добавить("");
	Строки.Добавить(Ванесса.Локализовать("- Тип:") + " " + ТипРеквизита);
	Строки.Добавить(Ванесса.Локализовать("- Значение:") + " " + MCPПредставлениеЗначенияДляMarkdown(ЗначениеРеквизита));
КонецПроцедуры

&НаКлиенте
Процедура ВывестиРеквизитыТабличнойЧастиВMarkdown(Строки, ТабличнаяЧасть, ТолькоЗаполненные = Ложь)
	
	Строки.Добавить(Ванесса.Локализовать("## Табличная часть: ") + ТабличнаяЧасть.Имя);
	Строки.Добавить("");
	Строки.Добавить(Ванесса.Локализовать("Количество строк: ") + Формат(ТабличнаяЧасть.ЗначениеТаблицы.Количество(), "ЧГ=0; ЧН=0"));
	Строки.Добавить("");
	
	Если ТабличнаяЧасть.ЗначениеТаблицы.Количество() > 0 Тогда
		// Получаем колонки
		
		Строки.Добавить(Ванесса.Локализовать("### Данные"));
		Строки.Добавить("");
		Для Сч = 0 По ТабличнаяЧасть.ЗначениеТаблицы.Количество() - 1 Цикл
			СтрокаТЧ = ТабличнаяЧасть.ЗначениеТаблицы[Сч];
			
			// Если установлен флаг ТолькоЗаполненные, проверяем есть ли в строке заполненные значения
			Если ТолькоЗаполненные Тогда
				ЕстьЗаполненныеЗначения = Ложь;
				Для Каждого ТекРеквизит Из СтрокаТЧ Цикл
					Если ЗначениеЗаполнено(ТекРеквизит.Значение) Тогда
						ЕстьЗаполненныеЗначения = Истина;
						Прервать;
					КонецЕсли;
				КонецЦикла;
				
				Если НЕ ЕстьЗаполненныеЗначения Тогда
					Продолжить;
				КонецЕсли;
			КонецЕсли;
			
			Строки.Добавить(Ванесса.Локализовать("#### Строка ") + Формат(Сч + 1, "ЧГ=0; ЧН=0"));
			Строки.Добавить("");
			Для Каждого ТекРеквизит Из СтрокаТЧ Цикл
				ЗначениеКолонки = ТекРеквизит.Значение;
				
				// Если установлен флаг ТолькоЗаполненные и значение пустое - пропускаем колонку
				Если ТолькоЗаполненные И НЕ ЗначениеЗаполнено(ЗначениеКолонки) Тогда
					Продолжить;
				КонецЕсли;
				
				Строки.Добавить(Ванесса.Локализовать("- ") + ТекРеквизит.Имя + ": " + MCPПредставлениеЗначенияДляMarkdown(ЗначениеКолонки) + " [" + ТекРеквизит.Тип + "]");
			КонецЦикла;
			Строки.Добавить("");
		КонецЦикла;
	Иначе
		Строки.Добавить(Ванесса.Локализовать("Табличная часть пуста."));
	КонецЕсли;
	
КонецПроцедуры

// Возвращает данные из таблицы базы данных (справочники, документы, перечисления)
&НаКлиенте
Функция ПолучитьДанныеИзТаблицыБД(Запрос, ДополнительныеПараметры) Экспорт
	
	// Получаем параметр object_type (обязательный, числовой)
	// 1 = Справочник, 2 = Документ, 3 = Перечисление
	Попытка
		ТипОбъекта = Число(ЗначениеПараметраИзЗапроса(Запрос, "object_type"));
	Исключение
		ТекстСообщения = Ванесса.Локализовать("Параметр object_type должен быть числом. Допустимые значения: 1 = Справочник, 2 = Документ, 3 = Перечисление.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецПопытки;
	
	// Проверка допустимого значения
	Если ТипОбъекта <> 1 И ТипОбъекта <> 2 И ТипОбъекта <> 3 Тогда
		ТекстСообщения = Ванесса.Локализовать("Недопустимое значение object_type. Допустимые значения: 1 = Справочник, 2 = Документ, 3 = Перечисление.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	// Получаем параметр object_name
	ИмяОбъекта = Строка(ЗначениеПараметраИзЗапроса(Запрос, "object_name"));
	Если НЕ ЗначениеЗаполнено(ИмяОбъекта) Тогда
		ТекстСообщения = Ванесса.Локализовать("Необходимо указать параметр object_name.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	// Получаем параметр limit (по умолчанию 10)
	Попытка
		Лимит = Число(ЗначениеПараметраИзЗапроса(Запрос, "limit"));
	Исключение
		Лимит = 0;
	КонецПопытки;
	
	Если Лимит = Неопределено ИЛИ Лимит <= 0 Тогда
		Лимит = 10;
	КонецЕсли;
	
	// Получаем параметр owner (для подчиненных справочников)
	Владелец = Строка(ЗначениеПараметраИзЗапроса(Запрос, "owner"));
	
	// Получаем параметры даты для документов
	ДатаНачала = ЗначениеПараметраИзЗапроса(Запрос, "date_start");
	ДатаОкончания = ЗначениеПараметраИзЗапроса(Запрос, "date_end");
	
	Если ЗначениеЗаполнено(ДатаНачала) Тогда
		Попытка
			ДатаНачала = Ванесса.ДатаИзСтрокиКомандыСистемы(ДатаНачала);
		Исключение
			ТекстОшибки = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Не получилось преобразовать строку <%1> в дату начала."), ДатаНачала) + Символы.ПС  + ТекстОшибки);
		КонецПопытки;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДатаОкончания) Тогда
		Попытка
			ДатаОкончания = Ванесса.ДатаИзСтрокиКомандыСистемы(ДатаОкончания);
		Исключение
			ТекстОшибки = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Не получилось преобразовать строку <%1> в дату окончания."), ДатаОкончания) + Символы.ПС  + ТекстОшибки);
		КонецПопытки;
	КонецЕсли;
	
	// Проверяем подключение клиента тестирования
	Попытка
		АктивноеОкно = Ванесса.ПолучитьАктивноеОкноИзТестовоеПриложение();
	Исключение
		ТекстОшибки = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.Локализовать("Клиент тестирования не подключен. Сначала вызовите connect_test_client.") + " " + ТекстОшибки);
	КонецПопытки;
	
	// Формируем результат в зависимости от типа объекта
	Если ТипОбъекта = 3 Тогда
		// Перечисление
		Возврат ПолучитьДанныеПеречисления(ИмяОбъекта);
	ИначеЕсли ТипОбъекта = 1 Тогда
		// Справочник
		Возврат ПолучитьДанныеСправочника(ИмяОбъекта, Владелец, Лимит);
	ИначеЕсли ТипОбъекта = 2 Тогда
		// Документ
		Возврат ПолучитьДанныеДокумента(ИмяОбъекта, ДатаНачала, ДатаОкончания, Лимит);
	КонецЕсли;
	
КонецФункции

// Возвращает данные перечисления
&НаКлиенте
Функция ПолучитьДанныеПеречисления(ИмяПеречисления)
	
	Если НЕ ЗначениеЗаполнено(ИмяПеречисления) Тогда
		ТекстСообщения = Ванесса.Локализовать("Для типа объекта 'Перечисление' необходимо указать параметр object_name.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("Тип", "Перечисление");
	ДопПараметры.Вставить("Вид", ИмяПеречисления);
	
	ТекстОшибки = Неопределено;
	Данные = ДанныеИзБазыДанныхКлиентаТестирования(ДопПараметры, ТекстОшибки);
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецЕсли;
	
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Перечисление:") + " " + ИмяПеречисления);
	Строки.Добавить("");
	
	Счетчик = 0;
	Для Каждого ТекДанные Из Данные Цикл
		Счетчик = Счетчик + 1;
		
		Строки.Добавить(Ванесса.Локализовать("## Значение") + " " + Формат(Счетчик, "ЧГ=0; ЧН=0"));
		Строки.Добавить("");
		Строки.Добавить(Ванесса.Локализовать("- Имя:") + " " + ТекДанные.Имя);
		Если ЗначениеЗаполнено(ТекДанные.Представление) Тогда
			Строки.Добавить(Ванесса.Локализовать("- Представление для пользоватля:") + " " + ТекДанные.Представление);
		Иначе	
			Строки.Добавить(Ванесса.Локализовать("- Представление для пользоватля:") + " " + ТекДанные.Имя);
		КонецЕсли;
		Строки.Добавить("");
	КонецЦикла;
	
	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Возвращает данные справочника
&НаКлиенте
Функция ПолучитьДанныеСправочника(ИмяСправочника, Владелец, Лимит)
	
	Если НЕ ЗначениеЗаполнено(ИмяСправочника) Тогда
		ТекстСообщения = Ванесса.Локализовать("Для типа объекта 'Справочник' необходимо указать параметр object_name.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("Тип", "Справочник");
	ДопПараметры.Вставить("Вид", ИмяСправочника);
	ДопПараметры.Вставить("Владелец", Владелец);
	ДопПараметры.Вставить("Лимит", Лимит);
	
	ТекстОшибки = Неопределено;
	Данные = ДанныеИзБазыДанныхКлиентаТестирования(ДопПараметры, ТекстОшибки);
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецЕсли;
	
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Справочник:") + " " + ИмяСправочника);
	Строки.Добавить("");

	Счетчик = 0;
	Для Каждого ТекСтрока Из Данные Цикл
		Счетчик = Счетчик + 1;
		
		Строки.Добавить(Ванесса.Локализовать("## Элемент") + " " + Формат(Счетчик, "ЧГ=0; ЧН=0"));
		Строки.Добавить("");
		Строки.Добавить(Ванесса.Локализовать("- Навигационная ссылка:") + " " + Строка(ТекСтрока.НавигационнаяСсылка));
		Строки.Добавить(Ванесса.Локализовать("- Наименование:") + " " + ТекСтрока.Наименование);
		Строки.Добавить(Ванесса.Локализовать("- Пометка удаления:") + " " + ТекСтрока.ПометкаУдаления);
		Если ТекСтрока.Свойство("Код") Тогда
			Строки.Добавить(Ванесса.Локализовать("- Код:") + " " + ТекСтрока.Код);
		КонецЕсли;
		Если ТекСтрока.Свойство("Владелец") Тогда
			Строки.Добавить(Ванесса.Локализовать("- Владелец:") + " " + Строка(ТекСтрока.Владелец));
		КонецЕсли;
		Строки.Добавить("");
	КонецЦикла;
	
	Если Счетчик = 0 Тогда
		Строки.Добавить(Ванесса.Локализовать("Справочник пуст."));
	КонецЕсли;
	
	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Возвращает данные документа
&НаКлиенте
Функция ПолучитьДанныеДокумента(ИмяДокумента, ДатаНачала, ДатаОкончания, Лимит)
	
	Если НЕ ЗначениеЗаполнено(ИмяДокумента) Тогда
		ТекстСообщения = Ванесса.Локализовать("Для типа объекта 'Документ' необходимо указать параметр object_name.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Документ: ") + ИмяДокумента);
	Строки.Добавить("");
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("Тип", "Документ");
	ДопПараметры.Вставить("Вид", ИмяДокумента);
	ДопПараметры.Вставить("Лимит", Лимит);
	ДопПараметры.Вставить("ДатаНачала", ДатаНачала);
	ДопПараметры.Вставить("ДатаОкончания", ДатаОкончания);
	
	ТекстОшибки = Неопределено;
	Данные = ДанныеИзБазыДанныхКлиентаТестирования(ДопПараметры, ТекстОшибки);
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецЕсли;
	
	Счетчик = 0;
	Для Каждого ТекСтрока Из Данные Цикл
		Счетчик = Счетчик + 1;
		
		Строки.Добавить(Ванесса.Локализовать("## Документ") + " " + Формат(Счетчик, "ЧГ=0; ЧН=0"));
		Строки.Добавить("");
		Строки.Добавить(Ванесса.Локализовать("- Ссылка:") + " " + Строка(ТекСтрока.Ссылка));
		Строки.Добавить(Ванесса.Локализовать("- Дата:") + " " + ТекСтрока.Дата);
		Если ТекСтрока.Свойство("Номер") Тогда
			Строки.Добавить(Ванесса.Локализовать("- Номер:") + " " + ТекСтрока.Номер);
		КонецЕсли;
		Строки.Добавить(Ванесса.Локализовать("- Пометка удаления:") + " " + ТекСтрока.ПометкаУдаления);
		Если ТекСтрока.Свойство("Проведен") Тогда
			Строки.Добавить(Ванесса.Локализовать("- Проведен:") + " " + ТекСтрока.Проведен);
		КонецЕсли;
		Строки.Добавить("");
	КонецЦикла;
	
	Если Счетчик = 0 Тогда
		Строки.Добавить(Ванесса.Локализовать("Документы не найдены."));
	КонецЕсли;
	
	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

&НаКлиенте
Функция ДанныеИзБазыДанныхКлиентаТестирования(ДопПараметры, ТекстОшибки)
	Ванесса.ОткрытьНавигационнуюСсылку("e1cib/app/Обработка.VAExtension_ПолучениеДанныхИзБазы");
	ТестовоеПриложение = Ванесса.ПолучитьТестовоеПриложение();
	НужнаяФорма = ТестовоеПриложение.НайтиОбъект(Тип("ТестируемаяФорма"),, "*.VAExtension_ПолучениеДанныхИзБазы.*",5);
	Если НужнаяФорма = Неопределено Тогда
		ТекстОшибки = Ванесса.Локализовать("Клиент тестирования подключен, но не найдена форма 'VAExtension_ПолучениеДанныхИзБазы' из служебного расширения.");
		Возврат Неопределено
	КонецЕсли;	
	
	РеквизитВыражениеВычислено = Ванесса.НайтиРеквизитОткрытойФормыПоЗаголовку("ОбработкаВыполнена", Истина);
	РеквизитТип = Ванесса.НайтиРеквизитОткрытойФормыПоЗаголовку("Тип", Истина);
	РеквизитВид = Ванесса.НайтиРеквизитОткрытойФормыПоЗаголовку("Вид", Истина);
	РеквизитТип.ВвестиТекст(ДопПараметры.Тип);
	РеквизитВид.ВвестиТекст(ДопПараметры.Вид);
	
	Если ДопПараметры.Свойство("Владелец") Тогда
		РеквизитИмяВладельца = Ванесса.НайтиРеквизитОткрытойФормыПоЗаголовку("ИмяВладельца", Истина);
		РеквизитИмяВладельца.ВвестиТекст(ДопПараметры.Владелец);
	КонецЕсли;
	
	Если ДопПараметры.Свойство("Лимит") Тогда
		РеквизитКоличествоСсылок = Ванесса.НайтиРеквизитОткрытойФормыПоЗаголовку("КоличествоСсылок", Истина);
		РеквизитКоличествоСсылок.ВвестиТекст(XMLСтрока(ДопПараметры.Лимит));
	КонецЕсли;
	
	ДанныеДат = Новый Структура;
	ПереданыДаты = Ложь;
	Если ДопПараметры.Свойство("ДатаНачала") И ЗначениеЗаполнено(ДопПараметры.ДатаНачала) Тогда
		ПереданыДаты = Истина;
		ДанныеДат.Вставить("ДатаНачала", ДопПараметры.ДатаНачала);
	КонецЕсли;
	
	Если ДопПараметры.Свойство("ДатаОкончания") И ЗначениеЗаполнено(ДопПараметры.ДатаОкончания) Тогда
		ПереданыДаты = Истина;
		ДанныеДат.Вставить("ДатаОкончания", ДопПараметры.ДатаОкончания);
	КонецЕсли;
	
	АктивноеОкно = Ванесса.ПолучитьАктивноеОкноИзТестовоеПриложение();
	Если ПереданыДаты Тогда
		РеквизитДляУстановкиПараметров = Ванесса.НайтиРеквизитОткрытойФормыПоЗаголовку("ДляУстановкиПараметров", Истина);
		РеквизитДляУстановкиПараметров.ВвестиТекст(Ванесса.ЗаписатьОбъектJSON(ДанныеДат));
		КнопкаПолучитьПараметры = АктивноеОкно.НайтиОбъект(Тип("ТестируемаяКнопкаФормы"),,"ФормаПолучитьПараметры");
		КнопкаПолучитьПараметры.Нажать();
	КонецЕсли;
	
	КнопкаВыполнитьОбработку = АктивноеОкно.НайтиОбъект(Тип("ТестируемаяКнопкаФормы"),,"ФормаВыполнитьОбработку");
	
	КнопкаЗакрытьФорму = АктивноеОкно.НайтиОбъект(Тип("ТестируемаяКнопкаФормы"),,"ЗакрытьФорму");
	
	КнопкаВыполнитьОбработку.Нажать();
	
	БылаОшибка = Истина;
	Ванесса.ОжиданиеОкончанияОбработки(БылаОшибка, РеквизитВыражениеВычислено);
	
	Если БылаОшибка Тогда
		ТекстОшибки = Ванесса.Локализовать("Не вышло получить данные из базы данных клиента тестирования.");
		Возврат Неопределено
	КонецЕсли;
	
	РеквизитЗначениеДляВозврата = Ванесса.НайтиРеквизитОткрытойФормыПоЗаголовку("ЗначениеРезультат", Истина);
	ПредставлениеРезультата = Ванесса.ПолучитьПредставлениеДанныхЭлементаФормы(РеквизитЗначениеДляВозврата);
	
	Данные = Ванесса.ПрочитатьОбъектJSON(ПредставлениеРезультата);
	
	Попытка
		КнопкаЗакрытьФорму.Нажать();
	Исключение
		Ванесса.ЗаписатьЛогВЖРИнформация("ДанныеИзБазыДанныхКлиентаТестирования", ОписаниеОшибки());
	КонецПопытки;
	
	Возврат Данные;
	
КонецФункции	

#КонецОбласти
