Функция ПоискПоВопросам(СтрокаПоиска)
	Если НЕ ЗначениеЗаполнено(СтрокаПоиска) Тогда
		ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Не корректно указан параметр 'search_string'."));
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	Массив_СтрокаПоиска = MCPПодготовитьВариантыТочногоПоиска(СтрокаПоиска);
	
	Вопросы = ПолучитьМассивВопросов();
	
	Результат = Новый Массив;
	Результат.Добавить(Ванесса.Локализовать("## Результат поиска по вопросам"));
	Результат.Добавить("");
	
	Для Каждого ТекВопрос Из Вопросы Цикл
		
		Если НайденоВхождениеЗначенияВМассиве(Массив_СтрокаПоиска, НРег(ТекВопрос.Текст)) Тогда
			Результат.Добавить("Вопрос №" + xmlСтрока(ТекВопрос.Номер));
			Результат.Добавить(ТекВопрос.Текст);
			Результат.Добавить("");
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ванесса._СтрСоединить(Результат);
	
КонецФункции

