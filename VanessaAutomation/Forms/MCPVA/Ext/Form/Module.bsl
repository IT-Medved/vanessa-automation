&НаКлиенте
Процедура ЗавершитьОткрытьЗагрузитьИлиПерезагрузитьФичаФайл(ПутьКФайлу, ДопПараметрыВызоваMCP)
	
	Путь = ДопПараметрыВызоваMCP.ИсходныйПутьКФайлу;
	
	Если ЗначениеЗаполнено(Путь) Тогда
		ПутьОтвета = Путь;
	Иначе
		ПутьОтвета = Объект.КаталогФич + " " + Ванесса.Локализовать("(текущий)");
	КонецЕсли;
	ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
		"# Загрузка фич
		|
		|- Загружено: да
		|- Путь: %1
		|
		|## Следующие шаги
		|- Подключите клиента тестирования: `connect_test_client`
		|- Найдите нужные шаги: `search_for_steps_by_keywords`
		|- Запустите сценарий: `run_scenario`"),
		ПутьОтвета,
		Формат(Ванесса.ТаблицаИзвестныхStepDefinition.Количество(), "ЧГ=0; ЧН=0"));
		
	МодульМсп_Сервер().ЗавершитьВызовИнструментаУспешно(Ванесса.ПолучитьИдентификаторЗадачиMCP(), ТекстОтвета);
	Ванесса.УстановитьИдентификаторЗадачиMCP(Неопределено);
	
КонецПроцедуры

&НаКлиенте
Процедура ПродолжитьВыполнениеШагаВРедакторе(ПутьКФайлу, ДопПараметрыВызоваMCP)
	
	// Проверяем что файл действительно открыт
	ТекущийФайл = MCPТекущийФайлРедактора();
	Если НРег(ТекущийФайл) <> НРег(ПутьКФайлу) Тогда
		ТекстСообщения = Ванесса.Локализовать("Не удалось активировать вкладку файла:") + " " + ПутьКФайлу;
		МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ЭкземплярVanessaEditor = Ванесса.ПолучитьVanessaEditor();
	ПолныйТекст = ЭкземплярVanessaEditor.getContent();
	
	НомерСтроки = ДопПараметрыВызоваMCP.НомерСтроки;
	КоличествоСтрок = Ванесса._СтрРазделить(ПолныйТекст, Символы.ПС).Количество();
	Если НомерСтроки > КоличествоСтрок Тогда
		ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Строка %1 выходит за пределы файла (%2 строк): %3"),
				НомерСтроки, КоличествоСтрок, ПутьКФайлу);
		МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	
	СтрокаДерева = Ванесса.СтрокаДереваПоНомеруСтрокиФичи(НомерСтроки);
	Если СтрокаДерева = Неопределено Тогда
		ТекстСтроки = ЭкземплярVanessaEditor.getLineContent(НомерСтроки);
		ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("По строке %1 не получилось найти исполнимую строку фича файла.
		|Текст в строке: %2
		|Имя файла: %3"),
				НомерСтроки, ТекстСтроки, ПутьКФайлу);
		МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
		Возврат;
	КонецЕсли;	
	Ванесса.МодульРедакторТекста().АктивизироватьСтрокуРедактораПоИдСтрокиИНомеруСтрокиФичи(СтрокаДерева.ИдСтроки, НомерСтроки);
	
	// Запускаем обработчик ожидания, чтобы редактор смог обновиться и перейти к нужной строке
	глДопПараметрыВызоваMCP = ДопПараметрыВызоваMCP;
	ПодключитьОбработчикОжидания("ПослеСделатьПереходкКТекстуВРедакторе", 0.1, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ПродолжитьВыполнитьСценарий1(ПутьКФайлу, ДопПараметрыВызоваMCP)
	
	// Обеспечить наличие активной вкладки .feature в VanessaEditor
	// (без неё КомандаВыполнитьСценарии/ВыполнитьВыделенныйСценарий молча завершаются)
	Если Ванесса.Объект.ИспользоватьРедакторVanessaEditor Тогда
		МСПНадоОткрытьФайл = Ложь;
		Если Ванесса.VanessaTabs = Неопределено ИЛИ Ванесса.VanessaTabs.current = Неопределено Тогда
			МСПНадоОткрытьФайл = Истина;
		ИначеЕсли НЕ Ванесса.ЭтоВкладкаEdit(Ванесса.VanessaTabs.current) Тогда
			МСПНадоОткрытьФайл = Истина;
		ИначеЕсли (НРег(Ванесса.Объект.КаталогФич) <> НРег(ПутьКФайлу)) И ЗначениеЗаполнено(ПутьКФайлу) Тогда
			МСПНадоОткрытьФайл = Истина;
		КонецЕсли;
		
		Если МСПНадоОткрытьФайл Тогда
			Ванесса.Объект.КаталогФич = ПутьКФайлу;
			ФайлВРедакторе = Ванесса.Объект.КаталогФич;
			Если ЗначениеЗаполнено(ФайлВРедакторе) И Прав(НРег(СокрЛП(ФайлВРедакторе)), 8) = ".feature" Тогда
				Попытка
					MCPOpenFeatureFileВРедакторе(ФайлВРедакторе, "ЗагрузитьФичуДляВыполненияСценария")
				Исключение
					ТекстСообщения = Ванесса.Локализовать("Не удалось открыть файл в редакторе:") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
					МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
					Возврат;
				КонецПопытки;
			Иначе
				ТекстСообщения = Ванесса.Локализовать("Нет активного .feature файла в редакторе. Используйте параметр filePath, или сначала загрузите фичу через load_features(path='путь/к/файлу.feature') и openFeatureFile.");
				МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ПродолжитьВыполнитьСценарий2(ПутьКФайлу, ДопПараметрыВызоваMCP);
	
КонецПроцедуры

