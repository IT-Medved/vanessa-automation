// Универсальный инструмент для работы с таблицей профилей клиентов тестирования
// Получает важные данные об окружении
&НаКлиенте
Функция ПолучитьДанныеОбОкружении(Запрос, ДополнительныеПараметры) Экспорт
	
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Данные об окружении"));
	Строки.Добавить("");
	
	// Текущая дата и время
	Строки.Добавить(Ванесса.Локализовать("- Текущая дата и время:") + " " + Формат(ТекущаяДата(), "ДЛФ:DD"));
	Строки.Добавить("");
	
	СистемнаяИнформация = Новый СистемнаяИнформация;
	
	// Версия платформы
	Попытка
		Строки.Добавить(Ванесса.Локализовать("## Информация о платформе"));
		Строки.Добавить(Ванесса.Локализовать("- Платформа:") + " " + СистемнаяИнформация.ВерсияПриложения);
	Исключение
		Строки.Добавить(Ванесса.Локализовать("! Не удалось получить информацию об информационной базе: ") + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки()));
	КонецПопытки;
	
	// Данные об операционной системе
	Строки.Добавить("");
	Строки.Добавить(Ванесса.Локализовать("## Операционная система"));
	Строки.Добавить(Ванесса.Локализовать("- Данные ОС:") + " " + СистемнаяИнформация.ТипПлатформы);
	
	// Данные о VA (обычная или Single)
	Строки.Добавить("");
	Строки.Добавить(Ванесса.Локализовать("## Vanessa Automation"));
	Если Объект.ВерсияПоставки = "single" Тогда
		Строки.Добавить("- Это Vanessa Automation Single");
	Иначе	
		Строки.Добавить("- Это обычная Vanessa Automation");
	КонецЕсли;
	Строки.Добавить(Ванесса.Локализовать("- Версия:") + " " + Ванесса.ВерсияVanessaAutomation());
	
	// Информация о внешней компоненте
	Строки.Добавить("");
	Строки.Добавить(Ванесса.Локализовать("## Внешняя компонента VanessaExt"));
	Строки.Добавить(Ванесса.Локализовать("- Включено использование внешней компоненты VanessaExt:") + " " + Ванесса.Объект.ИспользоватьКомпонентуVanessaExt);
	
	// Информация о базе менеджера тестирования
	Строки.Добавить("");
	Строки.Добавить(Ванесса.Локализовать("## Менеджер тестирования"));
	Строки.Добавить(Ванесса.Локализовать("- Строка соединения с информационной базой:") + " " + СтрокаСоединенияИнформационнойБазы());
	
	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Возвращает информацию о доступных типах голосовых уведомлений
&НаКлиенте
Функция ГолосовыеУведомления(Запрос, ДополнительныеПараметры) Экспорт
	
	ТипУведомления = Строка(ЗначениеПараметраИзЗапроса(Запрос, "notification_type"));
	
	Если НЕ ЗначениеЗаполнено(ТипУведомления) Тогда
		ТекстСообщения = Ванесса.Локализовать("Параметр notification_type обязателен. Допустимые значения: 'task_completed', 'decision_required', 'task_cannot_be_completed', 'error_occurred'.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	// Получаем параметр языка озвучки (по умолчанию 'ru')
	Язык = Строка(ЗначениеПараметраИзЗапроса(Запрос, "language"));
	Если НЕ ЗначениеЗаполнено(Язык) Тогда
		Язык = "ru";
	Иначе
		Язык = НРег(СокрЛП(Язык));
		Если Язык <> "ru" И Язык <> "en" Тогда
			ТекстСообщения = Ванесса.Локализовать("Некорректное значение параметра language. Допустимые значения: 'ru' (русский), 'en' (английский).");
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
		КонецЕсли;
	КонецЕсли;
	
	// Проверяем допустимое значение
	ДопустимыеТипы = Новый Массив;
	ДопустимыеТипы.Добавить("task_completed");
	ДопустимыеТипы.Добавить("decision_required");
	ДопустимыеТипы.Добавить("task_cannot_be_completed");
	ДопустимыеТипы.Добавить("error_occurred");
	
	Если ДопустимыеТипы.Найти(ТипУведомления) = Неопределено Тогда
		ТекстСообщения = Ванесса.Локализовать("Недопустимое значение notification_type. Допустимые значения: 'task_completed', 'decision_required', 'task_cannot_be_completed', 'error_occurred'.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	Если Ванесса.ЭтоLinux Тогда
		ТекстСообщения = Ванесса.Локализовать("Голосовое уведомление не работает под linux.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстСообщения);
	КонецЕсли;
	
	Если НЕ Ванесса.Объект.ИспользоватьКомпонентуVanessaExt Тогда
		ТекстСообщения = Ванесса.Локализовать("Чтобы была возможность выполнить голосовое уведомление нужно в Vanessa Automation включить использование внешней компоненты VanessaExt.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстСообщения);
	КонецЕсли;	
	
	Если КаталогСФайламиОзвучки = Неопределено Тогда
		ДвоичныеДанныеГолос = ДвоичныеДанныеГолосСервер();	
		ЧтениеZipФайла = Новый ЧтениеZipФайла(ДвоичныеДанныеГолос.ОткрытьПотокДляЧтения());
		ВременныйКаталог = ПолучитьИмяВременногоФайла("");
		Ванесса.СоздатьКаталогКомандаСистемы(ВременныйКаталог);
		ЧтениеZipФайла.ИзвлечьВсе(ВременныйКаталог);
		КаталогСФайламиОзвучки = ВременныйКаталог;
	КонецЕсли;	 
	
	ИмяФайла = ТипУведомления + "_" + Язык + ".mp3";
	ПолноеИмяФайла = КаталогСФайламиОзвучки + "\" + ИмяФайла;
	Ванесса.ВнешняяКомпонентаДляСкриншотов.НачатьВызовВоспроизвестиМедиа(Ванесса.ОписаниеПустогоОбработчика(3), ПолноеИмяФайла, ПолноеИмяФайла);
	
	// Формируем ответ в формате Markdown
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Голосовое уведомление выполнено"));
	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

