&НаКлиенте
Функция ПоискПоВопросам(СтрокаПоиска)
	Если НЕ ЗначениеЗаполнено(СтрокаПоиска) Тогда
		ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Не корректно указан параметр 'search_string'."));
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	Массив_СтрокаПоиска = MCPПодготовитьВариантыТочногоПоиска(СтрокаПоиска);
	
	Вопросы = ПолучитьМассивВопросов();
	
	Результат = Новый Массив;
	Результат.Добавить(Ванесса.Локализовать("## Результат поиска по вопросам"));
	Результат.Добавить("");
	
	Для Каждого ТекВопрос Из Вопросы Цикл
		
		Если НайденоВхождениеЗначенияВМассиве(Массив_СтрокаПоиска, НРег(ТекВопрос.Текст)) Тогда
			Результат.Добавить("Вопрос №" + xmlСтрока(ТекВопрос.Номер));
			Результат.Добавить(ТекВопрос.Текст);
			Результат.Добавить("");
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ванесса._СтрСоединить(Результат);
	
КонецФункции

&НаКлиенте
Функция ПоискПоОтветам(СтрокаПоиска)
	Если НЕ ЗначениеЗаполнено(СтрокаПоиска) Тогда
		ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Не корректно указан параметр 'search_string'."));
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	Массив_СтрокаПоиска = MCPПодготовитьВариантыТочногоПоиска(СтрокаПоиска);
	
	Вопросы = ПолучитьМассивВопросов();
	
	Результат = Новый Массив;
	Результат.Добавить(Ванесса.Локализовать("## Результат поиска по ответам"));
	Результат.Добавить("");
	
	НайденныеВопросы = Новый Массив;
	
	Для Каждого ТекВопрос Из Вопросы Цикл
		
		Для Каждого СтрокаОтвета Из ТекВопрос.Ответ Цикл
			Если НайденоВхождениеЗначенияВМассиве(Массив_СтрокаПоиска, НРег(СтрокаОтвета)) Тогда
				НайденныеВопросы.Добавить(ТекВопрос);
				Прервать;
			КонецЕсли;
		КонецЦикла;	
		
	КонецЦикла;
	
	Для Каждого ТекВопрос Из НайденныеВопросы Цикл
		Результат.Добавить("Вопрос №" + xmlСтрока(ТекВопрос.Номер));
		Результат.Добавить(ТекВопрос.ТекстВопросаБезОбработки);
		Для Каждого Стр Из ТекВопрос.Ответ Цикл
			Результат.Добавить(Стр);
		КонецЦикла;	
		Результат.Добавить("");
		Результат.Добавить("");
		Результат.Добавить("");
	КонецЦикла;	
	
	Возврат Ванесса._СтрСоединить(Результат);
	
КонецФункции

