&НаКлиенте
Функция MCPСформироватьMarkdownРезультатаПоискаШагов(Данные)
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Найденные шаги Vanessa Automation"));
	Строки.Добавить("");
	Строки.Добавить(Ванесса.Локализовать("- Поисковый запрос по представлению шагов:") + " " + MCPПредставлениеЗначенияДляMarkdown(Данные["search_name"]));
	Строки.Добавить(Ванесса.Локализовать("- Поисковый запрос по исключению в представлении шагов:") + " " + MCPПредставлениеЗначенияДляMarkdown(Данные["exclude_name"]));
	Строки.Добавить(Ванесса.Локализовать("- Поисковый запрос по описанию шагов:") + " " + MCPПредставлениеЗначенияДляMarkdown(Данные["search_description"]));
	Строки.Добавить(Ванесса.Локализовать("- Поисковый запрос по исключению в описании шагов:") + " " + MCPПредставлениеЗначенияДляMarkdown(Данные["exclude_description"]));
	Строки.Добавить(Ванесса.Локализовать("- Поисковый запрос по типу шагов:") + " " + MCPПредставлениеЗначенияДляMarkdown(Данные["search_type"]));
	Строки.Добавить(Ванесса.Локализовать("- Поисковый запрос по исключению в типе шагов:") + " " + MCPПредставлениеЗначенияДляMarkdown(Данные["exclude_type"]));
	Строки.Добавить(Ванесса.Локализовать("- Лимит:") + " " + MCPПредставлениеЛимитаДляMarkdown(Данные["limit"]));
	Строки.Добавить(Ванесса.Локализовать("- Всего найдено:") + " " + MCPПредставлениеЗначенияДляMarkdown(Данные["totalFound"]));
	Строки.Добавить(Ванесса.Локализовать("- Показано:") + " " + Строка(Данные["steps"].Количество()));
	Строки.Добавить(Ванесса.Локализовать("- Категории:") + " " + MCPПредставлениеЗначенияДляMarkdown(Данные["categories"]));
	Строки.Добавить(Ванесса.Локализовать("- Примечание: поиск выполняется по полному точному совпадению без учета регистра. Для поиска альтернатив используйте разделитель '|', например 'первая часть|вторая часть'. Семантическая обработка не используется."));
	Строки.Добавить("");

	Если Данные["steps"].Количество() = 0 Тогда
		Строки.Добавить(Ванесса.Локализовать("Совпадения не найдены."));
		Строки.Добавить("");
		Строки.Добавить(Ванесса.Локализовать("Поиск выполнен с указанными выше параметрами."));
		Строки.Добавить(Ванесса.Локализовать("Если ожидался другой результат, проверьте поисковый запрос, категорию и область поиска."));
		Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
	КонецЕсли;

	НомерШага = 0;
	Для Каждого Шаг Из Данные["steps"] Цикл
		НомерШага = НомерШага + 1;
		Строки.Добавить(Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("## %1. %2"), Строка(НомерШага), MCPПредставлениеЗначенияДляMarkdown(Шаг["name"]))); 
		Строки.Добавить("");
		Строки.Добавить(Ванесса.Локализовать("- Категория:") + " " + MCPПредставлениеЗначенияДляMarkdown(Шаг["category"]));
		Строки.Добавить(Ванесса.Локализовать("- Описание:") + " " + MCPПредставлениеЗначенияДляMarkdown(Шаг["description"]));
		Строки.Добавить(Ванесса.Локализовать("- Сниппет: `") + MCPПредставлениеЗначенияДляMarkdown(Шаг["snippet"]) + "`");
		Строки.Добавить(Ванесса.Локализовать("- Тип: `") + MCPПредставлениеЗначенияДляMarkdown(Шаг["type"]) + "`");
		//Строки.Добавить(Ванесса.Локализовать("- Строка поиска:") + " " + MCPПредставлениеЗначенияДляMarkdown(Шаг["searchString"]));
		//Строки.Добавить(Ванесса.Локализовать("- Исходный файл:") + " " + MCPПредставлениеЗначенияДляMarkdown(Шаг["sourceFile"]));
		Строки.Добавить("");
