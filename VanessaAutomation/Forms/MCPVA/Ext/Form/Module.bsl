// Активизирует окно клиента тестирования по заголовку
&НаКлиенте
Функция АктивизироватьОкноКлиентаТестирования(Запрос, ДополнительныеПараметры) Экспорт
	
	// Реальная проверка подключения клиента тестирования
	Попытка
		АктивноеОкно = Ванесса.ПолучитьАктивноеОкноИзТестовоеПриложение();
	Исключение
		ТекстОшибки = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	
	Попытка
		ТестовоеПриложение = Ванесса.ПолучитьТестовоеПриложение();
	Исключение
		ТекстОшибки = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	
	ЗаголовокОкна = Строка(ЗначениеПараметраИзЗапроса(Запрос, "window_title"));
	Если НЕ ЗначениеЗаполнено(ЗаголовокОкна) Тогда
		ТекстОшибки = Ванесса.Локализовать("Не указан обязательный параметр window_title");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстОшибки);
	КонецЕсли;	
	
	НужноеОкно = ТестовоеПриложение.НайтиОбъект(Тип("ТестируемоеОкноКлиентскогоПриложения"), ЗаголовокОкна);
	
	Если НужноеОкно = Неопределено Тогда
		ТекстОшибки = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Окно с заголовоком <%1> не найдено."), ЗаголовокОкна);
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецЕсли;	
	
	Попытка
		НужноеОкно.Активизировать();
	Исключение
		ТекстОшибки = Ванесса.Локализовать("Не получилось активизировать указанное окно. Возмжоно оно заблокировано модальным окном или другим окном.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	
	Возврат Ванесса.Локализовать("Окно было успешно активизировано.");
	
КонецФункции

// Добавляет, читает и удаляет переменные контекста и глобального контекста
&НаКлиенте
Функция УправлениеПеременными(Запрос, ДополнительныеПараметры) Экспорт
	
	Действие = Строка(ЗначениеПараметраИзЗапроса(Запрос, "action"));
	Если НЕ ЗначениеЗаполнено(Действие) Тогда
		Действие = "get";
	КонецЕсли;
	
	ИмяПеременной = Строка(ЗначениеПараметраИзЗапроса(Запрос, "name"));
	ЗначениеПеременнойПараметр = Строка(ЗначениеПараметраИзЗапроса(Запрос, "value"));
	ПеременнаяГлобальная = Строка(ЗначениеПараметраИзЗапроса(Запрос, "is_global"));
	Если ЗначениеЗаполнено(ПеременнаяГлобальная) Тогда
		ПеременнаяГлобальная = Булево(ПеременнаяГлобальная);
	Иначе
		ПеременнаяГлобальная = Ложь;
	КонецЕсли;	
	
	ОбъектКонтекст = Ванесса.ОбъектКонтекст;
	ОбъектКонтекстСохраняемый = Ванесса.ОбъектКонтекстСохраняемый;
	
	Если Действие = "get" Тогда
		// Если имя указано — одна переменная, иначе — все
		Если ЗначениеЗаполнено(ИмяПеременной) Тогда
			Значение = Ванесса.ЗначениеПеременной(ИмяПеременной);
			
			Если ПеременнаяГлобальная Тогда
				Значение = ЗначениеИзСтруктуры(ОбъектКонтекстСохраняемый, ИмяПеременной);
			Иначе	
				Значение = ЗначениеИзСтруктуры(ОбъектКонтекст, ИмяПеременной);
			КонецЕсли;	
			
			ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
				"# Переменная: %1
				|
				|- Значение: %2"),
				ИмяПеременной,
				MCPПредставлениеЗначенияДляMarkdown(Значение));
			Возврат ТекстОтвета;
		Иначе
			// Все переменные — формируем Markdown
			Строки = Новый Массив;
			Строки.Добавить("# Переменные контекста");
			Строки.Добавить("");
			
			КоличествоПеременных = 0;
			
			Если ОбъектКонтекст <> Неопределено И ТипЗнч(ОбъектКонтекст) = Тип("Структура") Тогда
				Строки.Добавить("## Контекст ($var$)");
				Для Каждого КлючЗначение Из ОбъектКонтекст Цикл
					Если Ванесса.ЭтоСлужебнаяПеременаяКонтекста(КлючЗначение.Ключ) Тогда
						Продолжить;
					КонецЕсли;
					Строки.Добавить("- `" + КлючЗначение.Ключ + "` = " + MCPПредставлениеЗначенияДляMarkdown(КлючЗначение.Значение));
					КоличествоПеременных = КоличествоПеременных + 1;
				КонецЦикла;
			КонецЕсли;
			
			Если ОбъектКонтекстСохраняемый <> Неопределено И ТипЗнч(ОбъектКонтекстСохраняемый) = Тип("Структура") Тогда
				Строки.Добавить("");
				Строки.Добавить("## Сохраняемый контекст ($$var$$)");
				Для Каждого КлючЗначение Из ОбъектКонтекстСохраняемый Цикл
					Если Ванесса.ЭтоСлужебнаяПеременаяКонтекста(КлючЗначение.Ключ) Тогда
						Продолжить;
					КонецЕсли;
					Строки.Добавить("- `" + КлючЗначение.Ключ + "` = " + MCPПредставлениеЗначенияДляMarkdown(КлючЗначение.Значение));
					КоличествоПеременных = КоличествоПеременных + 1;
				КонецЦикла;
			КонецЕсли;
			
			Если КоличествоПеременных = 0 Тогда
				Строки.Добавить(Ванесса.Локализовать("Переменных нет."));
			КонецЕсли;
			
			Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
		КонецЕсли;
		
	ИначеЕсли Действие = "set" Тогда
		Если Не ЗначениеЗаполнено(ИмяПеременной) Тогда
			ТекстОшибки = Ванесса.Локализовать("Параметр name обязателен для action=set.");
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстОшибки);
		КонецЕсли;
		
		Попытка
			Если ПеременнаяГлобальная Тогда
				ОбъектКонтекстСохраняемый.Вставить(ИмяПеременной, ЗначениеПеременнойПараметр);
			Иначе
				ОбъектКонтекст.Вставить(ИмяПеременной, ЗначениеПеременнойПараметр);
			КонецЕсли;	
			ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
				"# Переменная установлена
				|
				|- Имя: %1
				|- Значение: %2"),
				ИмяПеременной,
				MCPПредставлениеЗначенияДляMarkdown(ЗначениеПеременнойПараметр));
			Возврат ТекстОтвета;
		Исключение
			ТекстОшибки = Ванесса.Локализовать("Ошибка установки переменной:") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
		КонецПопытки;
		
	ИначеЕсли Действие = "delete" Тогда
		Если Не ЗначениеЗаполнено(ИмяПеременной) Тогда
			ТекстОшибки = Ванесса.Локализовать("Параметр name обязателен для action=delete.");
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстОшибки);
		КонецЕсли;
		
		Попытка
			// Удаляем из обоих контекстов
			Если ОбъектКонтекст <> Неопределено И ТипЗнч(ОбъектКонтекст) = Тип("Структура") Тогда
				Попытка
					ОбъектКонтекст.Удалить(ИмяПеременной);
				Исключение
				КонецПопытки;
			КонецЕсли;
			
			ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
				"# Переменная удалена
				|
				|- Имя: %1"),
				ИмяПеременной);
			Возврат ТекстОтвета;
		Исключение
			ТекстОшибки = Ванесса.Локализовать("Ошибка удаления:")+ " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
		КонецПопытки;
		
	Иначе
		ТекстОшибки = Ванесса.Локализовать("Неизвестное действие:") + " " + Действие + Ванесса.Локализовать(". Допустимые: get, set, delete.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстОшибки);
	КонецЕсли;
	
	
	Возврат Ванесса.Локализовать("Окно было успешно активизировано.");
	
КонецФункции

// Получает информацию из базы знаний
&НаКлиенте
Функция ПолучитьДанныеИзБазыЗнаний(Запрос, ДополнительныеПараметры) Экспорт
	
	ФорматОтвета = ЗначениеПараметраИзЗапроса(Запрос, "format");
	СтрокаПоиска = СокрЛП(ЗначениеПараметраИзЗапроса(Запрос, "search_string"));
	Попытка
		НомерВопроса = Число(ЗначениеПараметраИзЗапроса(Запрос, "question_number"));	
	Исключение
		НомерВопроса = Неопределено;
	КонецПопытки;
	
	Если НЕ ЗначениеЗаполнено(ФорматОтвета) Тогда
		ТекстСообщения = Ванесса.Локализовать("Не указан обязательный параметр 'format'");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	Если ФорматОтвета <> "short_info"
		И ФорматОтвета <> "questions_only"
		И ФорматОтвета <> "one_question"
		И ФорматОтвета <> "question_search"
		И ФорматОтвета <> "answers_search"
		И ФорматОтвета <> "all"
		Тогда
		ТекстСообщения = Ванесса.Локализовать("Передано недопустимое значение параметра 'format'");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	Если глКешБазыЗнаний = Неопределено Тогда
		глКешБазыЗнаний = ПолныйТекстБазыЗнанийСервер();
	КонецЕсли;
	
	Возврат ДанныеИзБазыЗнанийКлиент(ФорматОтвета, НомерВопроса, СтрокаПоиска);
	
КонецФункции

// Получает информацию о статистике использования шагов
&НаКлиенте
Функция ПолучитьДанныеОЧастоИспользуемыхШагах(Запрос, ДополнительныеПараметры) Экспорт
	
	Количество = ЗначениеПараметраИзЗапроса(Запрос, "limit");
	Если НЕ ЗначениеЗаполнено(Количество) Тогда
		Количество = 100;
	КонецЕсли;	
	
	Если глЧастоИспользуемыеШаги = Неопределено Тогда
		глЧастоИспользуемыеШаги = ПолучитьДанныеМакетаЧастоИспользуемыеШаги();
	КонецЕсли;
	
	Возврат ДанныеОЧастоИспользуемыхШагах(Количество);
	
КонецФункции

// Универсальный инструмент для управления командным интерфейсом
&НаКлиенте
Функция УправлениеКоманднымИнтерфейсом(Запрос, ДополнительныеПараметры) Экспорт
	
	Действие = Строка(ЗначениеПараметраИзЗапроса(Запрос, "action"));
	Если НЕ ЗначениеЗаполнено(Действие) Тогда
		ТекстСообщения = Ванесса.Локализовать("Параметр action обязателен. Допустимые значения: 'get_section_panel', 'get_function_panel', 'click_section_panel', 'click_function_panel'.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	// Проверка подключения клиента тестирования
	Попытка
		АктивноеОкно = Ванесса.ПолучитьАктивноеОкноИзТестовоеПриложение();
	Исключение
		ТекстОшибки = ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.Локализовать("Клиент тестирования не подключен. Сначала вызовите connect_test_client.") + " " + ТекстОшибки);
	КонецПопытки;
	
	Если Действие = "get_section_panel" Тогда
		Возврат ПолучитьПанельРазделов(Запрос);
	ИначеЕсли Действие = "get_function_panel" Тогда
		Возврат ПолучитьПанельФункций(Запрос);
	ИначеЕсли Действие = "click_section_panel" Тогда
		Возврат НажатьКнопкуПанелиРазделов(Запрос);
	ИначеЕсли Действие = "click_function_panel" Тогда
		Возврат НажатьКнопкуПанелиФункций(Запрос);
	Иначе
		ТекстСообщения = Ванесса.Локализовать("Неизвестное действие:") + " " + Действие + ". " + Ванесса.Локализовать("Допустимые: 'get_section_panel', 'get_function_panel', 'click_section_panel', 'click_function_panel'.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
КонецФункции

// Получает панель разделов (внутренняя реализация)
&НаКлиенте
Функция ПолучитьПанельРазделов(Запрос)
	
	ПанельРазделов = Ванесса.ПанельРазделов();
	Если ПанельРазделов = Неопределено Тогда
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.Локализовать("Панель разделов пуста или недоступна."));
	КонецЕсли;
	СписокКоманд = ПанельРазделов.НайтиОбъекты();
	
	// Markdown формат
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Панель разделов"));
	Строки.Добавить("");
	
	Если СписокКоманд.Количество() = 0 Тогда
		Строки.Добавить(Ванесса.Локализовать("Панель разделов пуста."));
	Иначе
		Для Каждого Команда Из СписокКоманд Цикл
			Строки.Добавить(Ванесса.Локализовать("- Команда:") + " " + Команда.ТекстЗаголовка);
			//Если ЗначениеЗаполнено(Команда.НавигационнаяСсылка) Тогда
			//	Строки.Добавить("  " + "- НавигационнаяСсылка:" + " " + Команда.НавигационнаяСсылка);
			//КонецЕсли;
			// Навигационные ссылки не добавляются для панели разделов, т.к. для них не работает переход по навигационной ссылке
			Строки.Добавить("");
		КонецЦикла;
	КонецЕсли;
	
	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Получает панель функций (внутренняя реализация)
&НаКлиенте
Функция ПолучитьПанельФункций(Запрос)
	
	ПанельФункций = Ванесса.ПанельФункций();
	
	Если ПанельФункций = Неопределено Тогда
		Возврат Ванесса.Локализовать("Панель функций пуста или недоступна. Возможно, не выбран раздел в панели разделов. Либо повторное нажатие на одну и туже команду панели разделов скрыло панель функций.");
	КонецЕсли;
	
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Панель функций"));
	Строки.Добавить("");
	
	ТекстОшибки = Неопределено;
	ДобавитьВМассивСтрокДанныеПанелиФункций(Строки, ТекстОшибки);
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецЕсли;	
	
	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Нажимает кнопку панели разделов (внутренняя реализация)
&НаКлиенте
Функция НажатьКнопкуПанелиРазделов(Запрос)
	
	Команда = Строка(ЗначениеПараметраИзЗапроса(Запрос, "command"));
	Если НЕ ЗначениеЗаполнено(Команда) Тогда
		ТекстСообщения = Ванесса.Локализовать("Параметр command обязателен для действия click_section_panel.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	ВозвратФункции = ЗначениеПараметраИзЗапроса(Запрос, "returnFunctionPanel");
	Если НЕ ЗначениеЗаполнено(ВозвратФункции) Тогда
		ВозвратФункции = Ложь;
	Иначе
		Попытка
			ВозвратФункции = Булево(ВозвратФункции);
		Исключение
			ВозвратФункции = Ложь;
		КонецПопытки;
	КонецЕсли;
	
	// Получаем панель разделов
	ПанельРазделов = Ванесса.ПанельРазделов();
	
	Если ПанельРазделов = Неопределено Тогда
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.Локализовать("Панель разделов пуста или недоступна."));
	КонецЕсли;
	
	// Ищем и нажимаем кнопку
	Попытка
		ДопПараметры = Новый Структура;
		ДопПараметры.Вставить("КоличествоПопыток", 1);
		Ванесса.ВПанелиРазделовЯВыбираю(Команда, ДопПараметры);
	Исключение
		ТекстОшибки = Ванесса.Локализовать("Не удалось нажать на команду панели разделов.") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	
	// Формируем ответ
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("# Команда панели разделов нажата: %1"), Команда));
	Строки.Добавить("");
	
	Если ВозвратФункции Тогда
		ТекстОшибки = Неопределено;
		ДобавитьВМассивСтрокДанныеПанелиФункций(Строки, ТекстОшибки);
		Если ЗначениеЗаполнено(ТекстОшибки) Тогда
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
		КонецЕсли;	
	КонецЕсли;
	
	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

&НаКлиенте
Процедура ДобавитьВМассивСтрокДанныеПанелиФункций(Строки, ТекстОшибки)
	Строки.Добавить(Ванесса.Локализовать("## Панель функций"));
	Строки.Добавить("");
	БылиЭлементы = Ложь;
	// Получаем панель функций после нажатия
	Попытка
		ПанельФункций = Ванесса.ПанельФункций();
		Если ПанельФункций <> Неопределено Тогда
			
			ДанныеПанелиФункций = ДанныеПанелиФункций(ПанельФункций);
			ЭлементыБезГруппы = ДанныеПанелиФункций.ЭлементыБезГруппы;
			КешГрупп = ДанныеПанелиФункций.КешГрупп;
			
			Если ЭлементыБезГруппы.Количество() > 0 Тогда
				Для Каждого Элем Из ЭлементыБезГруппы Цикл
					Строки.Добавить("- `" + Элем.ТекстЗаголовка + "`");
					БылиЭлементы = Истина;
				КонецЦикла;
				Строки.Добавить("");
			КонецЕсли;
			
			Для Каждого КлючЗначение Из КешГрупп Цикл
				Строки.Добавить(Ванесса.Локализовать("# Группа `") + КлючЗначение.Ключ + "`");
				ДанныеГруппы = КлючЗначение.Значение;
				Для Каждого Элем Из ДанныеГруппы Цикл
					Строки.Добавить("* `" + Элем.ТекстЗаголовка + "`");
					Строки.Добавить("  " + "- Навигацонная ссылка:" + " " + Элем.НавигационнаяСсылка);
					Строки.Добавить("");
					БылиЭлементы = Истина;
				КонецЦикла;	
			КонецЦикла;	
			
		КонецЕсли;
		
		Если НЕ БылиЭлементы Тогда
			Строки.Добавить(Ванесса.Локализовать("Панель функций пуста."));
		КонецЕсли;	
		
	Исключение
		ТекстОшибки = Ванесса.Локализовать("Не удалось нажать на команду панели функций.") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
	КонецПопытки;
КонецПроцедуры

&НаКлиенте
Функция ДанныеПанелиФункций(ПанельФункций)
	
	ЭлементыБезГруппы = Новый Массив;
	КешГрупп = Новый Соответствие;

	Результат = Новый Структура;
	Результат.Вставить("ЭлементыБезГруппы", ЭлементыБезГруппы);
	Результат.Вставить("КешГрупп", КешГрупп);
	
	СписокКомандФункций = ПанельФункций.НайтиОбъекты();
	Если СписокКомандФункций.Количество() = 0 Тогда
	Иначе
		КешНавигационныхССылок = Новый Соответствие;
		
		Для Каждого КомандаФункции Из СписокКомандФункций Цикл
			Если ТипЗнч(КомандаФункции) = Тип("ТестируемаяГруппаКомандногоИнтерфейса") Тогда
				Если КешГрупп[КомандаФункции.ТекстЗаголовка] = Неопределено Тогда
					ДанныеГруппы = Новый Массив;
					КешГрупп.Вставить(КомандаФункции.ТекстЗаголовка, ДанныеГруппы);
				КонецЕсли;
				
				ДанныеГруппы = КешГрупп[КомандаФункции.ТекстЗаголовка];
				
				ЭлементыГруппы = КомандаФункции.НайтиОбъекты();
				Для Каждого Элем Из ЭлементыГруппы Цикл
					Если ЗначениеЗаполнено(Элем.НавигационнаяСсылка) Тогда
						Если КешНавигационныхССылок[Элем.НавигационнаяСсылка] <> Неопределено Тогда
							Продолжить;
						КонецЕсли;
						КешНавигационныхССылок.Вставить(Элем.НавигационнаяСсылка, Элем);
					КонецЕсли;	
					ДанныеГруппы.Добавить(Элем);
				КонецЦикла;	
			КонецЕсли;
		КонецЦикла;
		
		// собираем элемены без группы
		Для Каждого КомандаФункции Из СписокКомандФункций Цикл
			Если ТипЗнч(КомандаФункции) = Тип("ТестируемаяГруппаКомандногоИнтерфейса") Тогда
				Продолжить;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(КомандаФункции.НавигационнаяСсылка) Тогда
				Если КешНавигационныхССылок[КомандаФункции.НавигационнаяСсылка] <> Неопределено Тогда
					Продолжить;
				КонецЕсли;
			КонецЕсли;	
			
			ЭлементыБезГруппы.Добавить(КомандаФункции);
			
		КонецЦикла;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции	

// Нажимает кнопку панели функций (внутренняя реализация)
&НаКлиенте
Функция НажатьКнопкуПанелиФункций(Запрос)
	
	Команда = Строка(ЗначениеПараметраИзЗапроса(Запрос, "command"));
	Если НЕ ЗначениеЗаполнено(Команда) Тогда
		ТекстСообщения = Ванесса.Локализовать("Параметр command обязателен для действия click_function_panel.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	Группа = Строка(ЗначениеПараметраИзЗапроса(Запрос, "group"));
	
	// Получаем панель функций
	ПанельФункций = Неопределено;
	Попытка
		ПанельФункций = Ванесса.ПанельФункций();
	Исключение
		ТекстОшибки = Ванесса.Локализовать("Не удалось получить панель функций.") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецПопытки;
	
	Если ПанельФункций = Неопределено Тогда
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.Локализовать("Панель функций пуста или недоступна. Возможно, не выбран раздел в панели разделов."));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Группа) Тогда
		//Ищем группу
		
		ЭлементыГруппа = ПанельФункций.НайтиОбъекты(Тип("ТестируемаяГруппаКомандногоИнтерфейса"),Группа);
		Если ЭлементыГруппа.Количество() = 0 Тогда
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("В панели функций не найдена группа '%1'"), Группа));
		КонецЕсли;
		
		Если ЭлементыГруппа.Количество() > 1 Тогда
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("В панели функций найдено %1 групп с заголовоком '%2'"), XMLСтрока(ЭлементыГруппа.Количество()), Группа));
		КонецЕсли;
		
		ЭлементФункция = ЭлементыГруппа[0].НайтиОбъект(,Команда);
		Если ЭлементФункция = Неопределено Тогда
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("В панели функций в группе '%1' не найдена команда '%2'"), Группа, Команда));
		КонецЕсли;
		
		Попытка
			ЭлементФункция.Нажать();
		Исключение
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("В панели функций не получлось нажать на команду '%1'"), Команда)) + Символы.ПС + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		КонецПопытки;
	Иначе	
		ЭлементФункция = ПанельФункций.НайтиОбъект(,Команда);
		Если ЭлементФункция = Неопределено Тогда
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("В панели функций не найдена команда '%1'"), Команда));
		КонецЕсли;
		
		Попытка
			ЭлементФункция.Нажать();
		Исключение
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("В панели функций не получлось нажать на команду '%1'"), Команда)) + Символы.ПС + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
		КонецПопытки;
	КонецЕсли;	
	
	Возврат Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("# Команда панели функций нажата: %1"), Команда);
	
КонецФункции

// Получает информацию о строке сценария. Если в строке находится шаг - то возвращает подробную информацию о шаге.
&НаКлиенте
Функция ПолучитьПодробнуюИнформациюОШагеВСтрокеСценария(Запрос, ДополнительныеПараметры) Экспорт
	
	НомерСтроки = Число(ЗначениеПараметраИзЗапроса(Запрос, "lineNumber"));	
	Если НЕ ЗначениеЗаполнено(НомерСтроки) Тогда
		ТекстСообщения = Ванесса.Локализовать("Не указан обязательный параметр 'lineNumber'");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;
	
	СтрокаДерева = Ванесса.СтрокаДереваПоНомеруСтрокиФичи(НомерСтроки);
	
	ЭкземплярVanessaEditor = Ванесса.ПолучитьVanessaEditor();
	Если СтрокаДерева = Неопределено Тогда
		Попытка
			ТекстСтроки = ЭкземплярVanessaEditor.getLineContent(НомерСтроки);
			ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("В строке %1 не найден шаг.
			|Текст в строке: %2"), XMLСтрока(НомерСтроки), ТекстСтроки);
			Возврат ТекстСообщения;
		Исключение
			ТекстОшибки = Ванесса.Локализовать("Ошибка:") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
		КонецПопытки;
	КонецЕсли;
	
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("### Данные строки"));
	Строки.Добавить("");
	ТекстСтроки = СокрЛ(ЭкземплярVanessaEditor.getLineContent(НомерСтроки));
	Строки.Добавить(Ванесса.Локализовать("Текст в строке:") + " " + ТекстСтроки);
	Строки.Добавить(Ванесса.Локализовать("Шаг в строке:") + " " + СтрокаДерева.Имя);
	Строки.Добавить(Ванесса.Локализовать("Снипет:") + " " + СтрокаДерева.Снипет);
	Строки.Добавить(Ванесса.Локализовать("Тип данных в строке:") + " " + СтрокаДерева.Тип);
	Если ЗначениеЗаполнено(СтрокаДерева.ДопТип) Тогда
		Строки.Добавить(Ванесса.Локализовать("Уточнение типа:") + " " + СтрокаДерева.ДопТип);
	КонецЕсли;	
	
	Если СтрокаДерева.Тип = "Шаг" Тогда
		СтрокаДляПоиска = ПолучитьСтрокуДляПоискаШагаПоСнипету(СтрокаДерева.Снипет);
		Отбор = Новый Структура();
		Отбор.Вставить("СтрокаДляПоиска", СтрокаДляПоиска);
		СтрокиТаблицы = Ванесса.ТаблицаИзвестныхStepDefinition.НайтиСтроки(Отбор);
		СтрокаТаблицаИзвестныхStepDefinition = Неопределено;
		Если СтрокиТаблицы.Количество() > 0 Тогда
			СтрокаТаблицаИзвестныхStepDefinition = СтрокиТаблицы[0];
		КонецЕсли;	
		Если СтрокаТаблицаИзвестныхStepDefinition = Неопределено Тогда
			Строки.Добавить(Ванесса.Локализовать("В таблице известных шагов не найден шаг:") + " " + СтрокаДерева.Имя);
		Иначе	
			Строки.Добавить(Ванесса.Локализовать("## Данные шага:"));
			Строки.Добавить(Ванесса.Локализовать("  " + "- Тип шага:") + " " + СтрокаТаблицаИзвестныхStepDefinition.ТипШага);
			ИмяФайла = СтрокаТаблицаИзвестныхStepDefinition.ИмяФайла;
			Если НЕ Ванесса.ЭтоLinuxКлиент() Тогда
				ИмяФайла = СтрЗаменить(ИмяФайла, "/", "\");
			КонецЕсли;	
			Строки.Добавить(Ванесса.Локализовать("  " + "- Имя файла где находится реализация шага:") + " " + ИмяФайла);
			Строки.Добавить(Ванесса.Локализовать("# Описание шага:"));
			Строки.Добавить(СтрокаТаблицаИзвестныхStepDefinition.ОписаниеШага);
		КонецЕсли;	
	КонецЕсли;	
	
	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Добавляет, читает и удаляет точки останова
&НаКлиенте
Функция УправлениеТочкамиОстанова(Запрос, ДополнительныеПараметры) Экспорт
	
	Если НЕ Ванесса.Объект.ИспользоватьРедакторVanessaEditor Тогда
		ТекстОшибки = Ванесса.Локализовать("Работать с точками останова можно только когда используется основной редактор Vanessa Automation, а сейчас он выключен.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецЕсли;	
	
	Действие = Строка(ЗначениеПараметраИзЗапроса(Запрос, "action"));
	Если НЕ ЗначениеЗаполнено(Действие) Тогда
		Действие = "toggle";
	КонецЕсли;
	
	Если Действие = "list" Тогда
		Попытка
			МассивБрейкпоинтов = Ванесса.БрейкпоинтыVanessaEditor();
			Строки = Новый Массив;
			Строки.Добавить(Ванесса.Локализовать("# Точки останова"));
			Строки.Добавить("");
			Если МассивБрейкпоинтов <> Неопределено И ТипЗнч(МассивБрейкпоинтов) = Тип("Массив") И МассивБрейкпоинтов.Количество() > 0 Тогда
				Строки.Добавить(Ванесса.Локализовать("Количество:") + " " + Формат(МассивБрейкпоинтов.Количество(), "ЧГ=0; ЧН=0"));
				Для Каждого ДанныеТочкиОстнова Из МассивБрейкпоинтов Цикл
					Строки.Добавить("- " + ДанныеТочкиОстнова.НомерСтроки);
				КонецЦикла;
			Иначе
				Строки.Добавить(Ванесса.Локализовать("Точек останова нет."));
				Строки.Добавить("");
				// Контекст: показать открытые файлы
				Если Не Ванесса.ОтсутствуетVanessaEditor() Тогда
					Попытка
						Редактор = Ванесса.ПолучитьVanessaEditor();
						СписокВкладок = Редактор.tabsGetAll();
						Если ТипЗнч(СписокВкладок) = Тип("Массив") И СписокВкладок.Количество() > 0 Тогда
							Строки.Добавить("## Открытые файлы");
							Для Каждого Вкладка Из СписокВкладок Цикл
								Строки.Добавить("- " + Строка(Вкладка));
							КонецЦикла;
						Иначе
							Строки.Добавить(Ванесса.Локализовать("Файлы не открыты. Загрузите фичи (`load_features`) и откройте сценарий."));
						КонецЕсли;
					Исключение
						Строки.Добавить(Ванесса.Локализовать("Загрузите фичи (`load_features`) и откройте сценарий для работы с точками останова."));
					КонецПопытки;
				Иначе
					Строки.Добавить(Ванесса.Локализовать("Редактор не доступен. Загрузите фичи (`load_features`) для инициализации."));
				КонецЕсли;
				Строки.Добавить("");
				Строки.Добавить(Ванесса.Локализовать("## Как добавить"));
				Строки.Добавить(Ванесса.Локализовать("- Используйте `manage_breakpoints(action='toggle', line=N)` для переключения точки останова на строке N."));
			КонецЕсли;
			
			Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
		Исключение
			ТекстОшибки = Ванесса.Локализовать("Ошибка:") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
		КонецПопытки;
		
	ИначеЕсли Действие = "remove_all" Тогда
		Попытка
			МассивБрейкпоинтов = Ванесса.Брейкпоинты();
			Количество = 0;
			Если МассивБрейкпоинтов <> Неопределено И ТипЗнч(МассивБрейкпоинтов) = Тип("Массив") Тогда
				Количество = МассивБрейкпоинтов.Количество();
			КонецЕсли;
			
			// Удаляем все точки останова через API редактора
			Если НЕ Ванесса.ОтсутствуетVanessaEditor() Тогда
				Ванесса.УдалитьВсеТочкиОстановаРедактора();
			КонецЕсли;
			
			ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
				"# Точки останова удалены
				|
				|- Удалено: %1"),
				Формат(Количество, "ЧГ=0; ЧН=0"));
			Возврат ТекстОтвета;
		Исключение
			ТекстОшибки = Ванесса.Локализовать("Ошибка:") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
		КонецПопытки;
		
	ИначеЕсли Действие = "toggle" Тогда
		Попытка
			
			Если НЕ Ванесса.ЭтоВкладкаEdit(Ванесса.VanessaTabs.current) Тогда
				ТекстОшибки = Ванесса.Локализовать("В редакторе не открыт фича файл.");
				Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
			КонецЕсли;	
			
			НомерСтроки = Число(ЗначениеПараметраИзЗапроса(Запрос, "line"));
			РедакторДоступен = НЕ Ванесса.ОтсутствуетVanessaEditor();
			
			Если НомерСтроки <> Неопределено И РедакторДоступен Тогда
				Редактор = Ванесса.ПолучитьVanessaEditor();
				Редактор.toggleBreakpoint(НомерСтроки);
			ИначеЕсли НомерСтроки <> Неопределено И Не РедакторДоступен Тогда
				ТекстОшибки = Ванесса.Локализовать("Редактор Monaco недоступен. Загрузите фичи (`load_features`) для инициализации редактора.");
				Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
			Иначе
				Ванесса.ОбработатьУстановкуСнятиеБрейкпоинта();
			КонецЕсли;
			
			Если НомерСтроки <> Неопределено Тогда
				ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
					"# Брейкпоинт переключён
					|
					|- Строка: %1"),
					Формат(НомерСтроки, "ЧГ=0; ЧН=0"));
			Иначе
				ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
					"# Брейкпоинт переключён
					|
					|- Строка: текущая"));
			КонецЕсли;
			Возврат ТекстОтвета;
		Исключение
			ТекстОшибки = Ванесса.Локализовать("Ошибка:") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
		КонецПопытки;
		
	Иначе
		ТекстОшибки = Ванесса.Локализовать("Неизвестное действие:") + " " + Действие + ". " + Ванесса.Локализовать("Допустимые: toggle, remove_all, list.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
	КонецЕсли;
	
КонецФункции

// Выполняет сценарий или все сценарии
&НаКлиенте
Функция ВыполнитьСценарий(Запрос, ДополнительныеПараметры) Экспорт
	
	Если Ванесса.Объект.ИдетВыполнениеСценариев Тогда
		ТекстСообщения = Ванесса.Локализовать("Сценарии уже выполняются. Дождитесь завершения или вызовите stopExecution.");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстСообщения);
	КонецЕсли;
	
	Режим = "all";
	Значение = Строка(ЗначениеПараметраИзЗапроса(Запрос, "mode"));
	Если ЗначениеЗаполнено(Значение) Тогда
		Режим = Значение;
	КонецЕсли;	
	
	// Параметр filePath: загрузить фичу и открыть в редакторе перед запуском
	ПутьКФайлу = Строка(ЗначениеПараметраИзЗапроса(Запрос, "filePath"));

	Идентификатор = Запрос.Идентификатор;
	Ванесса.УстановитьИдентификаторЗадачиMCP(Идентификатор);
	
	ДопПараметрыВызоваMCP = Новый Структура;
	ДопПараметрыВызоваMCP.Вставить("Тип", "ВыполнитьСценарий");
	ДопПараметрыВызоваMCP.Вставить("ПутьКФайлу", ПутьКФайлу);
	ДопПараметрыВызоваMCP.Вставить("Режим", Режим);
	ДопПараметрыВызоваMCP.Вставить("Идентификатор", Идентификатор);
	
	ПродолжитьВыполнитьСценарий1(ПутьКФайлу, ДопПараметрыВызоваMCP);
	
КонецФункции

// Останавливает выполнение сценариев
&НаКлиенте
Функция ОстановитьВыполнениеСценариев(Запрос, ДополнительныеПараметры) Экспорт
	
	БылоВыполнение = Ванесса.Объект.ИдетВыполнениеСценариев;
	
	Попытка
		Ванесса.КомандаОстановитьСценарии();
	Исключение
	КонецПопытки;
	
	Если Не БылоВыполнение Тогда
		ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
			"# Остановка выполнения
			|
			|- Остановлено: да
			|- Было активное выполнение: %1
			|
			|Сценарии не выполнялись. Используйте `run_scenario` для запуска."),
			MCPПредставлениеЗначенияДляMarkdown(БылоВыполнение));
	Иначе
		ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
			"# Остановка выполнения
			|
			|- Остановлено: да
			|- Было активное выполнение: %1
			|
			|## Следующие шаги
			|- Получите результаты: `get_test_results`"),
			MCPПредставлениеЗначенияДляMarkdown(БылоВыполнение));
	КонецЕсли;
	
	Возврат ТекстОтвета;
	
КонецФункции

// Получает результат выполнения тестов
&НаКлиенте
Функция ПолучитьРезультатВыполненияТестов(Запрос, ДополнительныеПараметры) Экспорт
	
	Результат = Неопределено;
	ИдСценария = Строка(ЗначениеПараметраИзЗапроса(Запрос, "scenarioId"));

	Если ЗначениеЗаполнено(ИдСценария) Тогда
		Попытка
			Результат = Ванесса.ПолучитьРезультатПрохожденияТестовСценария(ИдСценария);
		Исключение
			ТекстОшибки = Ванесса.Локализовать("Ошибка получения результата:") + " " + ОписаниеОшибки();
			Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстОшибки);
		КонецПопытки;
	Иначе
		// Последний результат
		
		МассивРезультатПрохожденияТестовСценария = Ванесса.ПолучитьМассивРезультатПрохожденияТестовСценария();	
		
		Попытка
			Если МассивРезультатПрохожденияТестовСценария <> Неопределено 
				И МассивРезультатПрохожденияТестовСценария.Количество() > 0 Тогда
				Результат = МассивРезультатПрохожденияТестовСценария[МассивРезультатПрохожденияТестовСценария.Количество() - 1];
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Если Результат = Неопределено Тогда
		
		ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
				"# Результаты тестов
				|
				|Нет результатов выполнения.
				|
				|## Следующие шаги
				|- Загрузите фичи: `load_features`
				|- Запустите сценарий: `run_scenario`
				|- Затем повторите: `get_test_results`"));
		
		Возврат ТекстСообщения;
	КонецЕсли;
	
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
		"# Результаты тестов
		|
		|- Статус: %1"),
		MCPПредставлениеЗначенияДляMarkdown(MCPБезопасноеСвойство(Результат, "Статус"))));
	
	ВремяНач = MCPБезопасноеСвойство(Результат, "ВремяНачала");
	ВремяКон = MCPБезопасноеСвойство(Результат, "ВремяОкончания");
	Если ВремяНач <> Неопределено И ВремяКон <> Неопределено Тогда
		Строки.Добавить(Ванесса.Локализовать("- Длительность:") + " " + Формат(ВремяКон - ВремяНач, "ЧГ=0; ЧН=0") + Ванесса.Локализовать(" мс"));
	КонецЕсли;
	
	ОписаниеОшибкиРез = MCPБезопасноеСвойство(Результат, "ОписаниеОшибки");
	Если ЗначениеЗаполнено(ОписаниеОшибкиРез) Тогда
		Строки.Добавить(Ванесса.Локализовать("- Ошибка:") + " " + ОписаниеОшибкиРез);
	КонецЕсли;
	Строки.Добавить("");
	
	ШагиРезультаты = MCPБезопасноеСвойство(Результат, "РезультатПрохожденияТестовШагов");
	Если ШагиРезультаты <> Неопределено И ТипЗнч(ШагиРезультаты) = Тип("Массив") Тогда
		Строки.Добавить(Ванесса.Локализовать("## Шаги (") + Формат(ШагиРезультаты.Количество(), "ЧГ=0; ЧН=0") + ")");
		Номер = 0;
		Для Каждого ШагРез Из ШагиРезультаты Цикл
			Номер = Номер + 1;
			ИмяШага = MCPПредставлениеЗначенияДляMarkdown(MCPБезопасноеСвойство(ШагРез, "Имя"));
			СтатусШага = MCPПредставлениеЗначенияДляMarkdown(MCPБезопасноеСвойство(ШагРез, "Статус"));
			
			ВремяНачШ = MCPБезопасноеСвойство(ШагРез, "ВремяНачала");
			ВремяКонШ = MCPБезопасноеСвойство(ШагРез, "ВремяОкончания");
			ВремяШага = "";
			Если ВремяНачШ <> Неопределено И ВремяКонШ <> Неопределено Тогда
				ВремяШага = " (" + Формат(ВремяКонШ - ВремяНачШ, "ЧГ=0; ЧН=0") + " " + Ванесса.Локализовать("мс)");
			КонецЕсли;
			
			ОшибкаШага = ТекстОшибкиИзОписанияОшибки(MCPБезопасноеСвойство(ШагРез, "ОписаниеОшибки"));
			
			Строки.Добавить(Формат(Номер, "ЧГ=0; ЧН=0") + ". " + ИмяШага + " → **" + СтатусШага + "**" + ВремяШага);
			Если ЗначениеЗаполнено(ОшибкаШага) Тогда
				Строки.Добавить(Ванесса.Локализовать("   " + "- Ошибка:") + " " + ОшибкаШага);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);

КонецФункции

// Возвращает текущую дату на сервере
&НаКлиенте
Функция ПолучитьТекущуюДатуНаСервере1С(Запрос, ДополнительныеПараметры) Экспорт
	Возврат ПолучитьТекущуюДатуНаСервере1СMCP_Сервер();
КонецФункции

// Возвращает состояние Vanessa Automation
&НаКлиенте
Функция ПолучитьСостояниеVanessaAutomation(Запрос, ДополнительныеПараметры) Экспорт

	Результат = Новый Структура;
	Результат.Вставить("isRunning", Ванесса.Объект.ИдетВыполнениеСценариев = Истина);
	Результат.Вставить("featureDirectory", Ванесса.Объект.КаталогФич);
	
	// Реальная проверка подключения клиента тестирования
	Попытка
		АктивноеОкноVA = Ванесса.ПолучитьАктивноеОкноИзТестовоеПриложение();
		Значение = АктивноеОкноVA <> Неопределено;
		ТекущиеДанныеКлиентаТестирования = Ванесса.ТекущиеДанныеКлиентаТестирования();
		Если ТекущиеДанныеКлиентаТестирования = Неопределено Тогда
			Значение = Ложь;
		КонецЕсли;	
		Результат.Вставить("testClientConnected", Значение);
		Если Значение Тогда
			ТекущиеДанныеКлиентаТестирования = Ванесса.ТекущиеДанныеКлиентаТестирования();
			Если ТекущиеДанныеКлиентаТестирования <> Неопределено Тогда
				Результат.Вставить("ИмяПрофиляКлиентаТестирования", ТекущиеДанныеКлиентаТестирования.Имя);
			КонецЕсли;	
		КонецЕсли;	
	Исключение
		Результат.Вставить("testClientConnected", Ложь);
	КонецПопытки;
	
	Попытка
		СостояниеVA = Ванесса.ПолучитьСостояниеVanessaAutomation();
	Исключение
		СостояниеVA = Неопределено;
	КонецПопытки;
	
	Если СостояниеVA <> Неопределено Тогда
		
		Если СостояниеVA.Свойство("ТекущаяФича")
			И ТипЗнч(СостояниеVA.ТекущаяФича) = Тип("Структура")
			И НЕ ЗначениеЗаполнено(СостояниеVA.ТекущаяФича.ПолныйПуть)
			И Ванесса.Объект.ИспользоватьРедакторVanessaEditor
			И Ванесса.ЭтоВкладкаEdit(Ванесса.VanessaTabs.current)
			Тогда
			// Значит фича была загружена, но ещё не запускалась. Сообщим об этом.
			ТекстСообщения = Ванесса.Локализовать("В редактор был загржен фича файл, но ещё ни разу не запускался. Для получения подробной информации о загруженном файле нужно вызвать get_editor_state.
				|Имя загруженного feature файла:" + " " + Ванесса.Объект.КаталогФич);
			Возврат ТекстСообщения;
		КонецЕсли;	
		
		// Текущая фича
		Если СостояниеVA.Свойство("ТекущаяФича") И ТипЗнч(СостояниеVA.ТекущаяФича) = Тип("Структура") Тогда
			Фича = Новый Структура;
			Фича.Вставить("name", MCPБезопасноеСвойство(СостояниеVA.ТекущаяФича, "Имя"));
			Фича.Вставить("fullPath", MCPБезопасноеСвойство(СостояниеVA.ТекущаяФича, "ПолныйПуть"));
			Фича.Вставить("language", MCPБезопасноеСвойство(СостояниеVA.ТекущаяФича, "ЯзыкФичи"));
			Фича.Вставить("tags", MCPБезопасноеСвойство(СостояниеVA.ТекущаяФича, "МассивТегов"));
			Результат.Вставить("currentFeature", Фича);
		Иначе
			Результат.Вставить("currentFeature", Неопределено);
		КонецЕсли;
		
		// Текущий сценарий
		Если СостояниеVA.Свойство("ТекущийСценарий") И ТипЗнч(СостояниеVA.ТекущийСценарий) = Тип("Структура") Тогда
			Сценарий = Новый Структура;
			Сценарий.Вставить("name", MCPБезопасноеСвойство(СостояниеVA.ТекущийСценарий, "Имя"));
			Сценарий.Вставить("id", MCPБезопасноеСвойство(СостояниеVA.ТекущийСценарий, "ИдСценария"));
			Сценарий.Вставить("result", MCPБезопасноеСвойство(СостояниеVA.ТекущийСценарий, "РезультатПрохожденияТестовСценария"));
			Сценарий.Вставить("tags", MCPБезопасноеСвойство(СостояниеVA.ТекущийСценарий, "МассивТегов"));
			Сценарий.Вставить("retryNumber", MCPБезопасноеСвойство(СостояниеVA.ТекущийСценарий, "НомерПопыткиВыполненияСценария"));
			Результат.Вставить("currentScenario", Сценарий);
		Иначе
			Результат.Вставить("currentScenario", Неопределено);
		КонецЕсли;
		
		// Текущий шаг
		Если СостояниеVA.Свойство("ТекущийШаг") И ТипЗнч(СостояниеVA.ТекущийШаг) = Тип("Структура") Тогда
			Шаг = Новый Структура;
			Шаг.Вставить("name", MCPБезопасноеСвойство(СостояниеVA.ТекущийШаг, "Имя"));
			Шаг.Вставить("paramValues", MCPБезопасноеСвойство(СостояниеVA.ТекущийШаг, "ЗначенияПараметров"));
			Шаг.Вставить("lineNumber", MCPБезопасноеСвойство(СостояниеVA.ТекущийШаг, "НомерСтрокиВФиче"));
			Результат.Вставить("currentStep", Шаг);
		Иначе
			Результат.Вставить("currentStep", Неопределено);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат MCPСформироватьMarkdownСостоянияVA(Результат);
	
КонецФункции

// Выполняет синтакс контроль
&НаКлиенте
Функция СинтаксКонтроль(Запрос, ДополнительныеПараметры) Экспорт
	
	ПутьКФайлу = Строка(ЗначениеПараметраИзЗапроса(Запрос, "filePath"));
	
	СтрокаСообщения = Ванесса.Локализовать("Выполнение синтакс контроля.
	|filePath=%1");
	СтрокаСообщения = Ванесса.ПодставитьПараметрыВСтроку(СтрокаСообщения, ПутьКФайлу);
	Ванесса.СообщитьПользователю(СтрокаСообщения);
	Ванесса.ЗаписатьЛогВЖРИнформация("ПоискШаговПоСтрокеMCP", СтрокаСообщения);
	
	ОткрытиеФичаФайлаВРедакторе(ПутьКФайлу, Запрос, "СинтаксКонтроль");	
	
КонецФункции

// Открывает фича файл
&НаКлиенте
Функция ОткрытьФичаФайл(Запрос, ДополнительныеПараметры) Экспорт
	
	ПутьКФайлу = Строка(ЗначениеПараметраИзЗапроса(Запрос, "filePath"));
	ОткрытиеФичаФайлаВРедакторе(ПутьКФайлу, Запрос, "ОткрытьФичаФайл");
	
КонецФункции

// Загружает или перезагружает .feature файлы
&НаКлиенте
Функция ОткрытьЗагрузитьИлиПерезагрузитьФичаФайл(Запрос, ДополнительныеПараметры) Экспорт
	
	ПутьКФайлу = Строка(ЗначениеПараметраИзЗапроса(Запрос, "path"));
	
	ДопПараметрыВызоваMCP = Новый Структура;
	ДопПараметрыВызоваMCP.Вставить("ИсходныйПутьКФайлу", ПутьКФайлу);
	
	Если НЕ ЗначениеЗаполнено(ПутьКФайлу) Тогда
		Если Ванесса.Объект.ИспользоватьРедакторVanessaEditor Тогда
			// Значит в редакторе должен быть открыт фича файл
			Если НЕ Ванесса.ЭтоВкладкаEdit(Ванесса.VanessaTabs.current) Тогда
				// Значит файл не открыт
				ТекстСообщения = Ванесса.Локализовать("Нельзя перезагрузить текущий фича файл, т.к. в редакторе нет открытого файла.");
				Возврат МодульМсп_Сервер().ОшибкаИнструмента("ACTION_FAILED", ТекстСообщения);
			КонецЕсли;	
		КонецЕсли;	
		ПутьКФайлу = Ванесса.Объект.КаталогФич;
	КонецЕсли;	
	
	ОткрытиеФичаФайлаВРедакторе(ПутьКФайлу, Запрос, "ОткрытьЗагрузитьИлиПерезагрузитьФичаФайл", ДопПараметрыВызоваMCP);
	
КонецФункции

// Получает состояние редактора
&НаКлиенте
Функция ПолучитьСостояниеРедактора(Запрос, ДополнительныеПараметры) Экспорт
	
	ВключитьСодержимое = Истина;
	ЗначениеИзЗапроса = ЗначениеПараметраИзЗапроса(Запрос, "includeContent");
	Если ЗначениеИзЗапроса <> Неопределено Тогда
		ВключитьСодержимое = ЗначениеИзЗапроса = Истина;
	КонецЕсли;
	
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Состояние редактора"));
	Строки.Добавить("");
	
	// Вкладки
	Строки.Добавить(Ванесса.Локализовать("## Открытые вкладки"));
	Если Ванесса.VanessaTabs <> Неопределено Тогда
		Попытка
			КоличествоВкладок = Ванесса.VanessaTabs.count();
			Строки.Добавить(Ванесса.Локализовать("Количество:") + " " + Формат(КоличествоВкладок, "ЧГ=0; ЧН=0"));
			Строки.Добавить("");
			
			Для Инд = 0 По КоличествоВкладок - 1 Цикл
				Вкладка = Ванесса.VanessaTabs.tabStack[Инд];
				ИмяФайла = Вкладка.filename;
				Изменена = Вкладка.modified;
				Текущая = (Ванесса.VanessaTabs.current <> Неопределено И НРег(Ванесса.VanessaTabs.current.filename) = НРег(ИмяФайла));
				
				Префикс = "";
				Если Текущая Тогда
					Префикс = "**→** ";
				КонецЕсли;
				
				Суффикс = "";
				Если Изменена = Истина Тогда
					Суффикс = " " + Ванесса.Локализовать("*(изменена)*");
				КонецЕсли;
				
				Строки.Добавить("- " + Префикс + ИмяФайла + Суффикс);
			КонецЦикла;
		Исключение
			Строки.Добавить(Ванесса.Локализовать("ошибка чтения вкладок:") + " " + ОписаниеОшибки());
		КонецПопытки;
	Иначе
		Строки.Добавить(Ванесса.Локализовать("Редактор не инициализирован. Загрузите фичи: `load_features`."));
	КонецЕсли;
	Строки.Добавить("");
	
	// Текущий файл и позиция
	Строки.Добавить(Ванесса.Локализовать("## Активный документ"));
	Если Не Ванесса.ОтсутствуетVanessaEditor() Тогда
		Попытка
			Редактор = Ванесса.ПолучитьVanessaEditor();
			
			// Позиция курсора
			Попытка
				Позиция = Редактор.getPosition();
				Если Позиция <> Неопределено Тогда
					Строки.Добавить(Ванесса.Локализовать("- Строка:") + " " + Формат(Позиция.lineNumber, "ЧГ=0; ЧН=0"));
				КонецЕсли;
			Исключение
			КонецПопытки;
			
			// Выбранный сценарий
			СтрокаДерева = Ванесса.СтрокаДереваПоНомеруСтрокиФичи(Позиция.lineNumber);
			ЕстьВыбранныйСценарий = Ложь;
			Если СтрокаДерева <> Неопределено Тогда
				ЭтоПример = Ложь;
				ЭтоШагКонтекста = Ложь;
				СтрокаСценария = Ванесса.НайтиСтрокуСценарияЧерезРодителя(СтрокаДерева, ЭтоПример, ЭтоШагКонтекста);
				Если СтрокаСценария <> Неопределено Тогда
					ЕстьВыбранныйСценарий = Истина;
					Строки.Добавить("");
					Строки.Добавить(Ванесса.Локализовать("### Выбранный сценарий:") + " " + СтрокаСценария.Имя);
				КонецЕсли;	
			КонецЕсли;	
			
			Если НЕ ЕстьВыбранныйСценарий Тогда
				Строки.Добавить("");
				Строки.Добавить(Ванесса.Локализовать("### Выбранный сценарий:") + " " + Ванесса.Локализовать("Нет выбранного сценария. Можно запустить все сценарии на выполнение с помощью"));
			КонецЕсли;
			
			// Все сценарии текущей вкладки
			ВсеСценарии = Ванесса.ПолучитьИменаСценариевПоТекущейФиче();
			Строки.Добавить("");
			Строки.Добавить(Ванесса.Локализовать("### Всего сценариев в файле:") + " " + ВсеСценарии.Количество());
			Строки.Добавить(Ванесса.Локализовать("### Все сценарии из файла:"));
			Для Каждого ТекСценарий Из ВсеСценарии Цикл
				Строки.Добавить("- " + ТекСценарий.Имя);
			КонецЦикла;	
			
			// Содержимое
			Если ВключитьСодержимое Тогда
				Строки.Добавить("");
				Строки.Добавить(Ванесса.Локализовать("### Содержимое"));
				Строки.Добавить("```gherkin");
				Попытка
					Содержимое = Редактор.getContent();
					Если ЗначениеЗаполнено(Содержимое) Тогда
						Строки.Добавить(Содержимое);
					Иначе
						Строки.Добавить(Ванесса.Локализовать("(пустой документ)"));
					КонецЕсли;
				Исключение
					Строки.Добавить(Ванесса.Локализовать("(ошибка чтения:") + " " + ОписаниеОшибки() + ")");
				КонецПопытки;
				Строки.Добавить("```");
			КонецЕсли;
		Исключение
			Строки.Добавить(Ванесса.Локализовать("ошибка доступа к редактору:") + " " + ОписаниеОшибки());
		КонецПопытки;
	Иначе
		Строки.Добавить(Ванесса.Локализовать("Редактор не открыт"));
	КонецЕсли;
	Строки.Добавить("");
	
	// Ошибки
	Строки.Добавить(Ванесса.Локализовать("## Ошибки в редакторе"));
	Попытка
		Если Ванесса.ДанныеОшибокVanessaEditor <> Неопределено И ТипЗнч(Ванесса.ДанныеОшибокVanessaEditor) = Тип("Соответствие") Тогда
			КоличествоОшибок = 0;
			Для Каждого КлючЗначение Из Ванесса.ДанныеОшибокVanessaEditor Цикл
				КоличествоОшибок = КоличествоОшибок + 1;
			КонецЦикла;
			Строки.Добавить(Ванесса.Локализовать("Количество:") + " " + Формат(КоличествоОшибок, "ЧГ=0; ЧН=0"));
			Если КоличествоОшибок > 0 Тогда
				Для Каждого КлючЗначение Из Ванесса.ДанныеОшибокVanessaEditor Цикл
					Строки.Добавить(Ванесса.Локализовать("- Строка") + " " + Формат(КлючЗначение.Значение.НомерСтрокиВФиче, "ЧГ=0; ЧН=0") + ". Текст ошибки: " + КлючЗначение.Значение.КраткйТекстОшибки);
					Строки.Добавить("  " + Ванесса.Локализовать("Имя feature файла где возникла эта ошибка:") + " " + КлючЗначение.Значение.ИмяФичи);
				КонецЦикла;
			КонецЕсли;
		Иначе
			Строки.Добавить(Ванесса.Локализовать("нет ошибок"));
		КонецЕсли;
	Исключение
		Строки.Добавить(Ванесса.Локализовать("ошибка чтения:") + " " + ОписаниеОшибки());
	КонецПопытки;
	
	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

// Выбирает и делает сценарий текущим. После этого можно вызывать выполнение текущего сценария
&НаКлиенте
Функция ВыбратьСценарий(Запрос, ДополнительныеПараметры) Экспорт
	
	ИмяСценария = ЗначениеПараметраИзЗапроса(Запрос, "name");
	Если НЕ ЗначениеЗаполнено(ИмяСценария) Тогда
		ТекстСообщения = Ванесса.Локализовать("Не указан обязательный параметр 'name'");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;	
	
	СценарииФичи = Ванесса.ПолучитьИменаСценариевПоТекущейФиче();
	
	Для Каждого ТекСценарий Из СценарииФичи Цикл
		Если НРег(ТекСценарий.Имя) = НРег(ИмяСценария) Тогда
			
			Ванесса.СделатьСтрокуДереваТекущейПоНомеруСтрокиФичи(ТекСценарий.НомерСтрокиВФиче);
			СтрокаДерева = Ванесса.СтрокаДереваПоНомеруСтрокиФичи(ТекСценарий.НомерСтрокиВФиче);
			Ванесса.МодульРедакторТекста().АктивизироватьСтрокуРедактораПоИдСтрокиИНомеруСтрокиФичи(СтрокаДерева.ИдСтроки, ТекСценарий.НомерСтрокиВФиче);
			
			Идентификатор = Запрос.Идентификатор;
			Ванесса.УстановитьИдентификаторЗадачиMCP(Идентификатор);
			ПодключитьОбработчикОжидания("ЗавершитьВыборСценария", 0.1, Истина);
			Возврат Неопределено;
		КонецЕсли;	
	КонецЦикла;
	
	ТекстСообщения = Ванесса.Локализовать("Не найден сценарий:") + " " + ИмяСценария;
	Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	
КонецФункции

// Выбирает и делает шаг текущим. После этого можно вызывать выполнение с текущего шага
&НаКлиенте
Функция ВыбратьШаг(Запрос, ДополнительныеПараметры) Экспорт
	
	НомерСтроки = ЗначениеПараметраИзЗапроса(Запрос, "lineNumber");
	Если НЕ ЗначениеЗаполнено(НомерСтроки) Тогда
		ТекстСообщения = Ванесса.Локализовать("Не указан обязательный параметр 'lineNumber'");
		Возврат МодульМсп_Сервер().ОшибкаИнструмента("INVALID_PARAMS", ТекстСообщения);
	КонецЕсли;	
	
	СтрокаДерева = Ванесса.СтрокаДереваПоНомеруСтрокиФичи(НомерСтроки);
	Ванесса.МодульРедакторТекста().АктивизироватьСтрокуРедактораПоИдСтрокиИНомеруСтрокиФичи(СтрокаДерева.ИдСтроки, НомерСтроки);
	Идентификатор = Запрос.Идентификатор;
	Ванесса.УстановитьИдентификаторЗадачиMCP(Идентификатор);
	ПодключитьОбработчикОжидания("ЗавершитьВыборШага", 0.1, Истина);
	
КонецФункции

// Вызывается при успешном завершении загрузки фичи/фич
&НаКлиенте
Функция ОповеститьMCP_ОЗавершенииЗагрузкиФичи(ПутьКФайлу, Тип, ДопПараметрыВызоваMCP) Экспорт
	
	Если Тип = "СинтаксКонтроль" Тогда
		ЗавершитьПроверкуСинтаксиса(ПутьКФайлу);
	ИначеЕсли Тип = "ОткрытьФичаФайл" Тогда
		ЗавершитьОткрытиеФичаФайла(ПутьКФайлу);
	ИначеЕсли Тип = "ОткрытьЗагрузитьИлиПерезагрузитьФичаФайл" Тогда
		ЗавершитьОткрытьЗагрузитьИлиПерезагрузитьФичаФайл(ПутьКФайлу, ДопПараметрыВызоваMCP);
	ИначеЕсли Тип = "ВыполнитьОдинШагВФичаФайле" Тогда
		ПродолжитьВыполнениеШагаВРедакторе(ПутьКФайлу, ДопПараметрыВызоваMCP);
	ИначеЕсли Тип = "ВыполнитьСценарий" Тогда
		ПродолжитьВыполнитьСценарий1(ПутьКФайлу, ДопПараметрыВызоваMCP);
	ИначеЕсли Тип = "ЗагрузитьФичуДляВыполненияСценария" Тогда
		ПродолжитьВыполнитьСценарий2(ПутьКФайлу, ДопПараметрыВызоваMCP);
	Иначе
		ТекстИсключения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Не известный тип оповещения MCP после загрузки фичи <%1>"), Тип);
		ВызватьИсключение ТекстИсключения;
	КонецЕсли;	
	
КонецФункции	

// Вызывается при успешном завершении выполнения одной строки фичи
&НаКлиенте
Функция ОповеститьMCP_ОУспешномЗавершенииВыполненияОднойСтрокиФичи(Тип, ДопПараметрыВызоваMCP) Экспорт
	
	Если Тип = "ВыполнитьОдинШагВФичаФайле" Тогда
		ЗавершитьУспешноеВыполнениеШагаВРедакторе(ДопПараметрыВызоваMCP);
	Иначе
		ТекстИсключения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Не известный тип оповещения MCP после выполнения одной строки фичи <%1>"), Тип);
		ВызватьИсключение ТекстИсключения;
	КонецЕсли;	
	
КонецФункции

// Вызывается при окончании выполнения сценариев
&НаКлиенте
Функция ОповеститьMCP_ОЗавершенииВыполненияСценариев(Тип, ДопПараметрыВызоваMCP) Экспорт
	
	Если Тип = "selected" Тогда
		ЗавершитьВыполненияСценария(Тип, ДопПараметрыВызоваMCP);
	ИначеЕсли Тип = "all" Тогда
		ЗавершитьВыполненияСценария(Тип, ДопПараметрыВызоваMCP);
	ИначеЕсли Тип = "reloadAndRun" Тогда
		ЗавершитьВыполненияСценария(Тип, ДопПараметрыВызоваMCP);
	ИначеЕсли Тип = "fromCurrentStep" Тогда
		ЗавершитьВыполненияСценария(Тип, ДопПараметрыВызоваMCP);
	Иначе
		ТекстИсключения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Не известный тип оповещения MCP при завершении выполнения сценариев <%1>"), Тип);
		ВызватьИсключение ТекстИсключения;
	КонецЕсли;	
	
КонецФункции

// Вызывается при ошибке при выполнении одной строки фичи
&НаКлиенте
Функция ОповеститьMCP_ОбОшибкеПриВыполненияОднойСтрокиФичи(Тип, ДопПараметрыВызоваMCP, РезультатПрохожденияШага) Экспорт
	
	Если Тип = "ВыполнитьОдинШагВФичаФайле" Тогда
		ЗавершитьВыполнениеШагаВРедактореСОшибкой(ДопПараметрыВызоваMCP, РезультатПрохожденияШага);
	Иначе
		ТекстИсключения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Не известный тип оповещения MCP <%1>"), Тип);
		ВызватьИсключение ТекстИсключения;
	КонецЕсли;	
	
КонецФункции

// Вызывается при ошибке выполнения выделенного сценария
&НаКлиенте
Функция ОповеститьMCP_ОбОшибкеВыполненияВыделенногоСценария(ДопПараметрыВызоваMCP, ТекстОшибки) Экспорт
	
	МодульМсп_Сервер().ЗавершитьВызовИнструментаУспешно(Ванесса.ПолучитьИдентификаторЗадачиMCP(), ТекстОшибки);
	Ванесса.УстановитьИдентификаторЗадачиMCP(Неопределено);
	
КонецФункции

// Вызывается при завершении выполнения шага строкой в MCPИнструментВыполнитьОдинШагТекстом
&НаКлиенте
Процедура ЗавершениеВыполнениеШагаИзСтроки() Экспорт
	МодульМсп_Сервер = МодульМсп_Сервер();
	ТекстСообщения = Ванесса.Локализовать("Шаг выполнен успешно");
	МодульМсп_Сервер.ЗавершитьВызовИнструментаУспешно(Ванесса.ПолучитьИдентификаторЗадачиMCP(), ТекстСообщения);
	Ванесса.УстановитьИдентификаторЗадачиMCP(Неопределено);
КонецПроцедуры

