	Если ТипЗнч(ИсходнаяСтруктура) = Тип("Структура") Тогда
		Значение = Неопределено;
		Если ИсходнаяСтруктура.Свойство(ИмяСвойства, Значение) Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЕсли;
	Возврат Неопределено;
	
КонецФункции

