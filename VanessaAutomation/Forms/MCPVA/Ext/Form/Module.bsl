		Истина)// Это асинхронный инструмент
		); 
		
	КонецПроцедуры
	
&НаКлиенте
Функция MCPНормализоватьПутьКФичаФайлу(Путь)
	
	Если Не ЗначениеЗаполнено(Путь) Тогда
		ВызватьИсключение Ванесса.Локализовать("Не указан путь к .feature файлу.");
	КонецЕсли;
	
	НормализованныйПуть = Ванесса.ПреобразоватьПутьСТочкамиКНормальномуПути(Строка(Путь));
	Если Не ЗначениеЗаполнено(НормализованныйПуть) Тогда
		ВызватьИсключение Ванесса.Локализовать("Не удалось определить путь к .feature файлу.");
	КонецЕсли;
	
	Если Не Ванесса.ФайлСуществуетКомандаСистемы(НормализованныйПуть) Тогда
		ВызватьИсключение Ванесса.Локализовать("Файл не найден: ") + НормализованныйПуть;
	КонецЕсли;
	
	Если Ванесса.ЭтоКаталогКомандаСистемы(НормализованныйПуть) Тогда
		ВызватьИсключение Ванесса.Локализовать("Ожидался путь к .feature файлу, а не к каталогу: ") + НормализованныйПуть;
	КонецЕсли;
	
	Возврат НормализованныйПуть;
	
КонецФункции

&НаКлиенте
Процедура MCPOpenFeatureFileВРедакторе(ИмяФайла)
	
	МодульМсп_Сервер = Вычислить("Мсп_Сервер");
	Если Не Ванесса.Объект.ИспользоватьРедакторVanessaEditor Тогда
		МодульМсп_Сервер.ЗавершитьЗадачуСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", Ванесса.Локализовать("Vanessa Editor отключен в настройках Vanessa Automation."));
		Возврат;
	КонецЕсли;
	
	Если Ванесса.VanessaTabs = Неопределено Тогда
		МодульМсп_Сервер.ЗавершитьЗадачуСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", Ванесса.Локализовать("Редактор Vanessa Editor не инициализирован."));
		Возврат;
	КонецЕсли;
	
	Если Ванесса.МодульРедакторТекста().СуществуетВкладкаСФайлом(ИмяФайла) Тогда
		Ванесса.МодульРедакторТекста().АктивизироватьВкладкуПоИмениФайла(ИмяФайла);
	КонецЕсли;
	
	Ванесса.Объект.КаталогФич = ИмяФайла;
	Ванесса.УстановитьФлагОповеститьMCPСерверПослеЗагрузкиФичи("СинтаксКонтроль");
	Ванесса.ЗагрузитьФичи();
	
КонецПроцедуры

&НаКлиенте
Функция MCPСформироватьMarkdownПроверкиСинтаксиса(Данные)
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Проверка синтаксиса Gherkin"));
	Строки.Добавить("");
	Если Данные["filePath"] <> Неопределено Тогда
		Строки.Добавить(Ванесса.Локализовать("- Файл: ") + MCPПредставлениеЗначенияДляMarkdown(Данные["filePath"]));
	КонецЕсли;
	Строки.Добавить(Ванесса.Локализовать("- Синтаксис корректен: ") + MCPПредставлениеЗначенияДляMarkdown(Данные["valid"]));
	Строки.Добавить(Ванесса.Локализовать("- Количество проблем: ") + MCPПредставлениеЗначенияДляMarkdown(Данные["problemCount"]));
	Строки.Добавить("");

	Если Данные["problemCount"] = 0 Тогда
		Строки.Добавить(Ванесса.Локализовать("Проблем не найдено."));
		Возврат СтрСоединить(Строки, Символы.ПС);
	КонецЕсли;

	Строки.Добавить(Ванесса.Локализовать("## Найденные проблемы"));
	Строки.Добавить("");

	НомерПроблемы = 0;
	Для Каждого Проблема Из Данные["problems"] Цикл
		НомерПроблемы = НомерПроблемы + 1;
		СтрокаПроблемы = Строка(НомерПроблемы) + ". ";
		Если Проблема["line"] <> Неопределено Тогда
			СтрокаПроблемы = СтрокаПроблемы + Ванесса.Локализовать("Строка ") + Строка(Проблема["line"]) + ": ";
		КонецЕсли;
		СтрокаПроблемы = СтрокаПроблемы + MCPПредставлениеЗначенияДляMarkdown(Проблема["message"]);
		Строки.Добавить(СтрокаПроблемы);
	КонецЦикла;

	Возврат СтрСоединить(Строки, Символы.ПС);

КонецФункции

&НаКлиенте
Функция MCPТекущийФайлРедактора()
	
	Если Ванесса.VanessaTabs <> Неопределено И Ванесса.VanessaTabs.current <> Неопределено Тогда
		Возврат Ванесса.VanessaTabs.current.filename;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаКлиенте
Процедура ЗавершитьПроверкуСинтаксиса(ПутьКФайлу)
	
	// Запускаем проверку синтаксиса
	Попытка
		Ванесса.МодульРедакторТекста().VanessaEditorПроверкаСинтаксисаВРедакторе(Неопределено);
	Исключение
	КонецПопытки;
	
	// Читаем найденные проблемы
	МассивПроблем = Новый Массив;
	Попытка
		Проблемы = Ванесса.НайденныеПроблемы();
		Если Проблемы <> Неопределено Тогда
			Для Каждого Проблема Из Проблемы Цикл
				ПроблемаJSON = Новый Структура;
				Если ТипЗнч(Проблема) = Тип("Структура") Тогда
					ПроблемаJSON.Вставить("line", MCPБезопасноеСвойство(Проблема, "НомерСтроки"));
					ПроблемаJSON.Вставить("message", MCPБезопасноеСвойство(Проблема, "Текст"));
				ИначеЕсли ТипЗнч(Проблема) = Тип("Соответствие") Тогда
					ЗначениеСтроки = Проблема["НомерСтроки"];
					Если ЗначениеСтроки = Неопределено Тогда
						ЗначениеСтроки = Проблема["line"];
					КонецЕсли;
					ПроблемаJSON.Вставить("line", ЗначениеСтроки);
					ЗначениеТекста = Проблема["Текст"];
					Если ЗначениеТекста = Неопределено Тогда
						ЗначениеТекста = Проблема["message"];
					КонецЕсли;
					ПроблемаJSON.Вставить("message", ЗначениеТекста);
				Иначе
					ПроблемаJSON.Вставить("message", Строка(Проблема));
				КонецЕсли;
				МассивПроблем.Добавить(ПроблемаJSON);
			КонецЦикла;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Результат = Новый Структура;
	Результат.Вставить("valid", МассивПроблем.Количество() = 0);
	Результат.Вставить("problemCount", МассивПроблем.Количество());
	Результат.Вставить("problems", МассивПроблем);
	Результат.Вставить("filePath", ПутьКФайлу);
	
	СтрокаРезультат = MCPСформироватьMarkdownПроверкиСинтаксиса(Результат);
	
	Результат = Новый Структура(
		"message,completedAt",
		СтрокаРезультат,
		Строка(ТекущаяДата()));
		
	МодульМсп_Сервер = Вычислить("Мсп_Сервер");
	МодульМсп_Сервер.ЗавершитьЗадачуУспешно(Ванесса.ПолучитьИдентификаторЗадачиMCP(), Результат);
	Ванесса.УстановитьИдентификаторЗадачиMCP(Неопределено);
	
КонецПроцедуры

#КонецОбласти