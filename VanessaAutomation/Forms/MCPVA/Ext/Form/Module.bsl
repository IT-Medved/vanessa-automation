	МодульМсп_Сервер = МодульМсп_Сервер();
	МодульМсп_Сервер.ЗавершитьВызовИнструментаУспешно(Ванесса.ПолучитьИдентификаторЗадачиMCP(), ТекстОтвета);
	Ванесса.УстановитьИдентификаторЗадачиMCP(Неопределено);
	
