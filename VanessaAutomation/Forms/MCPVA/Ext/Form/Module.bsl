&НаКлиенте
Процедура ЗавершитьВыполненияСценария(Тип, ДопПараметрыВызоваMCP)
	
	МассивРезультатПрохожденияТестовСценария = Ванесса.ПолучитьМассивРезультатПрохожденияТестовСценария();
	БылиОшибки = Ложь;
	Для Каждого ДанныеСценария Из МассивРезультатПрохожденияТестовСценария Цикл
		Если ДанныеСценария.Свойство("ОписаниеОшибки") И ЗначениеЗаполнено(ДанныеСценария.ОписаниеОшибки) Тогда
			БылиОшибки = Истина;
			Прервать;
		КонецЕсли;	
	КонецЦикла;	
	
	МассивСтрок = Новый Массив;
	Если БылиОшибки Тогда
		ТекстСтроки = Ванесса.Локализовать("## Результат выполнения сценариев: были ошибки");
	Иначе	
		ТекстСтроки = Ванесса.Локализовать("## Результат выполнения сценариев: все сценарии выполнены успешно");
	КонецЕсли;	
	МассивСтрок.Добавить(ТекстСтроки);
	МассивСтрок.Добавить("");
	
	Для Каждого ДанныеСценария Из МассивРезультатПрохожденияТестовСценария Цикл
		СтрокаСценария = Ванесса.СтрокаДереваПоИдСтроки(ДанныеСценария.ИДСтроки);
		
		ТекстСтроки = Ванесса.Локализовать("Имя сценария:" + " " + СтрокаСценария.Имя);
		МассивСтрок.Добавить(ТекстСтроки);
		ТекстСтроки = Ванесса.Локализовать("Результат прохождения сценнария:") + " " + ДанныеСценария.Статус;
		МассивСтрок.Добавить(ТекстСтроки);
		
		Если ДанныеСценария.Свойство("ОписаниеОшибки") И ЗначениеЗаполнено(ДанныеСценария.ОписаниеОшибки) Тогда
			БылиОшибки = Истина;
			СтрокаУпавшегоШага = Ванесса.СтрокаДереваПоИдСтроки(ДанныеСценария.ДанныеДляФормированияJsonОбОшибке.ИДСтрокиУпавшегоШага);
			ТекстСтроки = Ванесса.Локализовать("Текст упавшего шага:") + " " + СтрокаУпавшегоШага.Имя;
			МассивСтрок.Добавить(ТекстСтроки);
			ТекстСтроки = Ванесса.Локализовать("Статус упавшего шага:") + " " + СтрокаУпавшегоШага.Статус;
			МассивСтрок.Добавить(ТекстСтроки);
			ТекстСтроки = Ванесса.Локализовать("Текст ошибки:") + " " + ДанныеСценария.ДанныеДляФормированияJsonОбОшибке.ОписаниеОшибкиКратко;
			МассивСтрок.Добавить(ТекстСтроки);
			МассивСтрок.Добавить("");
			МассивСтрок.Добавить("");
		КонецЕсли;	
		
	КонецЦикла;	
	
	МодульМсп_Сервер().ЗавершитьВызовИнструментаУспешно(Ванесса.ПолучитьИдентификаторЗадачиMCP(), Ванесса._СтрСоединить(МассивСтрок));
	Ванесса.УстановитьИдентификаторЗадачиMCP(Неопределено);
	Ванесса.УстановитьФлагОповеститьMCPСерверПослеВыполненияСценариев(Неопределено, Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура ПослеСделатьПереходкКТекстуВРедакторе()
	НомерСтроки = глДопПараметрыВызоваMCP.НомерСтроки;
	ПутьКФайлу = глДопПараметрыВызоваMCP.ПутьКФайлу;
	
	ЭкземплярVanessaEditor = Ванесса.ПолучитьVanessaEditor();
	ТекстСтроки = ЭкземплярVanessaEditor.getLineContent(НомерСтроки);
	
	Если НЕ ЗначениеЗаполнено(ТекстСтроки) Тогда
		ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Строка %1 пуста в файле: %2"),
				НомерСтроки, ПутьКФайлу);
		МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	Ванесса.УстановитьФлагОповеститьMCPСерверПослеВыполненияОднойСтрокиФичи(глДопПараметрыВызоваMCP.Тип);
	Ванесса.ВыполнитьОдинШаг();
	
	// Вызов вернётся в ОповеститьMCP_ОЗавершенииВыполненияОднойСтрокиФичи
	
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьУспешноеВыполнениеШагаВРедакторе(ДопПараметрыВызоваMCP)
	ТекстСообщения = Ванесса.Локализовать("Шаг в строке фича файла успешно выполнен");
	МодульМсп_Сервер().ЗавершитьВызовИнструментаУспешно(Ванесса.ПолучитьИдентификаторЗадачиMCP(), ТекстСообщения);
	Ванесса.УстановитьИдентификаторЗадачиMCP(Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьВыполнениеШагаВРедактореСОшибкой(ДопПараметрыВызоваMCP, РезультатПрохожденияШага)
	ТекстСообщения = ТекстОшибкиИзОписанияОшибки(РезультатПрохожденияШага.ОписаниеОшибки);
	МодульМсп_Сервер().ЗавершитьВызовИнструментаУспешно(Ванесса.ПолучитьИдентификаторЗадачиMCP(), ТекстСообщения);
	Ванесса.УстановитьИдентификаторЗадачиMCP(Неопределено);
КонецПроцедуры

&НаКлиенте
Функция ОткрытиеФичаФайлаВРедакторе(ПутьКФайлу, Запрос, ТипВызова, ДопПараметрыВызоваMCP = Неопределено)
	
	Если ЗначениеЗаполнено(ПутьКФайлу) Тогда
		Если НЕ Ванесса.ФайлСуществуетКомандаСистемы(ПутьКФайлу) Тогда
			
			ПолныйПутьКФайлуВКаталогеПроекта = Ванесса.ДополнитьСлешВПуть(Ванесса.Объект.КаталогПроекта) + ПутьКФайлу;
			Если НЕ Ванесса.ФайлСуществуетКомандаСистемы(ПолныйПутьКФайлуВКаталогеПроекта) Тогда
				МодульМсп_Сервер = МодульМсп_Сервер();
				ТекстОшибки = Ванесса.Локализовать("Файл <%1> не был найден.");
				Если НЕ Ванесса.ЭтоLinux И Найти(ПутьКФайлу, ":") = 0 Тогда
					ТекстОшибки = Ванесса.Локализовать("Файл <%1> не был найден. В каталоге проекта файл <%2> тоже не был найден. Видимо был передан относительный путь, попробуйте передать полный путь к файлу.");
				КонецЕсли;
				
				ТекстОшибки = Ванесса.ПодставитьПараметрыВСтроку(ТекстОшибки, ПутьКФайлу, ПолныйПутьКФайлуВКаталогеПроекта);
				Возврат МодульМсп_Сервер.ОшибкаИнструмента("INVALID_PARAMS", ТекстОшибки);
			Иначе
				ПутьКФайлу = ПолныйПутьКФайлуВКаталогеПроекта;
			КонецЕсли;	
			
		КонецЕсли;	
		ПутьКФайлу = MCPНормализоватьПутьКФичаФайлу(ПутьКФайлу);
		
		МодульМсп_Сервер = МодульМсп_Сервер();
		Идентификатор = Запрос.Идентификатор;
		Ванесса.УстановитьИдентификаторЗадачиMCP(Идентификатор);
		МодульМсп_Сервер.УведомитьОПрогрессе(Идентификатор, 0, 3, Ванесса.Локализовать("Загрузка feature файла."));
		
		MCPOpenFeatureFileВРедакторе(ПутьКФайлу, ТипВызова, ДопПараметрыВызоваMCP);
	Иначе
		Возврат МодульМсп_Сервер.ОшибкаИнструмента("INVALID_PARAMS", Ванесса.Локализовать("Не передан путь к файлу."));
	КонецЕсли;
	
КонецФункции	

