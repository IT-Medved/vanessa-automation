Процедура MCPИнструментПолучитьРеквизитыОбъекта(ПараметрыСозданияMCP)
	
    Свойства = Новый Структура;
	
	Описание_data_mode = Ванесса.Локализовать("Режим получения данных: 'all' (все данные - шапка и табличные части), 'attributes_only' (только реквизиты шапки), 'single_attribute' (значение указанного реквизита шапки), 'tabular_sections_only' (только все табличные части), 'single_tabular_section' (только указанная табличная часть). По умолчанию 'all'.");
    Свойства.Вставить("data_mode", ПараметрыСозданияMCP.МодульМсп_СхемаПараметров.НовыйСвойствоСхемы("string", Описание_data_mode));
	
	Описание_attribute_name = Ванесса.Локализовать("Имя реквизита шапки для получения значения. Используется только при data_mode='single_attribute'. Обязательный параметр для этого режима.");
    Свойства.Вставить("attribute_name", ПараметрыСозданияMCP.МодульМсп_СхемаПараметров.НовыйСвойствоСхемы("string", Описание_attribute_name));
	
	Описание_tabular_section_name = Ванесса.Локализовать("Имя табличной части для получения данных. Используется только при data_mode='single_tabular_section'. Обязательный параметр для этого режима.");
    Свойства.Вставить("tabular_section_name", ПараметрыСозданияMCP.МодульМсп_СхемаПараметров.НовыйСвойствоСхемы("string", Описание_tabular_section_name));
	
	Описание_only_filled = Ванесса.Локализовать("Возвращать только заполненные реквизиты: true (только заполненные), false (все реквизиты, по умолчанию). Параметр не применяется при получении одного реквизита (data_mode='single_attribute').");
    Свойства.Вставить("only_filled", ПараметрыСозданияMCP.МодульМсп_СхемаПараметров.НовыйСвойствоСхемы("boolean", Описание_only_filled));
	
    ТребуемыеПоля = Новый Массив;
    Схема = ПараметрыСозданияMCP.МодульМсп_СхемаПараметров.НовыйСхемаОбъекта(Свойства, ТребуемыеПоля);
	ПараметрыСозданияMCP.МодульМсп_Сервер.ЗарегистрироватьИнструмент(ПараметрыСозданияMCP.МодульМсп_Сервер.НовыйИнструмент(
        "get_object_attributes",
        Ванесса.Локализовать("Получает значения реквизитов объекта (и их тип), связанного с открытой формой. Работает только для форм объектов (Справочники, Документы и т.п.), не работает для форм списков и служебных форм.
		|Параметр data_mode определяет состав возвращаемых данных:
		|- 'all' - все данные (реквизиты шапки и все табличные части)
		|- 'attributes_only' - только реквизиты шапки
		|- 'single_attribute' - только значение указанного реквизита шапки (требуется attribute_name)
		|- 'tabular_sections_only' - только все табличные части
		|- 'single_tabular_section' - только указанная табличная часть (требуется tabular_section_name)
		|
		|Параметр only_filled определяет фильтровать ли пустые реквизиты:
		|- true - возвращать только заполненные реквизиты
		|- false - возвращать все реквизиты (по умолчанию)
		|
		|Возвращает данные в формате Markdown с именами, типами и значениями реквизитов."),
        Схема,
        Новый ОписаниеОповещения("ПолучитьРеквизитыОбъекта", Вычислить("ЭтотОбъект")),
		Ложь),
	    ИмяПровайдера());
		
