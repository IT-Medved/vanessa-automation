Функция MCPСформироватьMarkdownСостоянияVA(Данные)
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Состояние Vanessa Automation"));
	Строки.Добавить("");
	Строки.Добавить(Ванесса.Локализовать("- Выполнение сценариев:") + " " + MCPПредставлениеЗначенияДляMarkdown(Данные["isRunning"]));
	Строки.Добавить(Ванесса.Локализовать("- Клиент тестирования подключен:") + " " + MCPПредставлениеЗначенияДляMarkdown(Данные["testClientConnected"]));
	Если Данные["testClientConnected"] Тогда
		Строки.Добавить(Ванесса.Локализовать("  " + "- Имя профиля клиента тестирования:") + " " + MCPПредставлениеЗначенияДляMarkdown(Данные["ИмяПрофиляКлиентаТестирования"]));
	КонецЕсли;	
	Строки.Добавить(Ванесса.Локализовать("- Каталог фич:") + " " + MCPПредставлениеЗначенияДляMarkdown(Данные["featureDirectory"]));
	Строки.Добавить("");

	Строки.Добавить(Ванесса.Локализовать("## Текущая фича"));
	Строки.Добавить(MCPСформироватьMarkdownРазделСвойств(Данные["currentFeature"]));
	Строки.Добавить("");

	Строки.Добавить(Ванесса.Локализовать("## Текущий сценарий"));
	Строки.Добавить(MCPСформироватьMarkdownРазделСвойств(Данные["currentScenario"]));
	Строки.Добавить("");

	Строки.Добавить(Ванесса.Локализовать("## Текущий шаг"));
	Строки.Добавить(MCPСформироватьMarkdownРазделСвойств(Данные["currentStep"]));
	
	// Подсказки, если ничего не загружено
	ФичаПуста = Данные["currentFeature"] = Неопределено
		ИЛИ (ТипЗнч(Данные["currentFeature"]) = Тип("Структура")
			И (НЕ Данные["currentFeature"].Свойство("name")
				ИЛИ Данные["currentFeature"]["name"] = Неопределено
				ИЛИ СокрЛП(Строка(Данные["currentFeature"]["name"])) = ""));
	СценарийПуст = Данные["currentScenario"] = Неопределено
		ИЛИ (ТипЗнч(Данные["currentScenario"]) = Тип("Структура")
			И (НЕ Данные["currentScenario"].Свойство("name")
				ИЛИ Данные["currentScenario"]["name"] = Неопределено
				ИЛИ СокрЛП(Строка(Данные["currentScenario"]["name"])) = ""));
	Если ФичаПуста И СценарийПуст Тогда
		Строки.Добавить("");
		Строки.Добавить(Ванесса.Локализовать("## Следующие шаги"));
		Строки.Добавить(Ванесса.Локализовать("- Загрузите фичи: `load_features`"));
		Строки.Добавить(Ванесса.Локализовать("- Подключите клиента тестирования: `connect_test_client`"));
	КонецЕсли;

	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);

КонецФункции

&НаКлиенте
Функция MCPПредставлениеЗначенияДляMarkdown(Значение)
	Если Значение = Неопределено Тогда
		Возврат Ванесса.Локализовать("не указано");
	КонецЕсли;

	Если ТипЗнч(Значение) = Тип("Булево") Тогда
		Если Значение Тогда
			Возврат Ванесса.Локализовать("да");
		КонецЕсли;
		Возврат Ванесса.Локализовать("нет");
	КонецЕсли;

	Если ТипЗнч(Значение) = Тип("Массив") Тогда
		Если Значение.Количество() = 0 Тогда
			Возврат Ванесса.Локализовать("не указано");
		КонецЕсли;

		Строки = Новый Массив;
		Для Каждого Элемент Из Значение Цикл
			Строки.Добавить(MCPПредставлениеЗначенияДляMarkdown(Элемент));
		КонецЦикла;
		Возврат Ванесса._СтрСоединить(Строки, ", ");
	КонецЕсли;

	Если ТипЗнч(Значение) = Тип("Структура") Тогда
		Строки = Новый Массив;
		Для Каждого КлючЗначение Из Значение Цикл
			Строки.Добавить(КлючЗначение.Ключ + ": " + MCPПредставлениеЗначенияДляMarkdown(КлючЗначение.Значение));
		КонецЦикла;
		Если Строки.Количество() = 0 Тогда
			Возврат Ванесса.Локализовать("не указано");
		КонецЕсли;
		Возврат Ванесса._СтрСоединить(Строки, "; ");
	КонецЕсли;

	Если ТипЗнч(Значение) = Тип("Соответствие") Тогда
		Строки = Новый Массив;
		Для Каждого КлючЗначение Из Значение Цикл
			Строки.Добавить(MCPПредставлениеЗначенияДляMarkdown(КлючЗначение.Ключ) + ": " + MCPПредставлениеЗначенияДляMarkdown(КлючЗначение.Значение));
		КонецЦикла;
		Если Строки.Количество() = 0 Тогда
			Возврат Ванесса.Локализовать("не указано");
		КонецЕсли;
		Возврат Ванесса._СтрСоединить(Строки, "; ");
	КонецЕсли;

	Возврат Строка(Значение);

КонецФункции

&НаКлиенте
Функция MCPСформироватьMarkdownРазделСвойств(ДанныеРаздела)
	Если ДанныеРаздела = Неопределено Тогда
		Возврат Ванесса.Локализовать("Данные отсутствуют.");
	КонецЕсли;

	Если ТипЗнч(ДанныеРаздела) <> Тип("Структура") Тогда
		Возврат MCPПредставлениеЗначенияДляMarkdown(ДанныеРаздела);
	КонецЕсли;

	Строки = Новый Массив;
	Для Каждого КлючЗначение Из ДанныеРаздела Цикл
		Строки.Добавить("- " + КлючЗначение.Ключ + ": " + MCPПредставлениеЗначенияДляMarkdown(КлючЗначение.Значение));
	КонецЦикла;

	Если Строки.Количество() = 0 Тогда
		Возврат Ванесса.Локализовать("Данные отсутствуют.");
	КонецЕсли;

	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);

КонецФункции

&НаКлиенте
Функция ПоискШаговПоСтрокеMCP(search_name, exclude_name, search_description, exclude_description, search_type, exclude_type, limit, ТолькоЦиклы, ТолькоУсловия)
	МодульМсп_Сервер = МодульМсп_Сервер();
	
	Массив_search_name = MCPПодготовитьВариантыТочногоПоиска(search_name);
	Массив_exclude_name = MCPПодготовитьВариантыТочногоПоиска(exclude_name);
	Массив_search_description = MCPПодготовитьВариантыТочногоПоиска(search_description);
	Массив_exclude_description = MCPПодготовитьВариантыТочногоПоиска(exclude_description);
	Массив_search_type = MCPПодготовитьВариантыТочногоПоиска(search_type);
	Массив_exclude_type = MCPПодготовитьВариантыТочногоПоиска(exclude_type);
	
	СтрокаСообщения = Ванесса.Локализовать("Поиск шагов с отбором:
	|search_name=%1
	|exclude_name=%2
	|search_description=%3
	|exclude_description=%4
	|search_type=%5
	|exclude_type=%6
	|limit=%7");
	СтрокаСообщения = Ванесса.ПодставитьПараметрыВСтроку(СтрокаСообщения, search_name, exclude_name, search_description, exclude_description, search_type, exclude_type, limit);
	Ванесса.СообщитьПользователю(СтрокаСообщения);
	Ванесса.ЗаписатьЛогВЖРИнформация("ПоискШаговПоСтрокеMCP", СтрокаСообщения);
	
	Лимит = 50;
	Если limit <> Неопределено Тогда
		Попытка
			ПромЛимит = Число(limit);
			Если ПромЛимит <> 0 Тогда
				Лимит = ПромЛимит;
			КонецЕсли;	
		Исключение
		КонецПопытки;
	КонецЕсли;

	Если Лимит < 0 Тогда
		Возврат МодульМсп_Сервер.ОшибкаИнструмента("INVALID_PARAMS", Ванесса.Локализовать("Параметр limit не может быть отрицательным. Используйте 0, чтобы вернуть все результаты."));
	КонецЕсли;
	
	МассивШагов = Новый Массив;
	МножествоКатегорий = Новый Соответствие;
	Счетчик = 0;
	
	Для Каждого СтрокаТаблицы Из Ванесса.ТаблицаИзвестныхStepDefinition Цикл
		
		Если ТолькоЦиклы Тогда
			Если НРег(СтрокаТаблицы.ТипШагаВДереве) <> "цикл" Тогда
				Продолжить;
			КонецЕсли;	
		КонецЕсли;	
		Если ТолькоУсловия Тогда
			Если НРег(СтрокаТаблицы.ТипШагаВДереве) <> "условие" Тогда
				Продолжить;
			КонецЕсли;	
		КонецЕсли;	
		
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ТипШага) Тогда
			// Значит это служебный шаг
			Продолжить;
		КонецЕсли;	
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ОписаниеШага) Тогда
			// Значит это служебный шаг
			Продолжить;
		КонецЕсли;	
		Если Найти(НРег(СтрокаТаблицы.ТипШага), "устаревшее") Тогда
			// Значит это устаревший шаг
			Продолжить;
		КонецЕсли;	
		
		// Исключения:
		// Имя, описание, тип
		Если Массив_exclude_name.Количество() > 0 И НайденоВхождениеЗначенияВМассиве(Массив_exclude_name, НРег(СтрокаТаблицы.ПредставлениеТеста)) Тогда
			Продолжить;
		КонецЕсли;
		Если Массив_exclude_description.Количество() > 0 И НайденоВхождениеЗначенияВМассиве(Массив_exclude_description, НРег(СтрокаТаблицы.ОписаниеШага)) Тогда
			Продолжить;
		КонецЕсли;
		Если Массив_exclude_type.Количество() > 0 И НайденоВхождениеЗначенияВМассиве(Массив_exclude_type, НРег(СтрокаТаблицы.ТипШага)) Тогда
			Продолжить;
		КонецЕсли;

		НадоПродолжить = Истина;
		
		Если Массив_search_name.Количество() = 0 И Массив_search_description.Количество() = 0 И Массив_search_type.Количество() = 0 Тогда
			// Значит не нужно делать отбор
			НадоПродолжить = Ложь;
		КонецЕсли;	
		
		// Фильтр по вхождению
		// Имя, описание, тип
		Если (Массив_search_name.Количество() > 0 И НайденоВхождениеЗначенияВМассиве(Массив_search_name, НРег(СтрокаТаблицы.ПредставлениеТеста)))
			ИЛИ (Массив_search_description.Количество() > 0 И НайденоВхождениеЗначенияВМассиве(Массив_search_description, НРег(СтрокаТаблицы.ОписаниеШага)))
			ИЛИ Массив_search_type.Количество() > 0 И НайденоВхождениеЗначенияВМассиве(Массив_search_type, НРег(СтрокаТаблицы.ТипШага))
			Тогда
			НадоПродолжить = Ложь;
		КонецЕсли;
		Если НадоПродолжить Тогда
			Продолжить;
		КонецЕсли;	
		
		// Собираем категории
		Если ЗначениеЗаполнено(СтрокаТаблицы.ТипШага) Тогда
			МножествоКатегорий.Вставить(СтрокаТаблицы.ТипШага, Истина);
		КонецЕсли;
		
		// Лимит
		Счетчик = Счетчик + 1;
		Если Лимит > 0 И Счетчик > Лимит Тогда
			Продолжить; // Продолжаем считать категории, но не добавляем шаги
		КонецЕсли;
		
		ШагJSON = Новый Структура;
		ШагJSON.Вставить("name", СтрокаТаблицы.ПредставлениеТеста);
		ШагJSON.Вставить("description", СтрокаТаблицы.ОписаниеШага);
		ШагJSON.Вставить("category", СтрокаТаблицы.ТипШага);
		ШагJSON.Вставить("snippet", СтрокаТаблицы.Id);
		ШагJSON.Вставить("searchString", СтрокаТаблицы.СтрокаДляПоиска);
		ШагJSON.Вставить("sourceFile", СтрокаТаблицы.ИмяФайла);
		ШагJSON.Вставить("type", СтрокаТаблицы.ТипШага);
		
		МассивШагов.Добавить(ШагJSON);
		
	КонецЦикла;
	
	// Собираем список категорий
	МассивКатегорий = Новый Массив;
	Для Каждого КлючЗначение Из МножествоКатегорий Цикл
		МассивКатегорий.Добавить(КлючЗначение.Ключ);
	КонецЦикла;
	
	Результат = Новый Структура;
	Результат.Вставить("totalFound", Счетчик);
	Результат.Вставить("categories", МассивКатегорий);
	Результат.Вставить("steps", МассивШагов);
	Результат.Вставить("search_name", СокрЛП(search_name));
	Результат.Вставить("exclude_name", СокрЛП(exclude_name));
	Результат.Вставить("search_description", СокрЛП(search_description));
	Результат.Вставить("exclude_description", СокрЛП(exclude_description));
	Результат.Вставить("search_type", СокрЛП(search_type));
	Результат.Вставить("exclude_type", СокрЛП(exclude_type));
	Результат.Вставить("limit", Лимит);
	
	Возврат MCPСформироватьMarkdownРезультатаПоискаШагов(Результат);
	
КонецФункции	

&НаКлиенте
Функция MCPПодготовитьВариантыТочногоПоиска(ТекстЗапроса)
	ВариантыЗапроса = Новый Массив;
	Если Не ЗначениеЗаполнено(ТекстЗапроса) Тогда
		Возврат ВариантыЗапроса;
	КонецЕсли;

	Для Каждого ЧастьЗапроса Из Ванесса._СтрРазделить(ТекстЗапроса, "|") Цикл
		НормализованнаяЧасть = НРег(СокрЛП(Строка(ЧастьЗапроса)));
		Если ЗначениеЗаполнено(НормализованнаяЧасть) Тогда
			ВариантыЗапроса.Добавить(НормализованнаяЧасть);
		КонецЕсли;
	КонецЦикла;

	Возврат ВариантыЗапроса;

КонецФункции

&НаКлиенте
Функция НайденоВхождениеЗначенияВМассиве(Массив, Значение)
	
	Для Каждого Стр Из Массив Цикл
		Если Найти(Значение, Стр) > 0 Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
