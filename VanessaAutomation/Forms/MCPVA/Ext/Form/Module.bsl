    Свойства = Новый Структура;
	Описание_profileName = Ванесса.Локализовать("Имя профиля клиента тестирования.");
    Свойства.Вставить("profileName", ПараметрыСозданияMCP.МодульМсп_СхемаПараметров.НовыйСвойствоСхемы("string", Описание_profileName));
	
