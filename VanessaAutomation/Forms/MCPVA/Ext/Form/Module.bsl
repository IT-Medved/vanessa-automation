&НаКлиенте
Функция MCPНормализоватьПутьКФичаФайлу(Путь)
	
	Если Не ЗначениеЗаполнено(Путь) Тогда
		ВызватьИсключение Ванесса.Локализовать("Не указан путь к .feature файлу.");
	КонецЕсли;
	
	НормализованныйПуть = Ванесса.ПреобразоватьПутьСТочкамиКНормальномуПути(Строка(Путь));
	Если Не ЗначениеЗаполнено(НормализованныйПуть) Тогда
		ВызватьИсключение Ванесса.Локализовать("Не удалось определить путь к .feature файлу.");
	КонецЕсли;
	
	Если Не Ванесса.ФайлСуществуетКомандаСистемы(НормализованныйПуть) Тогда
		ВызватьИсключение Ванесса.Локализовать("Файл не найден:") + " " + НормализованныйПуть;
	КонецЕсли;
	
	Если Ванесса.ЭтоКаталогКомандаСистемы(НормализованныйПуть) Тогда
		ВызватьИсключение Ванесса.Локализовать("Ожидался путь к .feature файлу, а не к каталогу:") + " " + НормализованныйПуть;
	КонецЕсли;
	
	Возврат НормализованныйПуть;
	
КонецФункции

&НаКлиенте
Процедура MCPOpenFeatureFileВРедакторе(ИмяФайла, ТипВызова, ДопПараметрыВызоваMCP = Неопределено)
	
	МодульМсп_Сервер = МодульМсп_Сервер();
	Если Не Ванесса.Объект.ИспользоватьРедакторVanessaEditor Тогда
		МодульМсп_Сервер.ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", Ванесса.Локализовать("Vanessa Editor отключен в настройках Vanessa Automation."));
		Возврат;
	КонецЕсли;
	
	Если Ванесса.VanessaTabs = Неопределено Тогда
		МодульМсп_Сервер.ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", Ванесса.Локализовать("Редактор Vanessa Editor не инициализирован."));
		Возврат;
	КонецЕсли;
	
	Если Ванесса.МодульРедакторТекста().СуществуетВкладкаСФайлом(ИмяФайла) Тогда
		Ванесса.МодульРедакторТекста().АктивизироватьВкладкуПоИмениФайла(ИмяФайла);
	КонецЕсли;
	
	Ванесса.Объект.КаталогФич = ИмяФайла;
	Ванесса.УстановитьФлагОповеститьMCPСерверПослеЗагрузкиФичи(ТипВызова);
	Если ДопПараметрыВызоваMCP <> Неопределено Тогда
		ДопПараметры = Новый Структура;
		ДопПараметры.Вставить("ДопПараметрыВызоваMCP", ДопПараметрыВызоваMCP);
	КонецЕсли;	
	Ванесса.ЗагрузитьФичи(ДопПараметры);
	
	// Контекст вызова вернётся в этот модуль после загрузки фичи в метод ОповеститьMCP_ОЗавершенииЗагрузкиФичи
	
КонецПроцедуры

&НаКлиенте
Функция MCPСформироватьMarkdownПроверкиСинтаксиса(Данные)
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Проверка синтаксиса Gherkin"));
	Строки.Добавить("");
	Если Данные["filePath"] <> Неопределено Тогда
		Строки.Добавить(Ванесса.Локализовать("- Файл:") + " " + MCPПредставлениеЗначенияДляMarkdown(Данные["filePath"]));
	КонецЕсли;
	Строки.Добавить(Ванесса.Локализовать("- Синтаксис корректен:") + " " + MCPПредставлениеЗначенияДляMarkdown(Данные["valid"]));
	Строки.Добавить(Ванесса.Локализовать("- Количество проблем:") + " " + MCPПредставлениеЗначенияДляMarkdown(Данные["problemCount"]));
	Строки.Добавить("");

	Если Данные["problemCount"] = 0 Тогда
		Строки.Добавить(Ванесса.Локализовать("Проблем не найдено."));
		Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);
	КонецЕсли;

	Строки.Добавить(Ванесса.Локализовать("## Найденные проблемы"));
	Строки.Добавить("");

	НомерПроблемы = 0;
	Для Каждого Проблема Из Данные["problems"] Цикл
		НомерПроблемы = НомерПроблемы + 1;
		СтрокаПроблемы = Строка(НомерПроблемы) + ". ";
		Если Проблема["line"] <> Неопределено Тогда
			СтрокаПроблемы = СтрокаПроблемы + Ванесса.Локализовать("Строка") + " " + Строка(Проблема["line"]) + ": ";
		КонецЕсли;
		СтрокаПроблемы = СтрокаПроблемы + MCPПредставлениеЗначенияДляMarkdown(Проблема["message"]);
		Строки.Добавить(СтрокаПроблемы);
	КонецЦикла;

	Возврат Ванесса._СтрСоединить(Строки, Символы.ПС);

КонецФункции

&НаКлиенте
Функция MCPТекущийФайлРедактора()
	
	Если Ванесса.VanessaTabs <> Неопределено И Ванесса.VanessaTabs.current <> Неопределено Тогда
		Возврат Ванесса.VanessaTabs.current.filename;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаКлиенте
Процедура ЗавершитьПроверкуСинтаксиса(ПутьКФайлу)
	
	Проблемы = Ванесса.ПолучитьПроблемыПоТекущейФиче();
	
	// Читаем найденные проблемы
	МассивПроблем = Новый Массив;
	Попытка
		Если Проблемы <> Неопределено Тогда
			Для Каждого Проблема Из Проблемы Цикл
				ПроблемаJSON = Новый Структура;
				Если ТипЗнч(Проблема) = Тип("Структура") Тогда
					ПроблемаJSON.Вставить("line", MCPБезопасноеСвойство(Проблема, "НомерСтроки"));
					ПроблемаJSON.Вставить("message", MCPБезопасноеСвойство(Проблема, "Текст"));
				ИначеЕсли ТипЗнч(Проблема) = Тип("Соответствие") Тогда
					ЗначениеСтроки = Проблема["НомерСтроки"];
					Если ЗначениеСтроки = Неопределено Тогда
						ЗначениеСтроки = Проблема["line"];
					КонецЕсли;
					ПроблемаJSON.Вставить("line", ЗначениеСтроки);
					ЗначениеТекста = Проблема["Текст"];
					Если ЗначениеТекста = Неопределено Тогда
						ЗначениеТекста = Проблема["message"];
					КонецЕсли;
					ПроблемаJSON.Вставить("message", ЗначениеТекста);
				Иначе
					ПроблемаJSON.Вставить("message", Строка(Проблема));
				КонецЕсли;
				МассивПроблем.Добавить(ПроблемаJSON);
			КонецЦикла;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Результат = Новый Структура;
	Результат.Вставить("valid", МассивПроблем.Количество() = 0);
	Результат.Вставить("problemCount", МассивПроблем.Количество());
	Результат.Вставить("problems", МассивПроблем);
	Результат.Вставить("filePath", ПутьКФайлу);
	
	СтрокаРезультат = MCPСформироватьMarkdownПроверкиСинтаксиса(Результат);
	
	Результат = Новый Структура(
		"message,completedAt",
		СтрокаРезультат,
		Строка(ТекущаяДата()));
		
	МодульМсп_Сервер = МодульМсп_Сервер();
	МодульМсп_Сервер.ЗавершитьВызовИнструментаУспешно(Ванесса.ПолучитьИдентификаторЗадачиMCP(), Результат);
	Ванесса.УстановитьИдентификаторЗадачиMCP(Неопределено);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьОткрытиеФичаФайла(ПутьКФайлу)
	
	ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(
		Ванесса.Локализовать("# Файл открыт в редакторе
							|
							|- Открыт: да
							|- Путь: %1
							|
							|## Следующие шаги
							|- Проверьте синтаксис: `check_syntax`
							|- Получите состояние редактора: `get_editor_state`
							|- Перезагрузите дерево, если меняли файл на диске: `load_features`"),
		ПутьКФайлу);
		
	МодульМсп_Сервер = МодульМсп_Сервер();
	МодульМсп_Сервер.ЗавершитьВызовИнструментаУспешно(Ванесса.ПолучитьИдентификаторЗадачиMCP(), ТекстОтвета);
	Ванесса.УстановитьИдентификаторЗадачиMCP(Неопределено);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьОткрытьЗагрузитьИлиПерезагрузитьФичаФайл(ПутьКФайлу, ДопПараметрыВызоваMCP)
	
	Путь = ДопПараметрыВызоваMCP.ИсходныйПутьКФайлу;
	
	Если ЗначениеЗаполнено(Путь) Тогда
		ПутьОтвета = Путь;
	Иначе
		ПутьОтвета = Объект.КаталогФич + " " + Ванесса.Локализовать("(текущий)");
	КонецЕсли;
	ТекстОтвета = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать(
		"# Загрузка фич
		|
		|- Загружено: да
		|- Путь: %1
		|
		|## Следующие шаги
		|- Подключите клиента тестирования: `connect_test_client`
		|- Найдите нужные шаги: `search_for_steps_by_keywords`
		|- Запустите сценарий: `run_scenario`"),
		ПутьОтвета,
		Формат(Ванесса.ТаблицаИзвестныхStepDefinition.Количество(), "ЧГ=0; ЧН=0"));
		
	МодульМсп_Сервер().ЗавершитьВызовИнструментаУспешно(Ванесса.ПолучитьИдентификаторЗадачиMCP(), ТекстОтвета);
	Ванесса.УстановитьИдентификаторЗадачиMCP(Неопределено);
	
КонецПроцедуры

&НаКлиенте
Процедура ПродолжитьВыполнениеШагаВРедакторе(ПутьКФайлу, ДопПараметрыВызоваMCP)
	
	// Проверяем что файл действительно открыт
	ТекущийФайл = MCPТекущийФайлРедактора();
	Если НРег(ТекущийФайл) <> НРег(ПутьКФайлу) Тогда
		ТекстСообщения = Ванесса.Локализовать("Не удалось активировать вкладку файла:") + " " + ПутьКФайлу;
		МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ЭкземплярVanessaEditor = Ванесса.ПолучитьVanessaEditor();
	ПолныйТекст = ЭкземплярVanessaEditor.getContent();
	
	НомерСтроки = ДопПараметрыВызоваMCP.НомерСтроки;
	КоличествоСтрок = Ванесса._СтрРазделить(ПолныйТекст, Символы.ПС).Количество();
	Если НомерСтроки > КоличествоСтрок Тогда
		ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Строка %1 выходит за пределы файла (%2 строк): %3"),
				НомерСтроки, КоличествоСтрок, ПутьКФайлу);
		МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	
	СтрокаДерева = Ванесса.СтрокаДереваПоНомеруСтрокиФичи(НомерСтроки);
	Если СтрокаДерева = Неопределено Тогда
		ТекстСтроки = ЭкземплярVanessaEditor.getLineContent(НомерСтроки);
		ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("По строке %1 не получилось найти исполнимую строку фича файла.
		|Текст в строке: %2
		|Имя файла: %3"),
				НомерСтроки, ТекстСтроки, ПутьКФайлу);
		МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
		Возврат;
	КонецЕсли;	
	Ванесса.МодульРедакторТекста().АктивизироватьСтрокуРедактораПоИдСтрокиИНомеруСтрокиФичи(СтрокаДерева.ИдСтроки, НомерСтроки);
	
	// Запускаем обработчик ожидания, чтобы редактор смог обновиться и перейти к нужной строке
	глДопПараметрыВызоваMCP = ДопПараметрыВызоваMCP;
	ПодключитьОбработчикОжидания("ПослеСделатьПереходкКТекстуВРедакторе", 0.1, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ПродолжитьВыполнитьСценарий1(ПутьКФайлу, ДопПараметрыВызоваMCP)
	
	// Обеспечить наличие активной вкладки .feature в VanessaEditor
	// (без неё КомандаВыполнитьСценарии/ВыполнитьВыделенныйСценарий молча завершаются)
	Если Ванесса.Объект.ИспользоватьРедакторVanessaEditor Тогда
		МСПНадоОткрытьФайл = Ложь;
		Если Ванесса.VanessaTabs = Неопределено ИЛИ Ванесса.VanessaTabs.current = Неопределено Тогда
			МСПНадоОткрытьФайл = Истина;
		ИначеЕсли НЕ Ванесса.ЭтоВкладкаEdit(Ванесса.VanessaTabs.current) Тогда
			МСПНадоОткрытьФайл = Истина;
		ИначеЕсли (НРег(Ванесса.Объект.КаталогФич) <> НРег(ПутьКФайлу)) И ЗначениеЗаполнено(ПутьКФайлу) Тогда
			МСПНадоОткрытьФайл = Истина;
		КонецЕсли;
		
		Если МСПНадоОткрытьФайл Тогда
			Ванесса.Объект.КаталогФич = ПутьКФайлу;
			ФайлВРедакторе = Ванесса.Объект.КаталогФич;
			Если ЗначениеЗаполнено(ФайлВРедакторе) И Прав(НРег(СокрЛП(ФайлВРедакторе)), 8) = ".feature" Тогда
				Попытка
					MCPOpenFeatureFileВРедакторе(ФайлВРедакторе, "ЗагрузитьФичуДляВыполненияСценария")
				Исключение
					ТекстСообщения = Ванесса.Локализовать("Не удалось открыть файл в редакторе:") + " " + ТекстОшибкиИзОписанияОшибки(ОписаниеОшибки());
					МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
					Возврат;
				КонецПопытки;
			Иначе
				ТекстСообщения = Ванесса.Локализовать("Нет активного .feature файла в редакторе. Используйте параметр filePath, или сначала загрузите фичу через load_features(path='путь/к/файлу.feature') и openFeatureFile.");
				МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ПродолжитьВыполнитьСценарий2(ПутьКФайлу, ДопПараметрыВызоваMCP);
	
КонецПроцедуры

&НаКлиенте
Процедура ПродолжитьВыполнитьСценарий2(ПутьКФайлу, ДопПараметрыВызоваMCP)
	
	MCPОжиданиеВыполненияСценария = Истина;
	Режим = ДопПараметрыВызоваMCP.Режим;
	
	Попытка
		
		Идентификатор = ДопПараметрыВызоваMCP.Идентификатор;
		Ванесса.УстановитьИдентификаторЗадачиMCP(Идентификатор);
		Ванесса.УстановитьФлагОповеститьMCPСерверПослеВыполненияСценариев(Режим, ДопПараметрыВызоваMCP);
		// Вызов вернётся в ОповеститьMCP_ОЗавершенииВыполненияСценариев
		
		Если Режим = "selected" Тогда
			ЭкземплярVanessaEditor = Ванесса.ПолучитьVanessaEditor();
			ПозицияVanessaEditor = ЭкземплярVanessaEditor.getPosition();
			ТекНомерСтроки = ПозицияVanessaEditor.lineNumber;
			
			СтрокаДерева = Ванесса.СтрокаДереваПоНомеруСтрокиФичи(ТекНомерСтроки);
			Если СтрокаДерева = Неопределено Тогда
				ТекстСообщения = Ванесса.Локализовать("Не найдена строка внутреннего дерева по номеру строки фичи:") + ТекНомерСтроки;
				МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
				Возврат;
			КонецЕсли;	
			
			Ванесса.ВыполнитьВыделенныйСценарий();
		ИначеЕсли Режим = "all" Тогда
			Ванесса.КомандаВыполнитьСценарии();
		ИначеЕсли Режим = "reloadAndRun" Тогда
			//Ванесса.ПерезагрузитьИВыполнитьДанныйСценарий();
			Если НЕ ЗначениеЗаполнено(ПутьКФайлу) Тогда
				ТекстОшибки = Неопределено;
				ПутьКФайлу = ПутьКФайлуИзТекущегоФайлаВРедакторе(ТекстОшибки);
				Если ЗначениеЗаполнено(ТекстОшибки) Тогда
					МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстОшибки);
					Возврат;
				КонецЕсли;
			КонецЕсли;	
			
			ДопПараметрыВызоваMCP = Новый Структура;
			ДопПараметрыВызоваMCP.Вставить("ИсходныйПутьКФайлу", ПутьКФайлу);
			ДопПараметрыВызоваMCP.Вставить("ЗапуститьВсеСценарииПослеЗагрузки", Истина);
			MCPOpenFeatureFileВРедакторе(ПутьКФайлу, "ЗагрузитьФичаФайлИВыполнитьСценарии", ДопПараметрыВызоваMCP);
			
		ИначеЕсли Режим = "fromCurrentStep" Тогда
			Ванесса.ВыполнитьДанныйСценарийСТекущегоШага();
		ИначеЕсли Режим = "reloadAndRunFromLine" Тогда
			// Получаем номер строки из параметров
			НомерСтроки = ДопПараметрыВызоваMCP.НомерСтроки;
			Если НЕ ЗначениеЗаполнено(НомерСтроки) Тогда
				ТекстСообщения = Ванесса.Локализовать("Для режима reloadAndRunFromLine необходимо указать параметр lineNumber.");
				МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
				Возврат;
			КонецЕсли;	
			
			// Сначала загружаем фича файл
			Если НЕ ЗначениеЗаполнено(ПутьКФайлу) Тогда
				ТекстОшибки = Неопределено;
				ПутьКФайлу = ПутьКФайлуИзТекущегоФайлаВРедакторе(ТекстОшибки);
