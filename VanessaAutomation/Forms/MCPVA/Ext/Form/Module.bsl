&НаКлиенте
Процедура MCPИнструментПолучитьВсеШаги(ПараметрыСозданияMCP)
	
    Свойства = Новый Структура;
    //Свойства.Вставить("text", МодульМсп_СхемаПараметров.НовыйСвойствоСхемы("string", "Текст для обработки"));
    Поля = Новый Массив;
    //Поля.Добавить("text");
    Схема = ПараметрыСозданияMCP.МодульМсп_СхемаПараметров.НовыйСхемаОбъекта(Свойства, Поля);
    ПараметрыСозданияMCP.МодульМсп_Сервер.ЗарегистрироватьИнструмент(ПараметрыСозданияMCP.МодульМсп_Сервер.НовыйОписаниеИнструмента(
        "get_all_steps_in_json_format",
        Ванесса.Локализовать("Возвращает все доступные шаги Vanessa Automation в формате массива json. Преполагается, что результат будет сохранен в файл и далее будет обрабатываться."),
        Схема,
        Новый ОписаниеОповещения("ВсеДоступныеШагиMCP", Вычислить("ЭтотОбъект")),
        ИмяПровайдера()));
		
КонецПроцедуры

&НаКлиенте
Процедура MCPИнструментНайтиШагиПоКлючевымСловам(ПараметрыСозданияMCP)
	
    Свойства = Новый Структура;
	//Представление шага
	Описание_search_name = Ванесса.Локализовать("Поисковый запрос без учета регистра. Строка ищется как подстрока в представлении шага.
	|Для альтернатив по принципу ИЛИ используйте разделитель '|', например 'первая часть|вторая часть'. Если параметр не указан — возвращаются все шаги.");
    Свойства.Вставить("search_name", ПараметрыСозданияMCP.МодульМсп_СхемаПараметров.НовыйСвойствоСхемы("string", Описание_search_name));
	
	Описание_exclude_name = Ванесса.Локализовать("Поисковый запрос без учета регистра. Шаг будет исключен из результата поиска, если в представлении шага будет найдено указанное значение.
	|Для альтернатив по принципу ИЛИ используйте разделитель '|', например 'первая часть|вторая часть'. Если параметр не указан — возвращаются все шаги.");
    Свойства.Вставить("exclude_name", ПараметрыСозданияMCP.МодульМсп_СхемаПараметров.НовыйСвойствоСхемы("string", Описание_exclude_name));
	
	//Описание шага
	Описание_search_description = Ванесса.Локализовать("Поисковый запрос без учета регистра. Строка ищется как подстрока в описании шага.
	|Для альтернатив по принципу ИЛИ используйте разделитель '|', например 'первая часть|вторая часть'. Если параметр не указан — возвращаются все шаги.");
    Свойства.Вставить("search_description", ПараметрыСозданияMCP.МодульМсп_СхемаПараметров.НовыйСвойствоСхемы("string", Описание_search_description));
	
	Описание_exclude_description = Ванесса.Локализовать("Поисковый запрос без учета регистра. Шаг будет исключен из результата поиска, если в описании шага будет найдено указанное значение.
	|Для альтернатив по принципу ИЛИ используйте разделитель '|', например 'первая часть|вторая часть'. Если параметр не указан — возвращаются все шаги.");
    Свойства.Вставить("exclude_description", ПараметрыСозданияMCP.МодульМсп_СхемаПараметров.НовыйСвойствоСхемы("string", Описание_exclude_description));
	
	//Тип шага
	Описание_search_type = Ванесса.Локализовать("Поисковый запрос без учета регистра. Строка ищется как подстрока в типе шага.
	|Для альтернатив по принципу ИЛИ используйте разделитель '|', например 'первая часть|вторая часть'. Если параметр не указан — возвращаются все шаги.");
    Свойства.Вставить("search_type", ПараметрыСозданияMCP.МодульМсп_СхемаПараметров.НовыйСвойствоСхемы("string", Описание_search_type));
	
	Описание_exclude_type = Ванесса.Локализовать("Поисковый запрос без учета регистра. Шаг будет исключен из результата поиска, если в типе шага будет найдено указанное значение.
	|Для альтернатив по принципу ИЛИ используйте разделитель '|', например 'первая часть|вторая часть'. Если параметр не указан — возвращаются все шаги.");
    Свойства.Вставить("exclude_type", ПараметрыСозданияMCP.МодульМсп_СхемаПараметров.НовыйСвойствоСхемы("string", Описание_exclude_type));
	
	// Количество шагов в выдаче
	Описание_limit = Ванесса.Локализовать("Максимальное количество результатов. 0 — вернуть все результаты. По умолчанию 50.");
    Свойства.Вставить("limit", ПараметрыСозданияMCP.МодульМсп_СхемаПараметров.НовыйСвойствоСхемы("number", Описание_limit));
	
    ТребуемыеПоля = Новый Массив;
    ТребуемыеПоля.Добавить("search_name");
    ТребуемыеПоля.Добавить("exclude_name");
    ТребуемыеПоля.Добавить("search_description");
    ТребуемыеПоля.Добавить("exclude_description");
    ТребуемыеПоля.Добавить("search_type");
    ТребуемыеПоля.Добавить("exclude_type");
    ТребуемыеПоля.Добавить("limit");
    Схема = ПараметрыСозданияMCP.МодульМсп_СхемаПараметров.НовыйСхемаОбъекта(Свойства, ТребуемыеПоля);
	ПараметрыСозданияMCP.МодульМсп_Сервер.ЗарегистрироватьИнструмент(ПараметрыСозданияMCP.МодульМсп_Сервер.НовыйОписаниеИнструмента(
        "search_for_steps_by_keywords",
        Ванесса.Локализовать("Ищет шаги Vanessa Automation по переданной строке поиска и возвращает их в формате Markdown.
		|Поиск производится по: представлению шагов, описании шагов и типу шагов.
		|В любой параметр можно передавать несколько значений, разделенных вертикальной чертой |.
		|Пример поиска шагов в представлении которых встречается слово ""кнопка"": search_name = ""кнопка|кнопки|кнопку"".
		|Пример исключения шагов в представлении которых встречается слово ""поле"": exclude_name = ""поле|поля"".
		
