&НаКлиенте
Процедура ЗавершитьВыполненияСценария(Тип, ДопПараметрыВызоваMCP)
	
	МассивРезультатПрохожденияТестовСценария = Ванесса.ПолучитьМассивРезультатПрохожденияТестовСценария();
	БылиОшибки = Ложь;
	Для Каждого ДанныеСценария Из МассивРезультатПрохожденияТестовСценария Цикл
		Если ДанныеСценария.Свойство("ОписаниеОшибки") И ЗначениеЗаполнено(ДанныеСценария.ОписаниеОшибки) Тогда
			БылиОшибки = Истина;
			Прервать;
		КонецЕсли;	
	КонецЦикла;	
	
	МассивСтрок = Новый Массив;
	Если БылиОшибки Тогда
		ТекстСтроки = Ванесса.Локализовать("## Результат выполнения сценариев: были ошибки");
	Иначе	
		ТекстСтроки = Ванесса.Локализовать("## Результат выполнения сценариев: все сценарии выполнены успешно");
	КонецЕсли;	
	МассивСтрок.Добавить(ТекстСтроки);
	МассивСтрок.Добавить("");
	
	Для Каждого ДанныеСценария Из МассивРезультатПрохожденияТестовСценария Цикл
		СтрокаСценария = Ванесса.СтрокаДереваПоИдСтроки(ДанныеСценария.ИДСтроки);
		
		ТекстСтроки = Ванесса.Локализовать("Имя сценария:" + " " + СтрокаСценария.Имя);
		МассивСтрок.Добавить(ТекстСтроки);
		ТекстСтроки = Ванесса.Локализовать("Результат прохождения сценнария:") + " " + ДанныеСценария.Статус;
		МассивСтрок.Добавить(ТекстСтроки);
		
		Если ДанныеСценария.Свойство("ОписаниеОшибки") И ЗначениеЗаполнено(ДанныеСценария.ОписаниеОшибки) Тогда
			БылиОшибки = Истина;
			
			Если ДанныеСценария.Свойство("ДанныеДляФормированияJsonОбОшибке") Тогда
				СтрокаУпавшегоШага = Ванесса.СтрокаДереваПоИдСтроки(ДанныеСценария.ДанныеДляФормированияJsonОбОшибке.ИДСтрокиУпавшегоШага);
				ТекстСтроки = Ванесса.Локализовать("Текст упавшего шага:") + " " + СтрокаУпавшегоШага.Имя;
				МассивСтрок.Добавить(ТекстСтроки);
				ТекстСтроки = Ванесса.Локализовать("Статус упавшего шага:") + " " + СтрокаУпавшегоШага.Статус;
				МассивСтрок.Добавить(ТекстСтроки);
				ТекстСтроки = Ванесса.Локализовать("Номер строки упавшего шага в feature файле:") + " " + XMLСтрока(СтрокаУпавшегоШага.НомерСтрокиВФиче);
				МассивСтрок.Добавить(ТекстСтроки);
				ТекстСтроки = Ванесса.Локализовать("Текст ошибки:") + " " + ДанныеСценария.ДанныеДляФормированияJsonОбОшибке.ОписаниеОшибкиКратко;
				МассивСтрок.Добавить(ТекстСтроки);
			Иначе
				ТекстСтроки = Ванесса.Локализовать("Текст ошибки:") + " " + ДанныеСценария.ОписаниеОшибки;
				МассивСтрок.Добавить(ТекстСтроки);
			КонецЕсли;	
			
			МассивСтрок.Добавить("");
			МассивСтрок.Добавить("");
		КонецЕсли;	
		
	КонецЦикла;	
	
	МодульМсп_Сервер().ЗавершитьВызовИнструментаУспешно(Ванесса.ПолучитьИдентификаторЗадачиMCP(), Ванесса._СтрСоединить(МассивСтрок));
	Ванесса.УстановитьИдентификаторЗадачиMCP(Неопределено);
	Ванесса.УстановитьФлагОповеститьMCPСерверПослеВыполненияСценариев(Неопределено, Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура ПослеСделатьПереходкКТекстуВРедакторе()
	НомерСтроки = глДопПараметрыВызоваMCP.НомерСтроки;
	ПутьКФайлу = глДопПараметрыВызоваMCP.ПутьКФайлу;
	
	ЭкземплярVanessaEditor = Ванесса.ПолучитьVanessaEditor();
	ТекстСтроки = ЭкземплярVanessaEditor.getLineContent(НомерСтроки);
	
	Если НЕ ЗначениеЗаполнено(ТекстСтроки) Тогда
		ТекстСообщения = Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Строка %1 пуста в файле: %2"),
				НомерСтроки, ПутьКФайлу);
		МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	Ванесса.УстановитьФлагОповеститьMCPСерверПослеВыполненияОднойСтрокиФичи(глДопПараметрыВызоваMCP.Тип);
	Ванесса.ВыполнитьОдинШаг();
	
	// Вызов вернётся в ОповеститьMCP_ОЗавершенииВыполненияОднойСтрокиФичи
	
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьУспешноеВыполнениеШагаВРедакторе(ДопПараметрыВызоваMCP)
	ТекстСообщения = Ванесса.Локализовать("Шаг в строке фича файла успешно выполнен");
	МодульМсп_Сервер().ЗавершитьВызовИнструментаУспешно(Ванесса.ПолучитьИдентификаторЗадачиMCP(), ТекстСообщения);
	Ванесса.УстановитьИдентификаторЗадачиMCP(Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьВыполнениеШагаВРедактореСОшибкой(ДопПараметрыВызоваMCP, РезультатПрохожденияШага)
	ТекстСообщения = ТекстОшибкиИзОписанияОшибки(РезультатПрохожденияШага.ОписаниеОшибки);
	МодульМсп_Сервер().ЗавершитьВызовИнструментаУспешно(Ванесса.ПолучитьИдентификаторЗадачиMCP(), ТекстСообщения);
	Ванесса.УстановитьИдентификаторЗадачиMCP(Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура ОткрытиеФичаФайлаВРедакторе(ПутьКФайлу, Запрос, ТипВызова, ДопПараметрыВызоваMCP = Неопределено)
	
	Если ЗначениеЗаполнено(ПутьКФайлу) Тогда
		Если НЕ Ванесса.ФайлСуществуетКомандаСистемы(ПутьКФайлу) Тогда
			
			ПолныйПутьКФайлуВКаталогеПроекта = Ванесса.ДополнитьСлешВПуть(Ванесса.Объект.КаталогПроекта) + ПутьКФайлу;
			Если НЕ Ванесса.ФайлСуществуетКомандаСистемы(ПолныйПутьКФайлуВКаталогеПроекта) Тогда
				МодульМсп_Сервер = МодульМсп_Сервер();
				ТекстОшибки = Ванесса.Локализовать("Файл <%1> не был найден.");
				Если НЕ Ванесса.ЭтоLinux И Найти(ПутьКФайлу, ":") = 0 Тогда
					ТекстОшибки = Ванесса.Локализовать("Файл <%1> не был найден. В каталоге проекта файл <%2> тоже не был найден. Видимо был передан относительный путь, попробуйте передать полный путь к файлу.");
				КонецЕсли;
				
				ТекстОшибки = Ванесса.ПодставитьПараметрыВСтроку(ТекстОшибки, ПутьКФайлу, ПолныйПутьКФайлуВКаталогеПроекта);
				МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Запрос.Идентификатор, "INVALID_PARAMS", ТекстОшибки);
				Возврат;
			Иначе
				ПутьКФайлу = ПолныйПутьКФайлуВКаталогеПроекта;
			КонецЕсли;	
			
		КонецЕсли;	
		ПутьКФайлу = MCPНормализоватьПутьКФичаФайлу(ПутьКФайлу);
		
		МодульМсп_Сервер = МодульМсп_Сервер();
		Идентификатор = Запрос.Идентификатор;
		Ванесса.УстановитьИдентификаторЗадачиMCP(Идентификатор);
		МодульМсп_Сервер.УведомитьОПрогрессе(Идентификатор, 0, 3, Ванесса.Локализовать("Загрузка feature файла."));
		
		MCPOpenFeatureFileВРедакторе(ПутьКФайлу, ТипВызова, ДопПараметрыВызоваMCP);
	Иначе
		ТекстОшибки = Ванесса.Локализовать("Не передан путь к файлу.");
		МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Запрос.Идентификатор, "INVALID_PARAMS", ТекстОшибки);
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ТекстОшибкиИзОписанияОшибки(Знач Стр)
	СтрКраткая = Ванесса.УбратьТехническиеДанныеИзСтроки(Стр);
	Если ЗначениеЗаполнено(СтрКраткая) Тогда
		Возврат СтрКраткая;
	КонецЕсли;
	Возврат Стр;
КонецФункции	

&НаКлиенте
Процедура MCPОткрытьИсследовательФормыДляАнализа(ИдентификаторЗапроса, ФорматВывода)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Язык", Ванесса.Объект.ЯзыкГенератораGherkin);
	ПараметрыФормы.Вставить("ТекущийTestclientЭтоWebКлиент", Ванесса.ТекущийTestclientЭтоWebКлиент);
	ПараметрыФормы.Вставить("ВладелецУникальныйИдентификатор", УникальныйИдентификатор);
	ПараметрыФормы.Вставить("MCPРежимЧтенияФормы", Истина);
	ПараметрыФормы.Вставить("MCPФорматЧтенияФормы", ФорматВывода);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("MCPИдентификаторЗапроса", ИдентификаторЗапроса);
	ДополнительныеПараметры.Вставить("MCPФорматВывода", ФорматВывода);
	
	Ванесса.УстановитьИдентификаторЗадачиMCP(ИдентификаторЗапроса);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("MCPПолученАнализФормы", ЭтаФорма, ДополнительныеПараметры);
	ОткрытьФорму(Ванесса.ПолучитьИмяОбработкиVA() + ".Форма.ИсследовательФормы", ПараметрыФормы, Ванесса, , , , ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура MCPПолученАнализФормы(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	ИдентификаторЗапроса = ДополнительныеПараметры.MCPИдентификаторЗапроса;
	ФорматВывода = ДополнительныеПараметры.MCPФорматВывода;
	
	ДеревоЭлементов = "";
	ШагиТекущегоЭлемента = "";
	
	Если ТипЗнч(РезультатЗакрытия) = Тип("Структура") Тогда
		Если РезультатЗакрытия.Свойство("treeText") Тогда
			ДеревоЭлементов = MCPПредставлениеЗначенияДляMarkdown(РезультатЗакрытия.treeText);
		КонецЕсли;
		Если РезультатЗакрытия.Свойство("stepText") Тогда
			ШагиТекущегоЭлемента = MCPПредставлениеЗначенияДляMarkdown(РезультатЗакрытия.stepText);
		КонецЕсли;
	ИначеЕсли РезультатЗакрытия <> Неопределено Тогда
		ТекстСообщения = Ванесса.Локализовать("Ошибка чтения результата анализа формы: неожиданный тип результата") + " " + Строка(ТипЗнч(РезультатЗакрытия));
		МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Анализ текущей формы"));
	Строки.Добавить("");
	
	Если ФорматВывода = "full" Тогда
		Попытка
			Ванесса.ПолучитьИзмененияФормыGherkin();
			Gherkin = Ванесса.Объект.СгенерированныйСценарий;
			Если ЗначениеЗаполнено(Gherkin) Тогда
				Строки.Добавить(Ванесса.Локализовать("## Gherkin-состояние формы"));
				Строки.Добавить("```gherkin");
				Строки.Добавить(Gherkin);
				Строки.Добавить("```");
				Строки.Добавить("");
			Иначе
				Строки.Добавить(Ванесса.Локализовать("## Gherkin-состояние формы"));
				Строки.Добавить(Ванесса.Локализовать("Нет данных."));
				Строки.Добавить("");
			КонецЕсли;
		Исключение
			Строки.Добавить(Ванесса.Локализовать("## Gherkin-состояние формы"));
			Строки.Добавить(Ванесса.Локализовать("ошибка:") + " " + ОписаниеОшибки());
			Строки.Добавить("");
		КонецПопытки;
	КонецЕсли;
	
	Строки.Добавить(Ванесса.Локализовать("## Элементы формы"));
	Если ЗначениеЗаполнено(ДеревоЭлементов) Тогда
		Строки.Добавить("```text");
		Строки.Добавить(ДеревоЭлементов);
		Строки.Добавить("```");
	Иначе
		Строки.Добавить(Ванесса.Локализовать("Нет данных."));
	КонецЕсли;
	
	Если ФорматВывода = "full" И ЗначениеЗаполнено(ШагиТекущегоЭлемента) Тогда
		Строки.Добавить("");
		Строки.Добавить(Ванесса.Локализовать("## Часто используемые шаги для текущего элемента"));
		Строки.Добавить("```gherkin");
		Строки.Добавить(ШагиТекущегоЭлемента);
		Строки.Добавить("```");
	КонецЕсли;
	
	Если ФорматВывода = "full" Тогда
		Попытка
			АктивноеОкно = Ванесса.ПолучитьАктивноеОкноИзТестовоеПриложение();
		Исключение
		КонецПопытки;
		
		Если АктивноеОкно <> Неопределено Тогда
			CообщенияПользователю = ПолучитьСообщенияПользователюИзОкна(АктивноеОкно);
			Если CообщенияПользователю = Неопределено Тогда
				Строки.Добавить(Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("В окне <%1> нет сообщений пользователю."), АктивноеОкно.Заголовок));
			Иначе	
				Строки.Добавить(Ванесса.Локализовать("Обнаружены сообщения пользователю:"));
				Для Каждого Стр Из CообщенияПользователю Цикл
					Строки.Добавить(Стр);
				КонецЦикла;	
			КонецЕсли;	
		КонецЕсли;	
	КонецЕсли;	
	
	МодульМсп_Сервер().ЗавершитьВызовИнструментаУспешно(Ванесса.ПолучитьИдентификаторЗадачиMCP(), Ванесса._СтрСоединить(Строки, Символы.ПС));
	Ванесса.УстановитьИдентификаторЗадачиMCP(Неопределено);
	
КонецПроцедуры

