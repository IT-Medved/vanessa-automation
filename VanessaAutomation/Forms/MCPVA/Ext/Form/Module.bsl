Функция ДанныеОЧастоИспользуемыхШагах(КоличествоВывод)
	
	ШагиИзМассиваСнипетов = ШагиИзМассиваСнипетов();
	
	Результат = Новый Массив;
	Результат.Добавить(Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("# Всего в статистике %1 шагов"),XMLСтрока(ШагиИзМассиваСнипетов.Количество())));
	Результат.Добавить(Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("# Вывожу данные по %1 шагов"),XMLСтрока(КоличествоВывод)));
	Результат.Добавить("");
	
	Счетчик = 0;
	Для Каждого ТекШаг Из ШагиИзМассиваСнипетов Цикл
		Счетчик = Счетчик + 1;
		
		Если Счетчик > КоличествоВывод Тогда
			Прервать;
		КонецЕсли;
		
		Результат.Добавить(Ванесса.Локализовать("## Номер шага:") + " " + XMLСтрока(Счетчик));
		Результат.Добавить(Ванесса.Локализовать("## Тип:") + " " + ТекШаг.Тип);
		Результат.Добавить(Ванесса.Локализовать("## Представление шага:") + Символы.ПС + ТекШаг.Имя);
		Результат.Добавить(Ванесса.Локализовать("## Описание:") + Символы.ПС + ТекШаг.Описание);
		Результат.Добавить("");
	КонецЦикла;	
	
	Возврат Ванесса._СтрСоединить(Результат);
	
КонецФункции

&НаКлиенте
Функция ШагиИзМассиваСнипетов()
	МассивСнипетов = Ванесса._СтрРазделить(глЧастоИспользуемыеШаги, Символы.ПС);
	
	Кеш = Новый Соответствие;
	Для Каждого СтрокаТаблицаИзвестныхStepDefinition Из Ванесса.ТаблицаИзвестныхStepDefinition Цикл
		ДанныеШага = Новый Структура;
		ДанныеШага.Вставить("Имя", СтрокаТаблицаИзвестныхStepDefinition.ПредставлениеТеста);
		ДанныеШага.Вставить("Описание", СтрокаТаблицаИзвестныхStepDefinition.ОписаниеШага);
		ДанныеШага.Вставить("Тип", СтрокаТаблицаИзвестныхStepDefinition.ТипШага);
		ДанныеШага.Вставить("СтрокаДляПоиска", СтрокаТаблицаИзвестныхStepDefinition.СтрокаДляПоиска);
		
		Кеш.Вставить(НРег(СтрокаТаблицаИзвестныхStepDefinition.СтрокаДляПоиска), ДанныеШага);
	КонецЦикла;	
	
	Результат = Новый Массив;
	Для Каждого ТекСнипет Из МассивСнипетов Цикл
		ДанныеШага = Кеш[ТекСнипет];
		Если ДанныеШага = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Результат.Добавить(ДанныеШага);
		
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

