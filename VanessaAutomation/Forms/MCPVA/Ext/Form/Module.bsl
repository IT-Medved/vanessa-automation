&НаКлиенте
Процедура MCPОткрытьИсследовательФормыДляАнализа(ИдентификаторЗапроса, ФорматВывода)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Язык", Ванесса.Объект.ЯзыкГенератораGherkin);
	ПараметрыФормы.Вставить("ТекущийTestclientЭтоWebКлиент", Ванесса.ТекущийTestclientЭтоWebКлиент);
	ПараметрыФормы.Вставить("ВладелецУникальныйИдентификатор", УникальныйИдентификатор);
	ПараметрыФормы.Вставить("MCPРежимЧтенияФормы", Истина);
	ПараметрыФормы.Вставить("MCPФорматЧтенияФормы", ФорматВывода);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("MCPИдентификаторЗапроса", ИдентификаторЗапроса);
	ДополнительныеПараметры.Вставить("MCPФорматВывода", ФорматВывода);
	
	Ванесса.УстановитьИдентификаторЗадачиMCP(ИдентификаторЗапроса);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("MCPПолученАнализФормы", ЭтаФорма, ДополнительныеПараметры);
	ОткрытьФорму(Ванесса.ПолучитьИмяОбработкиVA() + ".Форма.ИсследовательФормы", ПараметрыФормы, Ванесса, , , , ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура MCPПолученАнализФормы(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	ИдентификаторЗапроса = ДополнительныеПараметры.MCPИдентификаторЗапроса;
	ФорматВывода = ДополнительныеПараметры.MCPФорматВывода;
	
	ДеревоЭлементов = "";
	ШагиТекущегоЭлемента = "";
	
	Если ТипЗнч(РезультатЗакрытия) = Тип("Структура") Тогда
		Если РезультатЗакрытия.Свойство("treeText") Тогда
			ДеревоЭлементов = MCPПредставлениеЗначенияДляMarkdown(РезультатЗакрытия.treeText);
		КонецЕсли;
		Если РезультатЗакрытия.Свойство("stepText") Тогда
			ШагиТекущегоЭлемента = MCPПредставлениеЗначенияДляMarkdown(РезультатЗакрытия.stepText);
		КонецЕсли;
	ИначеЕсли РезультатЗакрытия <> Неопределено Тогда
		ТекстСообщения = Ванесса.Локализовать("Ошибка чтения результата анализа формы: неожиданный тип результата") + " " + Строка(ТипЗнч(РезультатЗакрытия));
		МодульМсп_Сервер().ЗавершитьВызовИнструментаСОшибкой(Ванесса.ИдентификаторЗадачиMCP(), "ACTION_FAILED", ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("# Анализ текущей формы"));
	Строки.Добавить("");
	
	Если ФорматВывода = "full" Тогда
		Попытка
			Ванесса.ПолучитьИзмененияФормыGherkin();
			Gherkin = Ванесса.Объект.СгенерированныйСценарий;
			Если ЗначениеЗаполнено(Gherkin) Тогда
				Строки.Добавить(Ванесса.Локализовать("## Gherkin-состояние формы"));
				Строки.Добавить("```gherkin");
				Строки.Добавить(Gherkin);
				Строки.Добавить("```");
				Строки.Добавить("");
			Иначе
				Строки.Добавить(Ванесса.Локализовать("## Gherkin-состояние формы"));
				Строки.Добавить(Ванесса.Локализовать("Нет данных."));
				Строки.Добавить("");
			КонецЕсли;
		Исключение
			Строки.Добавить(Ванесса.Локализовать("## Gherkin-состояние формы"));
			Строки.Добавить(Ванесса.Локализовать("ошибка:") + " " + ОписаниеОшибки());
			Строки.Добавить("");
		КонецПопытки;
	КонецЕсли;
	
	Строки.Добавить(Ванесса.Локализовать("## Элементы формы"));
	Если ЗначениеЗаполнено(ДеревоЭлементов) Тогда
		Строки.Добавить("```text");
		Строки.Добавить(ДеревоЭлементов);
		Строки.Добавить("```");
	Иначе
		Строки.Добавить(Ванесса.Локализовать("Нет данных."));
	КонецЕсли;
	
	Если ФорматВывода = "full" И ЗначениеЗаполнено(ШагиТекущегоЭлемента) Тогда
		Строки.Добавить("");
		Строки.Добавить(Ванесса.Локализовать("## Часто используемые шаги для текущего элемента"));
		Строки.Добавить("```gherkin");
		Строки.Добавить(ШагиТекущегоЭлемента);
		Строки.Добавить("```");
	КонецЕсли;
	
	Если ФорматВывода = "full" Тогда
		Попытка
			АктивноеОкно = Ванесса.ПолучитьАктивноеОкноИзТестовоеПриложение();
		Исключение
		КонецПопытки;
		
		Если АктивноеОкно <> Неопределено Тогда
			CообщенияПользователю = ПолучитьСообщенияПользователюИзОкна(АктивноеОкно);
			Если CообщенияПользователю = Неопределено Тогда
				Строки.Добавить(Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("В окне <%1> нет сообщений пользователю."), АктивноеОкно.Заголовок));
			Иначе	
				Строки.Добавить(Ванесса.Локализовать("Обнаружены сообщения пользователю:"));
				Для Каждого Стр Из CообщенияПользователю Цикл
					Строки.Добавить(Стр);
				КонецЦикла;	
			КонецЕсли;	
		КонецЕсли;	
	КонецЕсли;	
	
	МодульМсп_Сервер().ЗавершитьВызовИнструментаУспешно(Ванесса.ПолучитьИдентификаторЗадачиMCP(), Ванесса._СтрСоединить(Строки, Символы.ПС));
	Ванесса.УстановитьИдентификаторЗадачиMCP(Неопределено);
	
КонецПроцедуры

&НаКлиенте
Функция MCPСписокДоступныхПрофилей()
	
	Строки = Новый Массив;
	Строки.Добавить(Ванесса.Локализовать("## Доступные профили"));
	
	Если Ванесса.ДанныеКлиентовТестирования.Количество() = 0 Тогда
		Строки.Добавить(Ванесса.Локализовать("Профили не настроены. Добавьте профиль на вкладке «Клиенты тестирования» в настройках VA."));
	Иначе
