&НаКлиенте
Процедура VanessaEditorПоказатьСкрытьДеревоКаталогов(Команда) Экспорт
	Если Ванесса.Элементы.ФункциональностьЗакладки.ТекущаяСтраница <> Ванесса.Элементы.ГруппаЗапускТестов Тогда
		Ванесса.Элементы.ФункциональностьЗакладки.ТекущаяСтраница = Ванесса.Элементы.ГруппаЗапускТестов;
		Ванесса.НазначитьГорячиеКлавишиКнопкамКоманднойПанелиРедактора(Истина);
	КонецЕсли;	 
	
	Ванесса.Элементы.ГруппаДереваФайлов.Видимость = НЕ Ванесса.Элементы.ГруппаДереваФайлов.Видимость;
	Если Ванесса.Элементы.ГруппаДереваФайлов.Видимость Тогда
		Ванесса.Элементы.ГруппаGit.Видимость = Ложь;
	КонецЕсли;	 
	
	Если Ванесса.Элементы.ГруппаДереваФайлов.Видимость Тогда
		Если ПустаяСтрока(Ванесса.ПутьКПапкеСФичами) Тогда
			Если НЕ ПустаяСтрока(Ванесса.Объект.КаталогФич) Тогда
				Если Ванесса.ФайлСуществуетКомандаСистемы(Ванесса.Объект.КаталогФич) Тогда
					Если Ванесса.ЭтоКаталогКомандаСистемы(Ванесса.Объект.КаталогФич) Тогда
						Ванесса.ПутьКПапкеСФичами = Ванесса.Объект.КаталогФич;
					Иначе
						Файл = Новый Файл(Ванесса.Объект.КаталогФич);
						Ванесса.ПутьКПапкеСФичами = Файл.Путь;
					КонецЕсли;	 
				КонецЕсли;	 
			КонецЕсли;	 
		КонецЕсли;	
		
		Если ПустаяСтрока(Ванесса.ПутьКПапкеСФичами) Тогда
			Если ЗначениеЗаполнено(Ванесса.Объект.КаталогПроекта) Тогда
				Ванесса.ПутьКПапкеСФичами = Ванесса.Объект.КаталогПроекта;
			КонецЕсли;	 
		КонецЕсли;	 
		
		Ванесса.ОбновитьДеревоФайлов();
	КонецЕсли;	 
КонецПроцедуры


&НаКлиенте
Процедура VanessaEditorПоказатьСкрытьДеревоGit(Команда) Экспорт
	Если НЕ Ванесса.Объект.ИспользоватьКомпонентуVanessaExt Тогда
		Ванесса.СообщитьПользователю(Ванесса.Локализовать("Необходимо включить использование внешней компоненты VanessaExt."));
		Возврат;
	КонецЕсли;	 
	
	Если Ванесса.Элементы.ФункциональностьЗакладки.ТекущаяСтраница <> Ванесса.Элементы.ГруппаЗапускТестов Тогда
		Ванесса.Элементы.ФункциональностьЗакладки.ТекущаяСтраница = Ванесса.Элементы.ГруппаЗапускТестов;
		Ванесса.НазначитьГорячиеКлавишиКнопкамКоманднойПанелиРедактора(Истина);
	КонецЕсли;
	Ванесса.Элементы.ГруппаGit.Видимость = НЕ Ванесса.Элементы.ГруппаGit.Видимость;
	Если Ванесса.Элементы.ГруппаGit.Видимость Тогда
		Ванесса.Элементы.ГруппаДереваФайлов.Видимость = Ложь;
		Ванесса.Элементы.ДеревоGitДеревоGitЗафиксировать.КнопкаПоУмолчанию = Истина;
	Иначе	
		Ванесса.Элементы.ДеревоGitДеревоGitЗафиксировать.КнопкаПоУмолчанию = Ложь;
	КонецЕсли;	 
	
	Если Ванесса.Элементы.ГруппаGit.Видимость Тогда
		Если ПустаяСтрока(Ванесса.ПутьКПапкеGit) Тогда
			Ванесса.ПутьКПапкеGit = Ванесса.Объект.КаталогПроекта;
		КонецЕсли;	 
		Ванесса.ДеревоGit.ПолучитьЭлементы().Очистить();
		Ванесса.ПутьКПапкеGitПриИзменении();
	Иначе
		Ванесса.Элементы.ГруппаVanessaEditorПереходКРазличиямВФайлах.Видимость = Ложь;
		Ванесса.МодульРаботаСGit().ЗакрытьВсеВкладкиDiff();
	КонецЕсли;	 
	
КонецПроцедуры


