&НаКлиенте
Процедура ИнициализироватьVanessaEditorКлиент2() Экспорт
	
	Попытка
		Если Ванесса.VanessaTabs = Неопределено Тогда  
			view = Ванесса.МодульРедакторТекста().ДокументHTMLViewРедактора();
			VanessaGherkinProvider = view.VanessaGherkinProvider;
			VanessaGherkinProvider.setSuggestWidgetWidth("90%");
			Ванесса.МодульРедакторТекста().УстановитьКлючевыеСловаVanessaEditor();
			Ванесса.МодульРедакторТекста().УстановитьСоответствиеСловУсловныхОператоров();
			Ванесса.МодульРедакторТекста().УстановитьКлючевыеСловаИсключений();
			Ванесса.МодульРедакторТекста().УстановитьСписокКомандVanessaEditor();
			Ванесса.VanessaTabs = view.createVanessaTabs();
			Массив = Новый Массив;
			Массив.Добавить(Ванесса.Локализовать("Версия редактора") + ": ");
			Массив.Добавить(Новый ФорматированнаяСтрока(Ванесса.VanessaTabs.version,, WebЦвета.Синий,, "https://github.com/Pr-Mex/VAEditor/releases"));
			Ванесса.Элементы.ДекорацияВерсияVAEditor.Заголовок = Новый ФорматированнаяСтрока(Массив);
			Ванесса.РедакторБылПроинициализирован = Истина;
		КонецЕсли;	 
	Исключение
		ОписаниеОшибки = ОписаниеОшибки();
		Ванесса.ЗаписатьЛогВЖРОшибка("ИнициализацияРедактора",
			Ванесса.ПодставитьПараметрыВСтроку(Ванесса.Локализовать("Ошибка инициализации редактора: %1"), ОписаниеОшибки));
		ВыключитьИспользованиеVanessaEditor();
	КонецПопытки;
	
	Если НЕ Ванесса.АсинхронноеПодключениеМодулейВыполнялось Тогда
		Ванесса.АсинхронноеПодключениеМодулейВыполнялось = Истина;
		Ванесса.АсинхронноеПодключениеМодулей();
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура VanessaEditorOnReceiveEventHandler(Event, Arg) Экспорт

	Если Event = "POSITION_DID_CHANGE" Тогда
		Возврат;
	ИначеЕсли Event = "CONTENT_DID_CHANGE" Тогда
		Если Ванесса.ИгнорироватьИзмененияVanessaEditor Тогда
			Ванесса.ИгнорироватьИзмененияVanessaEditor = Ложь;
		КонецЕсли;	 
	ИначеЕсли Event = "UPDATE_BREAKPOINTS" Тогда
		Ванесса.МодульРедакторТекста().ОбновитьДанныеПоБрейкпоинтамVanessaEditor(Arg);
		Ванесса.МодульРедакторТекста().ОтрисоватьБрейкпоинтыVanessaEditor();
	ИначеЕсли Event = "ErrorDetails" Тогда
		Если НЕ ПустаяСтрока(Arg) Тогда
			ПоказатьДеталиОшибкиVanessaEditor(Ванесса.ПрочитатьОбъектJSON(Arg));
		КонецЕсли;	 
	ИначеЕсли Event = "Actualize" Тогда
		Если НЕ ПустаяСтрока(Arg) Тогда
			Ванесса.АктуализироватьПоДаннымОшибки(Ванесса.ПрочитатьОбъектJSON(Arg));
		КонецЕсли;	 
	ИначеЕсли Event = "CopyError" Тогда
		Если НЕ ПустаяСтрока(Arg) Тогда
			Ванесса.МодульРедакторТекста().СкопироватьТекстОшибкиВБуферОбменаVAVanessaEditor(Ванесса.ПрочитатьОбъектJSON(Arg));
		КонецЕсли;	 
	ИначеЕсли Event = "ON_HREF_CLICK" Тогда
		Ванесса.МодульРедакторТекста().ОткрытьГиперссылкуВРедактореПоУмолчанию(Arg);
	ИначеЕсли Event = "ON_LINK_CLICK" Тогда
		Ванесса.МодульРедакторТекста().ОбработкаНажатияНаСсылку(Arg, Ванесса.ДанныеСекцииПеременные());
	ИначеЕсли Event = "REQUEST_IMAGE" Тогда
		Ванесса.МодульРедакторТекста().ПоказатьКартинкуВРедакторе(Arg);
	ИначеЕсли Event = "PRESS_CTRL_S" Тогда
		VanessaEditorСохранитьФайлОбработчик();
	ИначеЕсли Event = "ON_MARK_CLICK" Тогда
		ОбработчикНажатияГиперссылкиВФайлеMarkDown(Arg);
	ИначеЕсли Event = "ON_TAB_CLOSING" Тогда
		Если Arg.modified = Истина Тогда
			ОписаниеОповещения = Новый ОписаниеОповещения("ПередЗакрытиемВкладкиРедактора", Ванесса, Arg);
			ТекстСообщения = Ванесса.Локализовать("Сохранить изменения?");
			ПоказатьВопрос(ОписаниеОповещения, ТекстСообщения, РежимДиалогаВопрос.ДаНетОтмена);
		Иначе
			Arg.accept();
			Если Ванесса.VanessaTabs.tabStack.length = 0 Тогда
				Ванесса.Объект.КаталогФич = "";
			КонецЕсли;	 
		КонецЕсли;	 
	ИначеЕсли Event = "ON_TAB_SELECT" Тогда
		Ванесса.МодульРедакторТекста().ПриСменеЗакладкиРедактора(Arg.tab);
	ИначеЕсли Event = "WELCOME_LAUNCH" Тогда
		Выполнить(Arg);
	ИначеЕсли Event = "WELCOME_RECENT" Тогда
		Ванесса.Объект.КаталогФич = Arg;
		Ванесса.ЗагрузитьФичи();
	ИначеЕсли Event = "PRESS_ESCAPE" Тогда
		Если (НЕ Ванесса.ЗначениеДополнительногоПараметра("ВЭтомСеансеИдётОбучение") = Истина)
			И Ванесса.ТекущийЭлемент = Ванесса.Элементы.VanessaEditor
			И (Ванесса.ВозможенЗапускСценариевИзТекущейВкладки() ИЛИ Ванесса.ЭтоВкладкаDiff(Ванесса.VanessaTabs.current)) Тогда
			Если Ванесса.Открыта() Тогда
				ПодключитьОбработчикОжидания("ЗакрытьОсновнуюФормуТаймер", 0.1, Истина);
			КонецЕсли;	
		КонецЕсли;	
	КонецЕсли;

КонецПроцедуры


&НаКлиенте
Процедура ПоказатьДеталиОшибкиVanessaEditor(ДанныеОшибки) Экспорт
	СохраненныеДанные = Ванесса.ДанныеОшибокVanessaEditor[ДанныеОшибки.id];
	Если СохраненныеДанные <> Неопределено Тогда
		ДопПараметры = Новый Структура;
		ДопПараметры.Вставить("ВозможнаАктуализацияШагаВРедакторе", Истина);
		Ванесса.ПоказатьТекстОшибки(СохраненныеДанные.ПолныйТекстОшибки, СохраненныеДанные.ПроизвольныеЗначения, СохраненныеДанные.НомерСтрокиДерева, ДопПараметры);
		Возврат;
	КонецЕсли;	 
	
	НомерСтроки = ДанныеОшибки.LineNumber;
	Если Ванесса.СделатьСтрокуДереваТекущейПоНомеруСтрокиФичи(НомерСтроки) Тогда
		Ванесса.ОбработкаДвойногоКликаПоДеревуШагов(Ложь, ДанныеОшибки);
	Иначе
		Ванесса.ПоказатьТекстОшибки(ДанныеОшибки.ErrorText, Неопределено, Неопределено);
	КонецЕсли;	 
КонецПроцедуры 


&НаКлиенте
Процедура ПерейтиВVanessaEditorПродолжение2() Экспорт
	
	Если НЕ Ванесса.РедакторБылПроинициализирован Тогда
		ПодключитьОбработчикОжидания("ПерейтиВVanessaEditorПродолжение2", 1, Истина);
		Возврат;
	КонецЕсли;	
	
	НадоБезусловноПерезагрузить = Ложь;
	
	Если НЕ ПустаяСтрока(Ванесса.Объект.КаталогФич) Тогда
		ДопПараметры = Новый Структура;
		ДопПараметры.Вставить("ПереходВРедакторИзДерева", Истина);
		ТекущиеДанные = Ванесса.Элементы.ДеревоТестов.ТекущиеДанные;
		ТекФича = Неопределено;
		Если ТекущиеДанные <> Неопределено Тогда
			Если ТекущиеДанные.Тип = "Каталог" И Ванесса.ФайлСуществуетКомандаСистемы(ТекущиеДанные.ПолныйПуть) И Ванесса.ЭтоКаталогКомандаСистемы(ТекущиеДанные.ПолныйПуть) Тогда
				Попытка  
					Если Ванесса.ЭтоВкладкаEdit(Ванесса.VanessaTabs.current) Тогда
						Ванесса.Объект.КаталогФич = Ванесса.VanessaTabs.current.filename;
						ТекФича = Ванесса.Объект.КаталогФич;
						НадоБезусловноПерезагрузить = Истина;
					КонецЕсли;	
				Исключение
					Возврат;
				КонецПопытки;
			Иначе	
				ФичаПодсенария = Ванесса.ПолучитьИмяФичиИзПолногоПути(ТекущиеДанные.ПолныйПуть);
				Если Прав(НРег(ФичаПодсенария), 8) = ".feature" Тогда
					ТекФича = ФичаПодсенария;
				КонецЕсли;	 
			КонецЕсли;	 
			
			ЗагруженКаталог = Ванесса.ЭтоКаталогКомандаСистемы(Ванесса.Объект.КаталогФич);
			
			Если ЗагруженКаталог ИЛИ (ТекФича <> Неопределено И НРег(ТекФича) <> НРег(Ванесса.Объект.КаталогФич)) Тогда
				ЭтоПример = Ложь;
				ЭтоШагКонтекста = Ложь;
				СтрокаСценария = Ванесса.НайтиСтрокуСценарияЧерезРодителя(ТекущиеДанные, ЭтоПример, ЭтоШагКонтекста);
				СтрокаФичи = Ванесса.НайтиСтрокуФичиЧерезРодителя(ТекущиеДанные);
				ТекущаяСтрока = ТекущиеДанные;
				
				Если ТекФича <> Неопределено Тогда
					Ванесса.Объект.КаталогФич = ТекФича;
				ИначеЕсли СтрокаФичи <> Неопределено Тогда
					Ванесса.Объект.КаталогФич = СтрокаФичи.ПолныйПуть;
				КонецЕсли;	 
				
				Если ТекущаяСтрока <> Неопределено Тогда
					Ванесса.ДанныеДляОбновленияСтрокиРедактораПоТекущейСтрокеДерева = Новый Структура;
					Ванесса.ДанныеДляОбновленияСтрокиРедактораПоТекущейСтрокеДерева.Вставить("ИдСтроки", ТекущаяСтрока.ИдСтроки);
					Ванесса.ДанныеДляОбновленияСтрокиРедактораПоТекущейСтрокеДерева.Вставить("НомерСтрокиВФиче", ТекущаяСтрока.НомерСтрокиВФиче);
					ДопПараметры.Вставить("ВыполнитьПроцедуруЧерезОбработчикОжидания", "ОбновитьТекущуюСтрокуРедактораПоТекущейСтрокеДереваОбработчик");
				ИначеЕсли СтрокаФичи <> Неопределено И СтрокаСценария <> Неопределено Тогда
					Ванесса.ДанныеДляОбновленияСтрокиРедактораПоТекущейСтрокеДерева = Новый Структура;
					Ванесса.ДанныеДляОбновленияСтрокиРедактораПоТекущейСтрокеДерева.Вставить("ИдСтроки", СтрокаСценария.ИдСтроки);
					Ванесса.ДанныеДляОбновленияСтрокиРедактораПоТекущейСтрокеДерева.Вставить("НомерСтрокиВФиче", СтрокаСценария.НомерСтрокиВФиче);
					ДопПараметры.Вставить("ВыполнитьПроцедуруЧерезОбработчикОжидания", "ОбновитьТекущуюСтрокуРедактораПоТекущейСтрокеДереваОбработчик");
				КонецЕсли;	 
			Иначе	
				Ванесса.ДанныеДляОбновленияСтрокиРедактораПоТекущейСтрокеДерева = Новый Структура;
				Ванесса.ДанныеДляОбновленияСтрокиРедактораПоТекущейСтрокеДерева.Вставить("ИдСтроки", ТекущиеДанные.ИдСтроки);
				Ванесса.ДанныеДляОбновленияСтрокиРедактораПоТекущейСтрокеДерева.Вставить("НомерСтрокиВФиче", ТекущиеДанные.НомерСтрокиВФиче);
				ДопПараметры.Вставить("ВыполнитьПроцедуруЧерезОбработчикОжидания", "ОбновитьТекущуюСтрокуРедактораПоТекущейСтрокеДереваОбработчик");
			КонецЕсли;	
		КонецЕсли;	 
		
		Если ТекФича = Неопределено ИЛИ ЗагруженКаталог ИЛИ НРег(ТекФича) <> НРег(Ванесса.Объект.КаталогФич) ИЛИ НЕ Ванесса.ЕстьВкладкаСДаннойФичей(ТекФича) ИЛИ НадоБезусловноПерезагрузить Тогда
			Ванесса.КомандаПерезагрузить(ДопПараметры);
		Иначе
			Если ДопПараметры.Свойство("ВыполнитьПроцедуруЧерезОбработчикОжидания") Тогда
				ПодключитьОбработчикОжидания(ДопПараметры.ВыполнитьПроцедуруЧерезОбработчикОжидания, 0.1, Истина);
			КонецЕсли;	 
		КонецЕсли;	 
		
	КонецЕсли;	 
	
Конецпроцедуры	


