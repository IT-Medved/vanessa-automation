&НаКлиенте
Процедура VanessaEditorПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка) Экспорт
	Element = ДанныеСобытия.Element;
	Если НРег(Element.tagName) = "body" Тогда  
		Если ДанныеСобытия.Event.type <> "click" Тогда
			Возврат;
		КонецЕсли;     
		
		ДанныеСобытияДля1С = ДанныеСобытия.Event.detail;    
		//Отсекаем события сгенерированные обычными кликами
		Если ДанныеСобытияДля1С = Неопределено Или ТипЗнч(ДанныеСобытияДля1С) = Тип("Число") Тогда
			Возврат;
		КонецЕсли;
        ИмяСобытия = ДанныеСобытияДля1С.name;  //Строка
		ДополнительныеДанныеСобытия = ДанныеСобытияДля1С.data; // Неопределено, Строка, ВнешнийОбъект
		
		Если Не ЗначениеЗаполнено(ИмяСобытия) Тогда
			Возврат;	
		КонецЕсли;
		
		VanessaEditorOnReceiveEventHandler(ИмяСобытия, ДополнительныеДанныеСобытия);
	ИначеЕсли КодСимвола(Element.innerText, 1) = 60020 Тогда
		//кнопка "i" во всплывающем окошке с информацией о шаге
		Ванесса.МодульРедакторТекста().ПоказатьПодробнуюИнформациюОШаге(Element.title);
	ИначеЕсли КодСимвола(Element.innerText, 1) = 60277 Тогда
		Ванесса.ОзвучитьСтрокуСценарияПоНомеру(Element.title);
	КонецЕсли;
	
	ИгнорироватьИзмененияVanessaEditor = Ложь;
	
КонецПроцедуры

