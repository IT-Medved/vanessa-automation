&НаКлиенте
Процедура ИнициализироватьVanessaEditorUrl(БылоИзменениеUrl = Ложь) Экспорт
	
	Если ПустаяСтрока(Ванесса.VanessaEditorМакет) Тогда
		Возврат;
	КонецЕсли;   
	
	Если НЕ Ванесса.ИнициализироватьVanessaEditorНаКлиенте Тогда
		Возврат;
	КонецЕсли;	
	
	Если НЕ Ванесса.VanessaEditorМакет = "Cache" Тогда
		ДвоичныеДанные = ПолучитьИзВременногоХранилища(Ванесса.VanessaEditorМакет);
		УдалитьИзВременногоХранилища(Ванесса.VanessaEditorМакет);
	КонецЕсли;
	Ванесса.VanessaEditorМакет = "";
	
	НадоРаспаковатьФайлы = Истина;
	#Если ВебКлиент Тогда
		VanessaEditorКаталог = "";
	#Иначе
		VanessaEditorКаталог = Ванесса.МодульОбщегоНазначенияVA().КаталогVanessaEditor(Ванесса.ВерсияРедактора());
	#КонецЕсли
	Если ЗначениеЗаполнено(VanessaEditorКаталог) Тогда
		Если НЕ Ванесса.ФайлСуществуетКомандаСистемы(VanessaEditorКаталог) Тогда
			Попытка
				Ванесса.СоздатьКаталогКомандаСистемы(VanessaEditorКаталог);
			Исключение
				#Если НЕ ВебКлиент Тогда
				VanessaEditorКаталог = ПолучитьИмяВременногоФайла();
				Ванесса.СоздатьКаталогКомандаСистемы(VanessaEditorКаталог);
				#КонецЕсли
			КонецПопытки;
		Иначе
			НадоРаспаковатьФайлы = Ложь;
		КонецЕсли;	
	Иначе	         
		
		#Если ВебКлиент Тогда
			Ванесса.VanessaEditorURL = "";
		#Иначе
			VanessaEditorКаталог = ПолучитьИмяВременногоФайла();
			Ванесса.СоздатьКаталогКомандаСистемы(VanessaEditorКаталог);
		#КонецЕсли
		
	КонецЕсли;	
	
	#Если ВебКлиент Тогда
		Ванесса.VanessaEditorURL = "";
	#Иначе
	Попытка             
		Если НадоРаспаковатьФайлы Тогда
			ЧтениеZipФайла = Новый ЧтениеZipФайла(ДвоичныеДанные.ОткрытьПотокДляЧтения());
			ЧтениеZipФайла.ИзвлечьВсе(VanessaEditorКаталог, Вычислить("РежимВосстановленияПутейФайловZIP.Восстанавливать"));
			ЧтениеZipФайла.Закрыть();
		КонецЕсли;	
		Ванесса.VanessaEditorURL = Ванесса.ДополнитьСлешВПуть(VanessaEditorКаталог) + "index.html?localeCode=" + Лев(ТекущийЯзыкСистемы(), 2);
		БылоИзменениеUrl = Истина;
	Исключение
		Ванесса.VanessaEditorURL = "";
	КонецПопытки;
	
	#КонецЕсли

КонецПроцедуры


