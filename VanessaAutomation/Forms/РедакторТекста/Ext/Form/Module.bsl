			Продолжить;
		КонецЕсли;	
		
		Если Найти(Элем.Ключ, "_Цикл_") > 0 Тогда
			Продолжить;
		КонецЕсли;	 
		
		ДанныеПеременных.Вставить(Элем.Ключ, Строка(Элем.Значение));
	КонецЦикла;	 
	Возврат Ванесса.ЗаписатьОбъектJSON(ДанныеПеременных);
