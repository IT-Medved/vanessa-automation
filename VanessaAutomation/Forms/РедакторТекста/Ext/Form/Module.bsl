	ТекстJSON = Ванесса.ЗаписатьОбъектJSON(СтруктураПараметров);
	Ванесса.VanessaTabs.welcome(Ванесса.Локализовать("Добро пожаловать!"), ТекстJSON);
	Ванесса.Объект.КаталогФич = "";

